    function generateEnemy(floor) {
        if (floor === 100) return { name: "SANS", level: 100, maxHp: 9999, hp: 9999, atk: Math.floor(150 * diffMult), sprite: spr_sans, color: "#ffffff", eMove: "GASTER BLASTER", intro: "do you wanna have a bad time?", domain: null, ultimate: { name: "BONE ZONE", used: false }, isSans: true };
        
        let isBoss = (floor % 10 === 0);
        let name = (isBoss ? "BOSS: " : "") + ["ROGUE","CURSED","ELITE","CORRUPTED","DEMON"][Math.floor(Math.random()*5)] + " " + ["SHINOBI","SPIRIT","SAIYAN","PIRATE","HOLLOW"][Math.floor(Math.random()*5)];
        let hpScale = (80 + (floor * 50)) * diffMult * (isBoss ? 2.5 : 1);
        let atkScale = (15 + (floor * 10)) * diffMult * (isBoss ? 1.5 : 1);
        let pColor = ['#ef4444', '#3b82f6', '#10b981', '#a855f7', '#f59e0b', '#ec4899'][Math.floor(Math.random()*6)];
        
        return { name: name, level: floor, maxHp: Math.floor(hpScale), hp: Math.floor(hpScale), atk: Math.floor(atkScale), sprite: spr_enemies[Math.floor(Math.random() * spr_enemies.length)], color: pColor, eMove: ["SLICING WAVE", "ENERGY BLAST", "BRUTAL STRIKE", "DARK ORB"][Math.floor(Math.random()*4)], intro: `Floor ${floor} Guardian appears!`, domain: (isBoss || Math.random() < 0.1) ? { name: "MALEVOLENT SHRINE", color1: "#450a0a", color2: "#000" } : null, ultimate: { name: "DEATH BLOW", used: false } };
