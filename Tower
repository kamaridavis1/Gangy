        document.getElementById('p-lv').innerText = `Lv${player.level}`; document.getElementById('p-hp-text').innerText = `${Math.floor(player.hp)}/${player.maxHp}`;
        document.getElementById('p-hp-bar').style.width = Math.max(0, (player.hp / player.maxHp) * 100) + '%';
        document.getElementById('p-domain-bar').style.width = (player.domainMeter / 5) * 100 + '%';

