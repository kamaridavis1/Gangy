        ["0000011110000000", "0001A3333A100000", "0013333333310000", "0017711117710000", "0017721127710000", "0017771177710000", "00011AAAA1100000", "0001A1AA1A100000", "001AA1AA1AA10000", "00101AAAA1010000", "000011AA11000000", "0000110011000000", "0000110011000000", "0001110011100000", "0000000000000000", "0000000000000000"]
