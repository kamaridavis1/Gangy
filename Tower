            playAnim('PLAYER_ATTACK', () => {
                if(m.t === 'buff') { player.atk += Math.floor(player.atk * 0.25); queueText(`ATK sharply rose!`); } 
                else {
                    let dmg = getDamage(player.atk, m.p, 'player');
                    if (dmg === 0 && currentEnemy.isSans) queueText(`SANS dodged it!`);
                    else {
                        currentEnemy.hp = Math.max(0, currentEnemy.hp - dmg); queueText(`Dealt ${dmg} damage!`);
