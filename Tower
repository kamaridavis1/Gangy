        onQueueEmpty = () => {
            if(it.type === 'heal_50') player.hp = Math.min(player.maxHp, player.hp + player.maxHp*0.5);
            if(it.type === 'heal_full') player.hp = player.maxHp;
            if(it.type === 'invuln') player.invulnTurns = 1;
            if(it.type === 'domain') player.domainMeter = 5;
            updateHUD(); endPlayerTurn();
        }; processTextQueue();
    }

    function getDamage(base, mult, attacker, forceHit=false) {
        if(attacker === 'enemy' && player.invulnTurns > 0) return 0;
        if(attacker === 'player' && currentEnemy.isSans && !forceHit && !(activeDomain && activeDomain.owner === 'player')) return 0; // Sans dodges
        let d = Math.floor(base * mult * (0.85 + Math.random()*0.3));
        if (activeDomain && activeDomain.owner === attacker) d = Math.floor(d * 1.5);
        if (attacker === 'enemy' && player.vulnerable) d = Math.floor(d * 2.0);
        if (attacker === 'player' && player.vulnerable) d = Math.floor(d * 0.5);
        return Math.max(1, d);
    }

    function endPlayerTurn() {
        onQueueEmpty = () => {
            if (currentEnemy.hp <= 0) { handleVictory(); return; }
            if (player.hp <= 0) { handleDefeat(); return; }
            player.vulnerable = false; if(player.invulnTurns > 0) player.invulnTurns--;

            if (activeDomain && activeDomain.owner === 'player') {
                activeDomain.turnsLeft--;
                if (activeDomain.turnsLeft > 0) { queueText(`DOMAIN ACTIVE! (${activeDomain.turnsLeft} turns left)`); onQueueEmpty = showActionMenu; processTextQueue(); } 
                else {
                    document.getElementById('game-wrapper').classList.add('glitch-effect'); setTimeout(() => document.getElementById('game-wrapper').classList.remove('glitch-effect'), 500);
                    queueText(`DOMAIN COLLAPSED! ${player.name} is VULNERABLE!`); activeDomain = null; player.vulnerable = true;
                    document.body.className = player.transformed ? 'transformed-ui' : ''; onQueueEmpty = executeEnemyTurn; processTextQueue();
                }
            } else { player.domainMeter = Math.min(5, player.domainMeter + 1); executeEnemyTurn(); }
        }; processTextQueue();
    }

    function executeEnemyTurn() {
        let e = currentEnemy;
        if (e.hp <= e.maxHp * 0.5 && !e.ultimate.used) {
            e.ultimate.used = true;
            triggerCutscene(`${e.name}:\n${e.ultimate.name}!`, () => {
                queueText(`${e.name} unleashes their Ultimate Attack!`);
                onQueueEmpty = () => {
                    if (player.hp <= player.maxHp * 0.5) {
                        queueText(`Counter with your ULTIMATE?`);
                        onQueueEmpty = () => { document.getElementById('dialogue-text').innerText = "COUNTER?"; document.getElementById('action-menu').innerHTML = `<button class="menu-btn" style="color:red; grid-column: span 2;" onclick="acceptClash()">YES (ULTIMATE)</button><button class="menu-btn" style="grid-column: span 2;" onclick="declineClash()">NO (DEFEND)</button>`; document.getElementById('action-menu').classList.remove('hidden'); gameState = "MENU"; }; processTextQueue();
                    } else {
                        playAnim('ENEMY_ULTIMATE', () => { triggerScreenShatter(); let dmg = getDamage(e.atk, 2.5, 'enemy'); player.hp = Math.max(0, player.hp - dmg); updateHUD(); queueText(dmg===0?`Blocked by SHIELD!`:`Took ${dmg} DMG!`); onQueueEmpty = () => { if(player.hp<=0) handleDefeat(); else showActionMenu(); }; processTextQueue(); });
                    }
                }; processTextQueue();
            }); return;
        }

        if (!activeDomain && e.domain) {
            triggerCutscene(`${e.name}: DOMAIN EXPANSION!\n${e.domain.name}`, () => {
                activeDomain = { owner: 'enemy', color1: e.domain.color1, color2: e.domain.color2, turnsLeft: 99 }; createShockwave(120, 80, e.domain.color1, 15, 10); queueText(`Enemy expanded their Domain!`); e.domain = null; onQueueEmpty = showActionMenu; processTextQueue();
            }); return;
        }

        queueText(`--- ENEMY TURN ---`); queueText(`${e.name} used ${e.eMove}!`);
        onQueueEmpty = () => {
            playAnim('ENEMY_ATTACK', () => { let dmg = getDamage(e.atk, 1.2, 'enemy'); player.hp = Math.max(0, player.hp - dmg); updateHUD(); queueText(dmg===0?`Blocked by SHIELD!`:`Took ${dmg} damage!`); onQueueEmpty = () => { if(player.hp<=0) handleDefeat(); else showActionMenu(); }; processTextQueue(); }, e.color);
        }; processTextQueue();
    }

    window.acceptClash = function() { document.getElementById('action-menu').classList.add('hidden'); resetActionMenu(); document.getElementById('game-wrapper').classList.add('glitch-effect'); setTimeout(() => document.getElementById('game-wrapper').classList.remove('glitch-effect'), 500); triggerCutscene(`${player.name}:\n${player.ultName}!`, startClash); }
    window.declineClash = function() { document.getElementById('action-menu').classList.add('hidden'); resetActionMenu(); playAnim('ENEMY_ULTIMATE', () => { triggerScreenShatter(); let dmg = getDamage(currentEnemy.atk, 1.5, 'enemy'); player.hp = Math.max(0, player.hp - dmg); updateHUD(); queueText(dmg===0?`Guarded by SHIELD!`:`Guarded! Took ${dmg} DMG!`); onQueueEmpty = () => { if(player.hp<=0) handleDefeat(); else showActionMenu(); }; processTextQueue(); }); }
    function resetActionMenu() { document.getElementById('action-menu').innerHTML = `<button class="menu-btn" onclick="openMenu('moves')">MOVES</button><button class="menu-btn" onclick="openMenu('items')">ITEMS</button><button class="menu-btn" id="btn-domain" onclick="handleAction('domain')" style="color:#a855f7;">DOMAIN</button><button class="menu-btn" id="btn-awaken" onclick="handleAction('awaken')" style="color:#eab308;">AWAKEN</button><button class="menu-btn" id="btn-ultimate" onclick="handleAction('ultimate')" style="color:#ef4444; font-weight:bold; grid-column:span 2;">ULTIMATE</button>`; }
    function startClash() { gameState = "CLASH"; clashActive = true; clashValue = 50; clashTimer = 100; document.getElementById('clash-layer').classList.remove('hidden'); updateClashUI(); }
    window.mashClash = function() { if(!clashActive) return; clashValue += 7; emitParticles(120, 80, player.color, 3, 10, 20); updateClashUI(); }
    function updateClashUI() { let bar = document.getElementById('clash-bar-fill'); bar.style.width = Math.max(0, Math.min(100, clashValue)) + '%'; bar.style.backgroundColor = clashValue > 50 ? player.color : '#ef4444'; }
    function resolveClash() {
        clashActive = false; document.getElementById('clash-layer').classList.add('hidden');
        if (clashValue >= 100 || (clashValue > 50 && clashTimer <= 0)) { playAnim('PLAYER_ULTIMATE', () => { triggerScreenShatter(); let dmg = getDamage(player.atk, 6.0, 'player', true); currentEnemy.hp = Math.max(0, currentEnemy.hp - dmg); updateHUD(); queueText(`CLASH WON! Dealt ${dmg} DMG!`); endPlayerTurn(); }); } 
        else { playAnim('ENEMY_ULTIMATE', () => { triggerScreenShatter(); let dmg = getDamage(currentEnemy.atk, 6.0, 'enemy'); player.hp = Math.max(0, player.hp - dmg); updateHUD(); queueText(dmg===0?`Lost Clash! But SHIELD blocked it!`:`CLASH LOST! Took ${dmg} DMG!`); onQueueEmpty = () => { if(player.hp<=0) handleDefeat(); else showActionMenu(); }; processTextQueue(); }); }
    }

    // --- RENDERING & EFFECTS ---
    function triggerScreenShatter() {
        let flash = document.getElementById('flash-overlay'); flash.classList.remove('super-flash'); void flash.offsetWidth; flash.classList.add('super-flash');
        let wrapper = document.getElementById('game-wrapper'); wrapper.classList.add('shatter-shake'); setTimeout(() => wrapper.classList.remove('shatter-shake'), 1200);
        glassShards = []; let cx = 450; let cy = 300; 
        for(let i=0; i<80; i++) {
            let angle = Math.random() * Math.PI * 2, speed = 10 + Math.random() * 30, points = []; let numPts = 3 + Math.floor(Math.random()*5);
            for(let p=0; p<numPts; p++) points.push({ x: (Math.random()-0.5)*120, y: (Math.random()-0.5)*120 });
            glassShards.push({ x: cx + (Math.random()-0.5)*50, y: cy + (Math.random()-0.5)*50, vx: Math.cos(angle)*speed, vy: Math.sin(angle)*speed, rot: Math.random()*Math.PI*2, vrot: (Math.random()-0.5)*1.5, points: points, life: 80 });
        }
    }
    function emitParticles(x, y, color, count, speed=2, life=30) { for(let i=0; i<count; i++) particles.push({ x, y, vx: (Math.random()-0.5)*speed*2, vy: (Math.random()-0.5)*speed*2, color, life: life + Math.random()*15, maxLife: life }); }
    function createShockwave(x, y, color, speed=5, width=3) { shockwaves.push({ x, y, radius: 1, maxRadius: 200, color, speed, width, life: 1.0 }); }
    function darkenColor(hex, factor) { if(!hex || hex === 'none') return '#000'; let r = parseInt(hex.slice(1,3), 16) * factor; let g = parseInt(hex.slice(3,5), 16) * factor; let b = parseInt(hex.slice(5,7), 16) * factor; return `rgb(${Math.floor(r)},${Math.floor(g)},${Math.floor(b)})`; }

    function drawSprite(arr, x, y, scale=4, flash=false, isTransformed=false, overrideColor=null, auraColor=null) {
        if (!arr) return;
        ctx.fillStyle = 'rgba(0,0,0,0.4)'; for(let r=0; r<16; r++) for(let c=0; c<16; c++) if(arr[r][c] !== '0') ctx.fillRect(x + c*scale + scale, y + r*scale + scale*2, scale, scale);
        if (isTransformed && auraColor) { ctx.shadowColor = auraColor; ctx.shadowBlur = 20; }
        for (let r=0; r<16; r++) {
            for (let c=0; c<16; c++) {
                let ch = arr[r][c];
                if (ch !== '0') {
                    let fill = flash ? '#ffffff' : colors[ch];
                    if (ch === '2' && overrideColor) fill = overrideColor;
                    if (ch === '6' && isTransformed && auraColor) fill = auraColor; // Replace hair color if transformed
                    if (!flash && r > 9 && ch !== '1') fill = darkenColor(fill, 0.6);
                    ctx.fillStyle = fill; ctx.fillRect(x + c*scale, y + r*scale, scale, scale);
                }
            }
        }
        ctx.shadowBlur = 0;
    }

    function renderGame() {
        ctx.clearRect(0, 0, 240, 160); let camX = 0, camY = 0; if (animState === "SHAKE") { camX = (Math.random() - 0.5) * 12; camY = (Math.random() - 0.5) * 12; }
        ctx.save(); ctx.translate(camX, camY);

        if (activeDomain) {
            let grad = ctx.createRadialGradient(120, 80, 10, 120, 80, 150 + Math.sin(frameCount*0.05)*20);
            grad.addColorStop(0, activeDomain.color1); grad.addColorStop(1, activeDomain.color2); ctx.fillStyle = grad; ctx.fillRect(0,0,240,160);
            if (frameCount%3===0) emitParticles(Math.random()*240, 160, '#ffffff', 2, 0.8, 60);
        } else {
            let skyGrad = ctx.createLinearGradient(0,0,0,100); skyGrad.addColorStop(0, '#1e1b4b'); skyGrad.addColorStop(1, '#4c1d95'); ctx.fillStyle = skyGrad; ctx.fillRect(0, 0, 240, 100);
            let floorGrad = ctx.createLinearGradient(0,100,0,160); floorGrad.addColorStop(0, '#312e81'); floorGrad.addColorStop(1, '#1e1b4b'); ctx.fillStyle = floorGrad; ctx.fillRect(0, 100, 240, 60);
            ctx.fillStyle = 'rgba(0,0,0,0.4)'; ctx.beginPath(); ctx.ellipse(180, 75, 45, 12, 0, 0, Math.PI*2); ctx.fill(); ctx.beginPath(); ctx.ellipse(60, 145, 50, 15, 0, 0, Math.PI*2); ctx.fill();
        }

        if (eVis && currentEnemy) drawSprite(currentEnemy.sprite, ePos.x + eOff.x, ePos.y + eOff.y + (currentEnemy.isSans?Math.sin(frameCount*0.1)*5:0), 4, eFlash, false, currentEnemy.color);
        if (pVis) drawSprite(player.transformed ? spr_awaken : spr_base, pPos.x + pOff.x, pPos.y + pOff.y, 4, pFlash, player.transformed, player.color, player.transformData.color);

        shockwaves.forEach(s => { ctx.beginPath(); ctx.arc(s.x, s.y, s.radius, 0, Math.PI*2); ctx.strokeStyle = `rgba(${parseInt(s.color.slice(1,3),16)},${parseInt(s.color.slice(3,5),16)},${parseInt(s.color.slice(5,7),16)},${s.life})`; ctx.lineWidth = s.width; ctx.stroke(); });
        particles.forEach(p => { ctx.fillStyle = p.color; let size = Math.max(1, (p.life/p.maxLife) * 4); ctx.fillRect(p.x, p.y, size, size); });

        if (animState === "BEAM") { ctx.fillStyle = animData.color; ctx.fillRect(animData.x, animData.y, animData.w, animData.h); ctx.fillStyle = '#fff'; ctx.fillRect(animData.x, animData.y + animData.h/4, animData.w, animData.h/2); emitParticles(animData.x + (animData.w > 0 ? animData.w : 0), animData.y + animData.h/2, animData.color, 5, 8, 20); } 
        else if (animState === "SLASH") { ctx.strokeStyle = '#fff'; ctx.lineWidth = animData.w; ctx.beginPath(); ctx.moveTo(animData.x1, animData.y1); ctx.lineTo(animData.x2, animData.y2); ctx.stroke(); ctx.strokeStyle = animData.color; ctx.lineWidth = animData.w/2; ctx.beginPath(); ctx.moveTo(animData.x1, animData.y1); ctx.lineTo(animData.x2, animData.y2); ctx.stroke(); } 
        else if (animState === "GLITCH") { for(let i=0; i<10; i++) { ctx.fillStyle = ['#f00', '#0f0', '#00f', '#fff'][Math.floor(Math.random()*4)]; ctx.fillRect(Math.random()*240, Math.random()*160, Math.random()*40, Math.random()*10); } }
        ctx.restore();

        sCtx.clearRect(0,0,900,600);
        if (glassShards.length > 0) {
            for(let i = glassShards.length-1; i>=0; i--) {
                let s = glassShards[i]; s.x += s.vx; s.y += s.vy; s.rot += s.vrot; s.life--;
                sCtx.save(); sCtx.translate(s.x, s.y); sCtx.rotate(s.rot); sCtx.beginPath(); sCtx.moveTo(s.points[0].x, s.points[0].y); for(let j=1; j<s.points.length; j++) sCtx.lineTo(s.points[j].x, s.points[j].y); sCtx.closePath();
                sCtx.fillStyle = `rgba(255, 255, 255, ${s.life/80})`; sCtx.fill(); sCtx.strokeStyle = `rgba(100, 200, 255, ${(s.life/80)*0.8})`; sCtx.lineWidth = 3; sCtx.stroke(); sCtx.restore();
                if (s.life <= 0) glassShards.splice(i, 1);
            }
        }
    }

    function triggerCutscene(text, callback) { gameState = "CUTSCENE"; let layer = document.getElementById('cutscene-layer'); let textEl = document.getElementById('cutscene-text'); textEl.innerText = text; textEl.style.animation = 'none'; textEl.offsetHeight; textEl.style.animation = null; layer.classList.remove('hidden'); setTimeout(() => { layer.classList.add('hidden'); callback(); }, 1500); }
    function playAnim(type, callback, color = '#ffffff') {
        animState = type; animTimer = 0; animData.color = color;
        let int = setInterval(() => {
            animTimer++;
            if (type === 'PLAYER_ATTACK') {
                if(animTimer===1) pOff.x = 10; if(animTimer===10) { pOff.x=0; animState="BEAM"; animData={x:80,y:90,w:0,h:12,color}; }
                if(animTimer>10 && animTimer<20) animData.w += 15; if(animTimer===20) { animState="SHAKE"; eFlash=true; emitParticles(150,30,color,15,5,20); }
                if(animTimer===35) { eFlash=false; animState=null; clearInterval(int); callback(); }
            } else if (type === 'ENEMY_ATTACK') {
                if(animTimer===1) eOff.x = -10; if(animTimer===10) { eOff.x=0; animState="BEAM"; animData={x:150,y:30,w:0,h:18,color}; }
                if(animTimer>10 && animTimer<20) { animData.w -= 15; animData.x -= 15; } if(animTimer===20) { animState="SHAKE"; pFlash=true; emitParticles(30,80,color,15,5,20); }
                if(animTimer===35) { pFlash=false; animState=null; clearInterval(int); callback(); }
            } else if (type === 'PLAYER_HEAL') {
                if(animTimer%2===0) { emitParticles(pPos.x+16, pPos.y+16, color, 10, 8, 30); createShockwave(pPos.x+16, pPos.y+16, color, 8, 2); }
                if(animTimer===40) { animState=null; clearInterval(int); callback(); }
            } else if (type === 'PLAYER_ULTIMATE') {
                let uc = player.color;
                if (player.ultType === "BEAM") {
                    if(animTimer===1) { animState="SHAKE"; emitParticles(pPos.x+16, pPos.y+16, uc, 40, 10, 50); }
                    if(animTimer===20) { animState="BEAM"; animData={x:50,y:-20,w:0,h:200,color:uc}; document.getElementById('game-wrapper').style.filter = "invert(1)"; } 
                    if(animTimer>20 && animTimer<35) animData.w += 20;
                    if(animTimer===35) { animState="SHAKE"; eFlash=true; emitParticles(150,30,uc,80,20,40); document.getElementById('game-wrapper').style.filter = "none"; createShockwave(180, 50, uc, 10, 5); }
                } else if (player.ultType === "BURST") {
                    if(animTimer===1) { animState="SHAKE"; emitParticles(pPos.x+16, pPos.y+16, uc, 60, 15, 60); }
                    if(animTimer===20) { animState="SHAKE"; eFlash=true; createShockwave(180, 50, uc, 25, 20); document.getElementById('game-wrapper').style.filter = "saturate(5) hue-rotate(90deg)"; }
                    if(animTimer===30) { createShockwave(180, 50, '#fff', 30, 10); emitParticles(180, 50, uc, 100, 25, 50); }
                    if(animTimer===40) document.getElementById('game-wrapper').style.filter = "none";
                } else if (player.ultType === "SLASH") {
                    if(animTimer===1) { animState="SHAKE"; pOff.x = 100; pOff.y = -50; }
                    if(animTimer===15) { animState="SLASH"; animData={x1: 240, y1: 0, x2: 0, y2: 160, color: uc, w: 2}; document.getElementById('game-wrapper').style.filter = "invert(1)"; }
                    if(animTimer>15 && animTimer<25) { animData.w += 5; eFlash = true; }
                    if(animTimer===25) { animState="SHAKE"; pOff.x = 0; pOff.y = 0; document.getElementById('game-wrapper').style.filter = "none"; emitParticles(180, 50, uc, 50, 15, 30); }
                } else if (player.ultType === "QUAKE") {
                    if(animTimer===1) { animState="SHAKE"; document.getElementById('game-wrapper').classList.add('shatter-shake'); }
                    if(animTimer===20) { animState="SHAKE"; document.getElementById('game-wrapper').classList.remove('shatter-shake'); eFlash=true; for(let q=0; q<5; q++) createShockwave(180, 100, uc, 15+q*2, 10); emitParticles(180, 100, '#444', 100, 15, 40); }
                } else if (player.ultType === "GLITCH") {
                    if(animTimer===1) { animState="GLITCH"; document.getElementById('game-wrapper').classList.add('glitch-effect'); }
                    if(animTimer===30) { animState="SHAKE"; eFlash=true; createShockwave(180, 50, uc, 50, 5); document.getElementById('game-wrapper').classList.remove('glitch-effect'); }
                }
                if(animTimer===65) { eFlash=false; animState=null; clearInterval(int); callback(); }
            } else if (type === 'ENEMY_ULTIMATE') {
                let ec = currentEnemy.color;
                if(animTimer===1) { animState="SHAKE"; emitParticles(ePos.x+16, ePos.y+16, ec, 40, 10, 50); }
                if(animTimer===20) { animState="BEAM"; animData={x:190,y:-20,w:0,h:200,color:ec}; document.getElementById('game-wrapper').style.filter = "invert(1) hue-rotate(180deg)"; } 
                if(animTimer>20 && animTimer<35) { animData.w -= 20; animData.x -= 20; }
                if(animTimer===35) { animState="SHAKE"; pFlash=true; emitParticles(30,80,ec,80,20,40); document.getElementById('game-wrapper').style.filter = "none"; createShockwave(60, 120, ec, 10, 5); }
                if(animTimer===65) { pFlash=false; animState=null; clearInterval(int); callback(); }
            } else if (type === 'ENEMY_FAINT') {
                eOff.y += 4; emitParticles(ePos.x+16, ePos.y+eOff.y, '#ffffff', 2, 1, 10);
                if (animTimer === 30) { eVis = false; animState=null; clearInterval(int); callback(); }
            }
        }, 1000/60); 
    }

    // --- PROGRESSION, LOOT & SHOP ---
    function handleVictory() {
        playAnim('ENEMY_FAINT', () => {
            let drop = Math.floor(currentFloor * (Math.random() * 10 + 5) * diffMult);
            player.money += drop;
            queueText(`Obliterated ${currentEnemy.name}! Gained $${drop}.`);
            queueText(`${player.name} grew to level ${player.level + 1}!`);
            onQueueEmpty = () => { showLootScreen(); }; processTextQueue();
        });
    }

    function handleDefeat() { queueText(`${player.name} was overwhelmed...`); onQueueEmpty = () => { document.getElementById('death-stats').innerText = `You reached TOWER FLOOR ${currentFloor}.`; document.getElementById('game-over-screen').classList.remove('hidden'); gameState = "GAMEOVER"; }; processTextQueue(); }

    function showLootScreen() {
        gameState = "LOOT"; document.getElementById('loot-screen').classList.remove('hidden'); let container = document.getElementById('loot-container'); container.innerHTML = '';
        let rewards = [];
        while(rewards.length < 3) { let randMove = ALL_ATTACKS[Math.floor(Math.random() * ALL_ATTACKS.length)]; if(!rewards.find(r => r.n === randMove.n)) rewards.push(randMove); }
        rewards.forEach(r => { let card = document.createElement('div'); card.className = 'card'; card.innerHTML = `<div class="card-title" style="color:${r.c}">${r.n}</div><div class="card-desc">${r.d}</div><div class="card-desc" style="background:#333; padding:0.2vw;">${r.t.toUpperCase()}</div>`; card.onclick = () => claimLoot(r); container.appendChild(card); });
    }

    function claimLoot(move) {
        if (player.moves.find(m => m.n === move.n)) return alert("You already know this move!");
        if (player.moves.length >= 4) { pendingLootMove = move; document.getElementById('loot-screen').classList.add('hidden'); showReplaceScreen(); } 
        else { player.moves.push(move); document.getElementById('loot-screen').classList.add('hidden'); checkShopAndAdvance(); }
    }

    function showReplaceScreen() { gameState = "REPLACE"; document.getElementById('replace-screen').classList.remove('hidden'); document.getElementById('replace-prompt').innerText = `Learn [${pendingLootMove.n}]. Which move will you forget?`; let grid = document.getElementById('replace-grid'); grid.innerHTML = ''; player.moves.forEach((m, i) => { let btn = document.createElement('button'); btn.className = 'big-btn'; btn.style.width = '100%'; btn.style.fontSize = '1.2vw'; btn.innerHTML = `<span style="color:${m.c}">${m.n}</span>`; btn.onclick = () => { player.moves[i] = pendingLootMove; document.getElementById('replace-screen').classList.add('hidden'); checkShopAndAdvance(); }; grid.appendChild(btn); }); }
    window.cancelReplace = function() { document.getElementById('replace-screen').classList.add('hidden'); checkShopAndAdvance(); }
    window.skipMenu = function(menuId) { document.getElementById(menuId + '-screen').classList.add('hidden'); if(menuId==='loot') checkShopAndAdvance(); else advanceFloor(); }

    function checkShopAndAdvance() {
        if(currentFloor % 5 === 0) {
            gameState = "SHOP"; document.getElementById('shop-screen').classList.remove('hidden'); document.getElementById('shop-money').innerText = player.money;
            let grid = document.getElementById('shop-grid'); grid.innerHTML = '';
            
            // Generate Shop Items (3 Items, 2 Moves)
            let sItems = [ITEMS_DB[0], ITEMS_DB[1], ITEMS_DB[2], ITEMS_DB[3]].sort(()=>0.5-Math.random()).slice(0,3);
            let sMoves = []; while(sMoves.length < 2) { let m = ALL_ATTACKS[Math.floor(Math.random() * ALL_ATTACKS.length)]; if(!sMoves.find(x=>x.n===m.n)) sMoves.push(m); }

            sItems.forEach(it => { let card = document.createElement('div'); card.className = 'card'; card.innerHTML = `<div class="card-title">${it.name}</div><div class="card-desc">${it.desc}</div><div class="card-price">$${it.price}</div>`; card.onclick = () => buyItem(it); grid.appendChild(card); });
            sMoves.forEach(mv => { let price = 250; let card = document.createElement('div'); card.className = 'card'; card.innerHTML = `<div class="card-title" style="color:${mv.c}">${mv.n}</div><div class="card-desc">${mv.d}</div><div class="card-price">$${price}</div>`; card.onclick = () => buyMove(mv, price); grid.appendChild(card); });
        } else { advanceFloor(); }
    }

    function buyItem(it) {
        if(player.money < it.price) return alert("Not enough money!");
        player.money -= it.price; document.getElementById('shop-money').innerText = player.money;
        let exist = player.items.find(x => x.id === it.id); if(exist) exist.count++; else player.items.push({...it, count:1});
        alert(`Bought ${it.name}!`);
    }

    function buyMove(mv, price) {
        if(player.money < price) return alert("Not enough money!");
        if(player.moves.find(m => m.n === mv.n)) return alert("Already know this move!");
        if(player.moves.length >= 4) return alert("Move slots full! Can't buy.");
        player.money -= price; document.getElementById('shop-money').innerText = player.money;
        player.moves.push(mv); alert(`Learned ${mv.n}!`);
    }

    function advanceFloor() {
        currentFloor++; player.level++; player.hp = Math.min(player.maxHp, player.hp + Math.floor(player.maxHp * 0.2)); player.maxHp += 10; player.atk += 5; 
        startEncounter();
    }

    function gameLoop() {
        frameCount++;
        if (gameState === "TEXT" || gameState === "INTRO") { if (isTyping && frameCount % 2 === 0) { typedText += currentText.charAt(textCharIndex); document.getElementById('dialogue-text').innerText = typedText; textCharIndex++; if (textCharIndex >= currentText.length) { isTyping = false; document.getElementById('dialogue-arrow').classList.remove('hidden'); } } } 
        else if (gameState === "CLASH") { clashTimer--; clashValue -= 1.5; updateClashUI(); if(frameCount%2===0) emitParticles(120 + (clashValue-50)*2, 80, (Math.random()>0.5?player.color:'#ef4444'), 4, 8, 15); if (clashValue >= 100 || clashValue <= 0 || clashTimer <= 0) resolveClash(); }
        for(let i = particles.length-1; i>=0; i--) { let p = particles[i]; p.x += p.vx; p.y += p.vy; p.life--; if (p.life <= 0) particles.splice(i, 1); }
        for(let i = shockwaves.length-1; i>=0; i--) { let s = shockwaves[i]; s.radius += s.speed; s.life -= 0.05; if (s.life <= 0 || s.radius >= s.maxRadius) shockwaves.splice(i, 1); }
        renderGame(); requestAnimationFrame(gameLoop);
    }
    
    requestAnimationFrame(gameLoop);
</script>
</body>
</html>
