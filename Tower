            currentText = nextItem.text;
            onQueueEmpty = nextItem.cb;
            typedText = "";
            textCharIndex = 0;
        } else {
            if(onQueueEmpty) {
                let cb = onQueueEmpty;
                onQueueEmpty = null;
                cb();
            }
        }
    }

