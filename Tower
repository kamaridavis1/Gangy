    function generateEnemy(floor) {
        const prefixes = ["ROGUE", "CURSED", "ELITE", "CORRUPTED", "DEMON", "SHADOW", "COSMIC", "FALLEN", "AWAKENED", "HAKAI"];
        const archetypes = ["SHINOBI", "SPIRIT", "SAIYAN", "PIRATE", "HOLLOW", "STAND USER", "HASHIRA", "VILLAIN", "ESPER", "DRAGON"];
