        // Player
        document.getElementById('p-name').innerText = player.name;
        document.getElementById('p-name').style.color = player.color;
        document.getElementById('p-hp-text').innerText = `${Math.floor(player.hp)}/${player.maxHp}`;
        document.getElementById('p-mp-text').innerText = `EN:${Math.floor(player.mp)}`;
        
        let pHpPct = Math.max(0, (player.hp / player.maxHp) * 100);
        let pMpPct = Math.max(0, (player.mp / player.maxMp) * 100);
        let pHpBar = document.getElementById('p-hp-bar');
        pHpBar.style.width = pHpPct + '%';
        if (pHpPct <= 25) pHpBar.classList.add('low'); else pHpBar.classList.remove('low');
        document.getElementById('p-mp-bar').style.width = pMpPct + '%';

