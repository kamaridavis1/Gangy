    function varColor(name) {
        return getComputedStyle(document.documentElement).getPropertyValue(name).trim();
    }

    function queueDialogue(texts, callback = null) {
        dialogueQueue = texts;
        textCallback = callback;
        advanceDialogue();
    }

    function advanceDialogue() {
        if (dialogueQueue.length > 0) {
            state = "DIALOGUE";
            currentText = dialogueQueue.shift();
            textCharIndex = 0; typedText = ""; isTyping = true;
            document.getElementById('dialogue-text').innerHTML = "";
            document.getElementById('moves-container').classList.add('hidden');
        } else {
            state = "IDLE";
            if(textCallback) {
                let cb = textCallback;
                textCallback = null;
                cb();
            }
        }
    }

    function switchBattleMenu(menuType) {
        document.getElementById('menu-main').classList.add('hidden');
        document.getElementById('menu-skills').classList.add('hidden');
        document.getElementById('menu-items').classList.add('hidden');
        document.getElementById('menu-' + menuType).classList.remove('hidden');
    }

    function startPlayerTurn() {
        if(player.hp <= 0) return handlePlayerDeath();
        if(enemy.hp <= 0) return handleEnemyDeath();

        state = "PLAYER_TURN";
        switchBattleMenu('main');
        document.getElementById('moves-container').classList.remove('hidden');
        document.getElementById('dialogue-text').innerHTML = `What will ${player.name} do?`;
        
        // Regain a bit of MP passively
        player.mp = Math.min(player.maxMp, player.mp + 15);
        updateHUD();
    }

    /* --- COMBAT ACTIONS --- */

    function doBasicAttack() {
        executeMove(player, enemy, BASIC_ATTACK, () => {
            player.mp = Math.min(player.maxMp, player.mp + 25);
            player.ultMeter += 20;
            enemyTurn();
        });
    }

    function useSkill(index) {
        let skill = player.skills[index];
        if (player.mp >= skill.mpCost) {
            player.mp -= skill.mpCost;
            executeMove(player, enemy, skill, () => {
                player.ultMeter += 30;
                enemyTurn();
            });
        }
    }

    function doUltimate() {
        if(player.ultMeter >= 100) {
            player.ultMeter = 0;
            executeMove(player, enemy, player.ultimate, () => {
                enemyTurn();
            });
        }
    }

    function usePotion() {
        if(partyInventory.potions > 0) {
            partyInventory.potions--;
            let heal = Math.floor(player.maxHp * 0.5);
            player.hp = Math.min(player.maxHp, player.hp + heal);
            spawnDamageNumber(player.x, player.y - 50, "+" + heal, varColor('--hp-green'));
            updateHUD();
            queueDialogue([`${player.name} recovered HP!`], () => { enemyTurn(); });
        }
    }

    function attemptTransform() {
        if(!player.transformed) {
            player.transformed = true;
            player.atk = Math.floor(player.baseAtk * player.transformData.mult);
            player.color = player.transformData.color;
            player.palette = generatePalette(player.color);
            player.aura = player.color;
            updateHUD();
            queueDialogue([`${player.name} transformed into ${player.transformData.name}!`, player.transformData.msg], () => { enemyTurn(); });
        } else {
            queueDialogue([`${player.name} is already transformed!`], () => { startPlayerTurn(); });
        }
    }

    function attemptDomain() {
        if(domainMeter >= 100) {
            domainMeter = 0;
            arena.colorSkyTop = "#000000";
            arena.colorSkyBot = "#4c1d95";
            arena.colorGround = "#1e1b4b";
            player.atk = Math.floor(player.atk * 1.5);
            screenShake = 20;
            queueDialogue([`DOMAIN EXPANSION!`, `${player.name}'s power vastly increased!`], () => { startPlayerTurn(); });
        } else {
            queueDialogue([`Domain meter not full!`], () => { startPlayerTurn(); });
        }
    }

    function enemyTurn() {
        if(enemy.hp <= 0) return handleEnemyDeath();
        if(player.hp <= 0) return handlePlayerDeath();

        state = "ENEMY_TURN";
        document.getElementById('moves-container').classList.add('hidden');
        
        enemy.mp = Math.min(enemy.maxMp, enemy.mp + 20);
        updateHUD();

        setTimeout(() => {
            // Very Basic AI
            let move = null;
            
            if (enemy.ultMeter >= 100) {
                move = enemy.ultimate;
                enemy.ultMeter = 0;
            } else if (enemy.hp < enemy.maxHp * 0.5 && !enemy.transformed && enemy.transformData) {
                enemy.transformed = true;
                enemy.atk = Math.floor(enemy.baseAtk * enemy.transformData.mult);
                enemy.color = enemy.transformData.color;
                enemy.palette = generatePalette(enemy.color);
                enemy.aura = enemy.color;
                return queueDialogue([`${enemy.name} used ${enemy.transformData.name}!`, enemy.transformData.msg], () => { startPlayerTurn(); });
            } else {
                let possibleSkills = enemy.skills.filter(s => enemy.mp >= s.mpCost);
                if (possibleSkills.length > 0 && Math.random() > 0.3) {
                    move = possibleSkills[Math.floor(Math.random() * possibleSkills.length)];
                    enemy.mp -= move.mpCost;
                } else {
                    move = BASIC_ATTACK;
                }
            }
            
            enemy.ultMeter += 20;

            // QTE chance for player to parry
            if (move.pwr >= 40) {
                triggerQTE((parried) => {
                    if(parried) {
                        spawnDamageNumber(player.x, player.y - 50, "PARRY!", varColor('--hp-green'));
                        let counterDmg = Math.floor(enemy.atk * 0.5);
                        enemy.hp -= counterDmg;
                        spawnDamageNumber(enemy.x, enemy.y, counterDmg, "#fff");
                        queueDialogue([`${player.name} parried the attack!`], () => { startPlayerTurn(); });
                    } else {
                        executeMove(enemy, player, move, () => { startPlayerTurn(); });
                    }
                });
            } else {
                executeMove(enemy, player, move, () => { startPlayerTurn(); });
            }
        }, 1000);
    }

    function executeMove(attacker, defender, move, onComplete) {
        state = "ANIMATING";
        document.getElementById('moves-container').classList.add('hidden');
        document.getElementById('dialogue-text').innerHTML = `${attacker.name} uses <span style="color:${move.color}">${move.n}</span>!`;
        
        playAnim(move.anim, attacker, defender, move.color, move.core, () => {
            // Calc damage
            let variance = 0.85 + (Math.random() * 0.3);
            let dmg = Math.floor(move.pwr * (attacker.atk / 20) * variance);
            
            // Domain bonus
            if(attacker === player && domainMeter < 100) domainMeter += 15;
            if(attacker.isPlayer && arena.colorSkyBot === "#4c1d95") dmg = Math.floor(dmg * 1.5);

            defender.hp -= dmg;
            if(defender.hp < 0) defender.hp = 0;
            
            spawnDamageNumber(defender.x, defender.y, dmg, move.type === MOVE_TYPES.SPECIAL ? varColor('--domain-purple') : "#fff");
            screenShake = Math.min(20, move.pwr / 10);
            updateHUD();

            setTimeout(() => { onComplete(); }, 800);
        });
    }

    /* --- ANIMATION ENGINE --- */
    function playAnim(type, attacker, defender, color, coreColor, cb) {
        activeAnim = { type, attacker, defender, color, coreColor, timer: 0, cb, step: 0 };
    }

    function updateAnimation(dt) {
        if(!activeAnim) return;
        let a = activeAnim;
        a.timer += dt;

        let aStartX = a.attacker.origX;
        let dStartX = a.defender.origX;
        let aDir = a.attacker.isPlayer ? 1 : -1;

        if (a.type === "dash" || a.type === "flurry") {
            if(a.step === 0) {
                // Dash forward
                let targetX = dStartX - (50 * aDir);
                a.attacker.x += (targetX - a.attacker.x) * 0.2;
                if(Math.abs(a.attacker.x - targetX) < 5) { a.step = 1; a.attacker.currentSprite = a.attacker.spritePunch; }
            } else if (a.step === 1) {
                // Hit
                spawnParticles(dStartX, a.defender.y, a.color, 10);
                if(a.timer > 0.4) { a.step = 2; a.attacker.currentSprite = a.attacker.spriteIdle; }
            } else if (a.step === 2) {
                // Return
                a.attacker.x += (aStartX - a.attacker.x) * 0.2;
                if(Math.abs(a.attacker.x - aStartX) < 2) {
                    a.attacker.x = aStartX;
                    activeAnim = null;
                    a.cb();
                }
            }
        } else if (a.type === "beam_thick" || a.type === "beam_huge") {
            if(a.step === 0) {
                a.attacker.currentSprite = a.attacker.spritePunch;
                if(a.timer > 0.2) a.step = 1;
            } else if (a.step === 1) {
                let w = a.type === "beam_huge" ? 60 : 30;
                let c1 = a.color; let c2 = a.coreColor || "#fff";
                ctx.fillStyle = c1;
                ctx.fillRect(Math.min(aStartX, dStartX), a.attacker.y - w/2, Math.abs(aStartX - dStartX), w);
                ctx.fillStyle = c2;
                ctx.fillRect(Math.min(aStartX, dStartX), a.attacker.y - w/4, Math.abs(aStartX - dStartX), w/2);
                spawnParticles(dStartX, a.defender.y, c1, 5);
                screenShake = 5;
                if(a.timer > 0.8) { a.step = 2; a.attacker.currentSprite = a.attacker.spriteIdle; }
            } else if (a.step === 2) {
                activeAnim = null; a.cb();
            }
        } else if (a.type === "spirit_bomb" || a.type === "death_ball") {
            if(a.step === 0) {
                a.attacker.y -= 2; // hover up
                if(a.timer > 0.5) a.step = 1;
            } else if (a.step === 1) {
                // Draw falling ball
                let ballY = 0 + (a.timer - 0.5) * 400;
                ctx.beginPath();
                ctx.arc(dStartX, ballY, a.type==="spirit_bomb"?80:40, 0, Math.PI*2);
                ctx.fillStyle = a.color; ctx.fill();
                if(ballY > a.defender.y) {
                    screenShake = 15;
                    spawnParticles(dStartX, a.defender.y, a.color, 30);
                    a.step = 2;
                }
            } else if (a.step === 2) {
                a.attacker.y += (a.attacker.origY || 220 - a.attacker.y) * 0.1;
                if(a.timer > 1.5) { a.attacker.y = 220; activeAnim = null; a.cb(); }
            }
        } else if (a.type === "slashes") {
            if(a.timer < 0.6) {
                if(Math.random() > 0.5) {
                    ctx.strokeStyle = a.color; ctx.lineWidth = 4;
                    ctx.beginPath();
                    ctx.moveTo(dStartX - 40 + Math.random()*80, a.defender.y - 40 + Math.random()*80);
                    ctx.lineTo(dStartX - 40 + Math.random()*80, a.defender.y - 40 + Math.random()*80);
                    ctx.stroke();
                }
            } else { activeAnim = null; a.cb(); }
        } else if (a.type === "world_shake" || a.type === "shatter") {
            if(a.step === 0) {
                screenShake = 20;
                ctx.fillStyle = "rgba(255,255,255,0.5)"; ctx.fillRect(0,0,width,height);
                if(a.timer > 0.5) a.step = 1;
            } else if (a.step === 1) {
                spawnParticles(dStartX, a.defender.y, a.color, 40);
                activeAnim = null; a.cb();
            }
        } else {
            // fallback
            spawnParticles(dStartX, a.defender.y, a.color, 10);
            activeAnim = null; a.cb();
        }
    }

    function spawnParticles(x, y, color, count) {
        for(let i=0; i<count; i++) {
            particles.push({
                x: x, y: y,
                vx: (Math.random() - 0.5) * 10, vy: (Math.random() - 0.5) * 10 - 2,
                life: 1.0, maxLife: 1.0, color: color, size: Math.random() * 5 + 2
            });
        }
    }

    function spawnDamageNumber(x, y, text, color) {
        damageNumbers.push({ x: x + (Math.random()*40-20), y: y - 20, vy: -2, text: text, color: color, life: 1.0 });
    }

    /* --- QTE SYSTEM --- */
    let qteActive = false;
    let qteCallback = null;
    let qteTimeout = null;

    function triggerQTE(cb) {
        qteActive = true;
        qteCallback = cb;
        let key = QTE_KEYS[Math.floor(Math.random() * QTE_KEYS.length)];
        document.getElementById('qte-key').innerText = key;
        document.getElementById('qte-key').dataset.key = key;
        document.getElementById('qte-ui').classList.remove('hidden');
        
        qteTimeout = setTimeout(() => {
            if(qteActive) {
                qteActive = false;
                document.getElementById('qte-ui').classList.add('hidden');
                qteCallback(false); // Failed
            }
        }, 800); // 0.8s to react
    }

    function handleQTEKey(e) {
        if(!qteActive) return;
        let expected = document.getElementById('qte-key').dataset.key;
        if(e.key.toUpperCase() === expected) {
            clearTimeout(qteTimeout);
            qteActive = false;
            document.getElementById('qte-ui').classList.add('hidden');
            qteCallback(true); // Success
        }
    }

    /* --- DEATH & PROGRESSION --- */

    function handlePlayerDeath() {
        player.isDead = true;
        player.hp = 0;
        updateHUD();
        queueDialogue([`${player.name} was defeated!`], () => {
            let aliveMates = playerRoster.filter(p => !p.isDead);
            if(aliveMates.length > 0) {
                isForcedSwap = true;
                openSwapMenu(true);
            } else {
                gameOver();
            }
        });
    }

    function handleEnemyDeath() {
        enemy.hp = 0;
        enemy.isDead = true;
        updateHUD();
        let reward = currentFloor * 50 + (currentFloor % 5 === 0 ? 100 : 0);
        gold += reward;
        document.getElementById('floor-timer-ui').classList.add('hidden');
        
        queueDialogue([
            `${enemy.name} was defeated!`,
            `Gained ${reward} Gold!`
        ], () => {
            if (currentFloor === 100) {
                queueDialogue(["YOU CONQUERED THE TOWER!", "Congratulations!"], () => location.reload());
            } else {
                openDraftMenu();
            }
        });
    }

    function openDraftMenu() {
        showScreen('screen-draft');
        document.getElementById('draft-char-name').innerText = player.name;
        document.getElementById('draft-char-name').style.color = player.color;
        
        let grid = document.getElementById('draft-grid');
        grid.innerHTML = '';

        // Pick 3 random moves player doesn't have
        let available = ALL_ANIME_ABILITIES.filter(m => !player.skills.find(s => s.n === m.n) && m.n !== "Gaster Blaster" && m.n !== "Bone Smash" && m.n !== "Karmic Retribution");
        
        let choices = [];
        for(let i=0; i<3; i++) {
            if(available.length > 0) {
                let idx = Math.floor(Math.random() * available.length);
                choices.push(available.splice(idx, 1)[0]);
            }
        }

        choices.forEach(c => {
            let card = document.createElement('div');
            card.className = 'draft-card';
            card.innerHTML = `
                <div class="draft-title" style="color: ${c.color}">${c.n}</div>
                <div class="draft-type">${c.type}</div>
                <div class="draft-desc">PWR: ${c.pwr} | MP: ${c.mpCost}</div>
            `;
            card.onclick = () => { selectDraft(c); };
            grid.appendChild(card);
        });
        
        // Add max HP option
        let hpCard = document.createElement('div');
        hpCard.className = 'draft-card';
        hpCard.innerHTML = `<div class="draft-title" style="color: var(--hp-green)">MAX HP +50</div><div class="draft-desc">Increases survivability.</div>`;
        hpCard.onclick = () => { 
            player.maxHp += 50; player.hp += 50; 
            openShopMenu(); 
        };
        grid.appendChild(hpCard);
    }

    function selectDraft(skill) {
        if(player.skills.length >= 4) {
            player.skills.shift(); // Forget oldest if full
        }
        player.skills.push(JSON.parse(JSON.stringify(skill)));
        openShopMenu();
    }

    function openShopMenu() {
        showScreen('screen-shop');
        updateShopUI();
    }

    function updateShopUI() {
        document.getElementById('shop-gold').innerText = gold;
        document.getElementById('shop-active-name').innerText = player.name;
        document.getElementById('shop-active-name').style.color = player.color;
        document.getElementById('shop-potions').innerText = partyInventory.potions;
        
        let deadCount = playerRoster.filter(p => p.isDead).length;
        document.getElementById('buy-revive').disabled = (deadCount === 0);
    }

    function buyItem(type) {
        if(type === 'potion' && gold >= 50) { gold -= 50; partyInventory.potions++; updateShopUI(); }
        else if(type === 'revive' && gold >= 200) {
            let deadMates = playerRoster.filter(p => p.isDead);
            if(deadMates.length > 0) {
                gold -= 200;
                deadMates[0].isDead = false;
                deadMates[0].hp = Math.floor(deadMates[0].maxHp * 0.5);
                updateShopUI();
            }
        }
        else if(type === 'atk' && gold >= 150) { gold -= 150; player.baseAtk += 15; player.atk += 15; updateShopUI(); }
    }

    function buyRandomizer() {
        if(gold >= 100) {
            gold -= 100;
            let available = ALL_ANIME_ABILITIES.filter(m => m.n !== "Gaster Blaster");
            let newSkills = [];
            for(let i=0; i<3; i++) newSkills.push(JSON.parse(JSON.stringify(available[Math.floor(Math.random() * available.length)])));
            player.skills = newSkills;
            let ults = ULTIMATE_ATTACKS.filter(u => u.n !== "MEGALOVANIA");
            player.ultimate = JSON.parse(JSON.stringify(ults[Math.floor(Math.random() * ults.length)]));
            
            // Re-apply correct active player stats
            document.getElementById('shop-active-name').innerText = player.name + " (REROLED!)";
            setTimeout(updateShopUI, 1000);
            updateShopUI();
        }
    }

    function nextFloor() {
        currentFloor++;
        initFloor();
    }

    function openSwapMenu(forced) {
        isForcedSwap = forced;
        showScreen('screen-swap');
        let grid = document.getElementById('swap-grid');
        grid.innerHTML = '';
        document.getElementById('btn-cancel-swap').style.display = forced ? 'none' : 'block';

        playerRoster.forEach((p, idx) => {
            let card = document.createElement('div');
            card.className = 'roster-card ' + (p.isDead ? 'dead ' : '') + (idx === activePlayerIndex ? 'active' : '');
            card.innerHTML = `<div class="roster-name" style="color:${p.color}">${p.name}</div><div style="font-size:8px;color:#fff;">HP: ${Math.floor(p.hp)}/${p.maxHp}</div>`;
            if(!p.isDead) {
                card.onclick = () => {
                    activePlayerIndex = idx;
                    player = playerRoster[activePlayerIndex];
                    if(state === "MENU" || state.includes("SHOP")) {
                        updateShopUI();
                        showScreen('screen-shop');
                    } else {
                        // In battle
                        player.x = 100; player.y = 220;
                        updateHUD();
                        showScreen('screen-battle');
                        if(isForcedSwap) {
                            isForcedSwap = false;
                            startPlayerTurn();
                        } else {
                            enemyTurn(); // Swapping takes a turn
                        }
                    }
                };
            }
            grid.appendChild(card);
        });
    }

    function cancelSwap() {
        if(state.includes("SHOP")) showScreen('screen-shop');
        else showScreen('screen-battle');
    }

    function gameOver() {
        showScreen('screen-end');
        document.getElementById('end-floor').innerText = currentFloor;
        if(isSpeedrunMode) document.getElementById('end-time').innerText = "Time: " + formatTime(speedrunTimer);
    }

    function formatTime(s) {
        let m = Math.floor(s / 60);
        let sec = (s % 60).toFixed(2);
        return `${m < 10 ? '0':''}${m}:${sec < 10 ? '0':''}${sec}`;
    }

    /* --- RENDERING --- */

    function drawSprite(ctx, spriteArray, x, y, scale, palette) {
        for(let row=0; row<spriteArray.length; row++) {
            for(let col=0; col<spriteArray[row].length; col++) {
                let colorIdx = spriteArray[row][col];
                if(colorIdx !== 0) {
                    ctx.fillStyle = palette[colorIdx];
                    ctx.fillRect(x + col*scale, y + row*scale, scale, scale);
                }
            }
        }
    }

    function gameLoop(timestamp) {
        let dt = (timestamp - lastTime) / 1000;
        if(dt > 0.1) dt = 0.1; // Cap dt
        lastTime = timestamp;
        globalTime += dt;

        ctx.fillStyle = "#000";
        ctx.fillRect(0, 0, width, height);

        if (state !== "MENU" && state !== "LEAD_SELECT") {
            // Speedrun Timer
            if(isSpeedrunMode && state !== "END") {
                speedrunTimer += dt;
                document.getElementById('speedrun-ui').innerText = formatTime(speedrunTimer);
            }

            // Floor Timer Check
            if(state !== "SHOP" && state !== "DRAFT" && state !== "MENU") {
                if(!activeAnim && state !== "DIALOGUE" && state !== "ANIMATING") {
                    floorTimer -= dt;
                    if(floorTimer <= 0) { floorTimer = 0; handlePlayerDeath(); } // Time over
                }
                document.getElementById('floor-timer-ui').innerText = floorTimer.toFixed(1) + "s";
            }

            // Draw Arena
            arena.scroll += dt * 20;
            let grad = ctx.createLinearGradient(0, 0, 0, height*0.6);
            grad.addColorStop(0, arena.colorSkyTop);
            grad.addColorStop(1, arena.colorSkyBot);
            ctx.fillStyle = grad;
            ctx.fillRect(0, 0, width, height*0.6);

            ctx.fillStyle = arena.colorGround;
            ctx.fillRect(0, height*0.6, width, height*0.4);

            // Ground lines
            ctx.strokeStyle = arena.colorLines;
            ctx.lineWidth = 2;
            for(let i=0; i<10; i++) {
                let lx = (i*100 - arena.scroll) % width;
                if(lx < 0) lx += width;
                ctx.beginPath(); ctx.moveTo(lx, height*0.6); ctx.lineTo(lx - 50, height); ctx.stroke();
            }

            // Screen Shake
            ctx.save();
            if(screenShake > 0) {
                ctx.translate((Math.random()-0.5)*screenShake, (Math.random()-0.5)*screenShake);
                screenShake -= dt * 30;
                if(screenShake < 0) screenShake = 0;
            }

            // Draw Entities
            if (player && !player.isDead) {
                if(player.aura) {
                    ctx.shadowColor = player.aura; ctx.shadowBlur = 15;
                    ctx.beginPath(); ctx.ellipse(player.x + 30, player.y + 35, 40, 50, 0, 0, Math.PI*2);
                    ctx.fillStyle = "rgba(255,255,255,0.1)"; ctx.fill();
                    ctx.shadowBlur = 0;
                }
                drawSprite(ctx, player.currentSprite, player.x, player.y, player.drawScale, player.palette);
            }

            if (enemy && !enemy.isDead && state !== "SHOP" && state !== "DRAFT") {
                if(enemy.aura) {
                    ctx.shadowColor = enemy.aura; ctx.shadowBlur = 20;
                    ctx.beginPath(); ctx.ellipse(enemy.x + 30, enemy.y + 35, 50, 60, 0, 0, Math.PI*2);
                    ctx.fillStyle = "rgba(255,0,0,0.1)"; ctx.fill();
                    ctx.shadowBlur = 0;
                }
                drawSprite(ctx, enemy.currentSprite, enemy.x, enemy.y, enemy.drawScale, enemy.palette);
            }

            // Particles
            for(let i=particles.length-1; i>=0; i--) {
                let p = particles[i];
                p.x += p.vx; p.y += p.vy; p.vy += 0.2; p.life -= dt;
                if(p.life <= 0) particles.splice(i, 1);
                else {
                    ctx.fillStyle = p.color;
                    ctx.globalAlpha = p.life / p.maxLife;
                    ctx.fillRect(p.x, p.y, p.size, p.size);
                    ctx.globalAlpha = 1.0;
                }
            }

            // Damage Numbers
            ctx.font = "16px 'Press Start 2P'";
            for(let i=damageNumbers.length-1; i>=0; i--) {
                let d = damageNumbers[i];
                d.y += d.vy; d.life -= dt;
                if(d.life <= 0) damageNumbers.splice(i, 1);
                else {
                    ctx.fillStyle = "#000";
                    ctx.fillText(d.text, d.x+2, d.y+2);
                    ctx.fillStyle = d.color;
                    ctx.globalAlpha = d.life;
                    ctx.fillText(d.text, d.x, d.y);
                    ctx.globalAlpha = 1.0;
                }
            }

            updateAnimation(dt);
            ctx.restore();
        }

        // Dialogue Typing Effect
        if (isTyping) {
            typeTimer += dt;
            if (typeTimer > 0.03) {
                typeTimer = 0;
                typedText += currentText.charAt(textCharIndex);
                textCharIndex++;
                document.getElementById('dialogue-text').innerHTML = typedText + (textCharIndex >= currentText.length ? " <span class='blink'>▼</span>" : "");
                if (textCharIndex >= currentText.length) isTyping = false;
            }
        }

        requestAnimationFrame(gameLoop);
    }

</script>
