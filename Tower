    window.handleAction = function(action, arg) {
        document.getElementById('action-menu').classList.add('hidden');
        document.getElementById('moves-menu').classList.add('hidden');
        document.getElementById('items-menu').classList.add('hidden');
        document.getElementById('dialogue-box').style.display = 'block';
        document.getElementById('dialogue-text').innerText = '';

        if(action === 'attack') {
            executeMove(player, currentEnemy, player.moves[arg], true);
        } else if(action === 'item') {
            useItem(arg);
        } else if(action === 'domain') {
            triggerDomain();
        } else if(action === 'awaken') {
            triggerAwaken();
        } else if(action === 'ultimate') {
            triggerUltimate();
        }
    }

    function useItem(idx) {
        let item = player.items[idx];
        item.count--;
        
        queueText(`${player.name} used ${item.name}!`);
        
        if(item.type === 'heal_50') {
            player.hp = Math.min(player.maxHp, player.hp + (player.maxHp * 0.5));
            spawnParticles(pPos.x, pPos.y, '#22c55e');
            queueText(`Recovered 50% HP.`);
        } else if(item.type === 'heal_full') {
            player.hp = player.maxHp;
            spawnParticles(pPos.x, pPos.y, '#22c55e');
            queueText(`HP fully restored!`);
        } else if(item.type === 'invuln') {
            player.invulnTurns = 2; // 1 for enemy turn, 1 for next
            queueText(`Shield active! Immune to damage.`);
        } else if(item.type === 'domain') {
            player.domainMeter = 100;
            spawnParticles(pPos.x, pPos.y, '#a855f7');
            queueText(`Domain meter maxed out!`);
        }
        
        updateHUD();
        setTimeout(enemyTurn, 1000);
    }

    // --- BATTLE MECHANICS ---
    function executeMove(user, target, move, isPlayer) {
        gameState = "ANIMATING";
        let dmgMult = move.p;
        
        // Buffs
        if(isPlayer && player.transformed) dmgMult *= player.transformData.mult;
        if(activeDomain === 'player' && isPlayer) dmgMult *= 1.5; // Domain buff
        if(activeDomain === 'player' && !isPlayer) dmgMult *= 0.5; // Domain debuff

        let damage = Math.max(1, Math.floor(user.atk * dmgMult * (0.8 + Math.random()*0.4)));
        
        // Critical hits (Black Flash logic)
        let isCrit = Math.random() < (move.n === "BLACK FLASH" ? 0.5 : 0.1);
        if(isCrit) damage = Math.floor(damage * 2.5);

        // Invulnerability
        if(!isPlayer && player.invulnTurns > 0) damage = 0;

        queueText(`${user.name} uses ${move.n}!`);

        // Attack Animation
        if(move.t === 'buff') {
            user.atk = Math.floor(user.atk * 1.5);
            spawnParticles(isPlayer ? pPos.x : ePos.x, isPlayer ? pPos.y : ePos.y, move.c);
            queueText(`${user.name}'s ATK rose sharply!`, () => { isPlayer ? enemyTurn() : checkTurnEnd() });
            return;
        }

        // Dash anim
        let dir = isPlayer ? 1 : -1;
        let dashDist = 40;
        let pRef = isPlayer ? pOff : eOff;
        
        let dashInterval = setInterval(() => { pRef.x += 5 * dir; if(Math.abs(pRef.x) >= dashDist) clearInterval(dashInterval); }, 16);
        
        setTimeout(() => {
            // Impact
            spawnParticles(isPlayer ? ePos.x : pPos.x, isPlayer ? ePos.y : pPos.y, move.c);
            shakeScreen();
            
            if(damage > 0) {
                target.hp -= damage;
                if(isCrit) queueText(`A CRITICAL HIT!`);
                queueText(`Dealt ${damage} damage!`);
            } else {
                queueText(`It had no effect!`);
            }

            // Special Effects
            if(move.t === 'vampire' && damage > 0) {
                let heal = Math.floor(damage * 0.5);
                user.hp = Math.min(user.maxHp, user.hp + heal);
                queueText(`Absorbed ${heal} HP!`);
            }
            if(move.t === 'recoil') {
                let rec = Math.floor(damage * 0.2);
                user.hp -= rec;
                queueText(`${user.name} took ${rec} recoil damage.`);
            }

            // Reset pos
            let retInterval = setInterval(() => { pRef.x -= 5 * dir; if(Math.abs(pRef.x) <= 0) { clearInterval(retInterval); pRef.x = 0; } }, 16);
            
            if(isPlayer) player.domainMeter += 15;

            updateHUD();
            
            setTimeout(() => {
                if(target.hp <= 0) checkDeath();
                else if(isPlayer) enemyTurn();
                else checkTurnEnd();
            }, 500);

        }, 300);
    }

    function enemyTurn() {
        if(currentEnemy.hp <= 0 || player.hp <= 0) return;
        
        // Auto-hit in domain
        if(activeDomain === 'player') {
            let tickDmg = Math.floor(player.atk * 0.5);
            currentEnemy.hp -= tickDmg;
            spawnParticles(ePos.x, ePos.y, '#a855f7');
            queueText(`Domain strikes automatically for ${tickDmg} DMG!`);
            if(currentEnemy.hp <= 0) { setTimeout(checkDeath, 1000); return; }
        }

        if(player.invulnTurns > 0) player.invulnTurns--;

        let move = currentEnemy.moves[Math.floor(Math.random() * currentEnemy.moves.length)];
        executeMove(currentEnemy, player, move, false);
    }

    function checkTurnEnd() {
        if(player.hp <= 0) checkDeath();
        else playerTurn();
    }

    function checkDeath() {
        if(player.hp <= 0) {
            document.getElementById('battle-ui').classList.add('hidden');
            document.getElementById('game-over-screen').classList.remove('hidden');
            document.getElementById('death-stats').innerText = `You reached Floor ${currentFloor}.`;
        } else if(currentEnemy.hp <= 0) {
            // Win
            player.money += Math.floor(20 * currentFloor * diffMult);
            player.level++;
            player.maxHp += 10;
            player.hp = player.maxHp;
            player.atk += 2;
            
            queueText(`${currentEnemy.name} was defeated!`, winFloor);
        }
    }

    // --- SPECIAL ACTIONS ---
    function triggerAwaken() {
        player.transformed = true;
        player.color = player.transformData.color;
        document.getElementById('p-name').style.color = player.color;
        document.body.classList.add('transformed-ui');
        
        spawnParticles(pPos.x, pPos.y, player.color, 50);
        document.getElementById('flash-overlay').style.opacity = 1;
        document.getElementById('flash-overlay').style.background = player.color;
        setTimeout(()=> document.getElementById('flash-overlay').style.opacity = 0, 500);

        queueText(`AWAKENING! ${player.transformData.msg}`);
        updateHUD();
        setTimeout(enemyTurn, 1000);
    }

    function triggerDomain() {
        player.domainMeter = 0;
        activeDomain = 'player';
        document.body.className = 'domain-ui';
        
        let cutLayer = document.getElementById('cutscene-layer');
        cutLayer.classList.remove('hidden');
        document.getElementById('cutscene-text').innerText = "DOMAIN EXPANSION\n" + player.domain.name;
        
        setTimeout(() => {
            cutLayer.classList.add('hidden');
            queueText(`Domain Expansion activated! Massive stat boost and auto-hits enabled!`);
            updateHUD();
            setTimeout(enemyTurn, 1000);
        }, 2000);
    }

    function triggerUltimate() {
        player.domainMeter -= 50;
        let cutLayer = document.getElementById('cutscene-layer');
        cutLayer.classList.remove('hidden');
        document.getElementById('cutscene-text').innerText = player.ultName;
        document.getElementById('cutscene-text').style.color = player.color;

        setTimeout(() => {
            cutLayer.classList.add('hidden');
            
            if(player.ultType === "BEAM") {
                startClash();
            } else {
                // Massive hit
                let damage = player.atk * 5 * (player.transformed ? player.transformData.mult : 1);
                currentEnemy.hp -= damage;
                shakeScreen(true);
                spawnParticles(ePos.x, ePos.y, player.color, 100);
                queueText(player.ultMsg);
                queueText(`ULTIMATE dealt ${Math.floor(damage)} damage!`);
                updateHUD();
                setTimeout(() => {
                    if(currentEnemy.hp <= 0) checkDeath();
                    else enemyTurn();
                }, 1000);
            }
        }, 2000);
    }

    // --- BEAM CLASH ---
    function startClash() {
        clashActive = true;
        clashValue = 50;
        clashTimer = 100; // frames
        document.getElementById('clash-layer').classList.remove('hidden');
        updateClashBar();
    }

    window.mashClash = function() {
        if(clashActive) {
            clashValue += 5; // Player pushes
            updateClashBar();
        }
    }

    function updateClashBar() {
        document.getElementById('clash-bar-fill').style.width = clashValue + "%";
        document.getElementById('clash-bar-fill').style.background = clashValue > 50 ? "#3b82f6" : "#ef4444";
    }

    function resolveClash() {
        clashActive = false;
        document.getElementById('clash-layer').classList.add('hidden');
        
        if(clashValue > 50) {
            // Player won
            let damage = player.atk * 6 * (clashValue/50);
            currentEnemy.hp -= damage;
            shakeScreen(true);
            spawnParticles(ePos.x, ePos.y, player.color, 100);
            queueText(`Clash WON! Beam destroyed the enemy for ${Math.floor(damage)} DMG!`);
        } else {
            // Enemy won
            let damage = currentEnemy.atk * 3;
            player.hp -= damage;
            shakeScreen(true);
            spawnParticles(pPos.x, pPos.y, "#ef4444", 100);
            queueText(`Clash LOST! You were overwhelmed and took ${Math.floor(damage)} DMG!`);
        }
        
        updateHUD();
        setTimeout(() => {
            if(currentEnemy.hp <= 0 || player.hp <= 0) checkDeath();
            else enemyTurn();
        }, 1000);
    }

    // --- PROGRESSION SCREENS ---
    function winFloor() {
        currentFloor++;
        document.getElementById('battle-ui').classList.add('hidden');
        
        // Either shop or loot
        if(currentFloor % 3 === 0) openShop();
        else showLoot();
    }

    function showLoot() {
        document.getElementById('loot-screen').classList.remove('hidden');
        let container = document.getElementById('loot-container');
        container.innerHTML = '';
        
        // Pick 3 random moves
        let options = [];
        for(let i=0; i<3; i++) {
            options.push(ALL_ATTACKS[Math.floor(Math.random() * ALL_ATTACKS.length)]);
        }

        options.forEach(move => {
            let card = document.createElement('div');
            card.className = 'card';
            card.innerHTML = `<div class="card-title" style="color:${move.c}">${move.n}</div><div class="card-desc">${move.d}</div><div class="card-price">PWR: ${move.p}</div>`;
            card.onclick = () => pickLoot(move);
            container.appendChild(card);
        });
    }

    function pickLoot(move) {
        if(player.moves.length < 4) {
            player.moves.push(move);
            skipMenu('loot');
        } else {
            // Full moves, need to replace
            pendingLootMove = move;
            document.getElementById('loot-screen').classList.add('hidden');
            document.getElementById('replace-screen').classList.remove('hidden');
            let grid = document.getElementById('replace-grid');
            grid.innerHTML = '';
            
            player.moves.forEach((m, idx) => {
                let card = document.createElement('div');
                card.className = 'card';
                card.innerHTML = `<div class="card-title" style="color:${m.c}">${m.n}</div><div class="card-desc">${m.d}</div>`;
                card.onclick = () => {
                    player.moves[idx] = pendingLootMove;
                    document.getElementById('replace-screen').classList.add('hidden');
                    startFloor();
                    document.getElementById('battle-ui').classList.remove('hidden');
                };
                grid.appendChild(card);
            });
        }
    }

    window.cancelReplace = function() {
        document.getElementById('replace-screen').classList.add('hidden');
        skipMenu('loot'); // Just skip
    }

    function openShop() {
        document.getElementById('shop-screen').classList.remove('hidden');
        document.getElementById('shop-money').innerText = player.money;
        let grid = document.getElementById('shop-grid');
        grid.innerHTML = '';

        ITEMS_DB.forEach(item => {
            let card = document.createElement('div');
            card.className = 'card';
            card.innerHTML = `<div class="card-title">${item.name}</div><div class="card-desc">${item.desc}</div><div class="card-price">$${item.price}</div>`;
            card.onclick = () => {
                if(player.money >= item.price) {
                    player.money -= item.price;
                    document.getElementById('shop-money').innerText = player.money;
                    
                    let existing = player.items.find(i => i.id === item.id);
                    if(existing) existing.count++;
                    else player.items.push({...item, count: 1});
                    
                    card.style.borderColor = "#4ade80";
                    setTimeout(()=> card.style.borderColor = "var(--gb-gray)", 200);
                }
            };
            grid.appendChild(card);
        });
    }

    window.skipMenu = function(menuId) {
        document.getElementById(menuId + '-screen').classList.add('hidden');
        document.getElementById('battle-ui').classList.remove('hidden');
        startFloor();
    }

    // --- RENDERING & EFFECTS ---
    function spawnParticles(x, y, color, amt = 20) {
        for(let i=0; i<amt; i++) {
            particles.push({
                x: x + 8, y: y + 8,
                vx: (Math.random() - 0.5) * 5, vy: (Math.random() - 0.5) * 5,
                life: 1.0, color: color
            });
        }
    }

    function shakeScreen(heavy = false) {
        let wrp = document.getElementById('game-wrapper');
        wrp.classList.add(heavy ? 'shatter-shake' : 'glitch-effect');
        setTimeout(() => {
            wrp.classList.remove('shatter-shake');
            wrp.classList.remove('glitch-effect');
        }, heavy ? 300 : 150);
    }

    function drawSprite(ctx, sprArray, x, y, scale, tint) {
        for(let r=0; r<16; r++) {
            for(let c=0; c<16; c++) {
                let char = sprArray[r][c];
                if(char !== '0') {
                    if(tint && char !== '1') ctx.fillStyle = tint; // Tint non-black parts
                    else ctx.fillStyle = colors[char];
                    ctx.fillRect(x + c*scale, y + r*scale, scale, scale);
                }
            }
        }
    }

    function gameLoop() {
        frameCount++;

        // Clear canvas
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        
        // Draw floor line
        ctx.fillStyle = "var(--gb-black)";
        ctx.fillRect(0, 110, canvas.width, 2);

        // Draw Player
        if(pVis && gameState !== "START") {
            let pSpr = player.transformed ? spr_awaken : spr_base;
            drawSprite(ctx, pSpr, pPos.x + pOff.x, pPos.y + pOff.y, 3, player.color);
        }

        // Draw Enemy
        if(currentEnemy && eVis && gameState !== "START") {
            drawSprite(ctx, currentEnemy.sprite, ePos.x + eOff.x, ePos.y + eOff.y, 4, null);
        }

        // Update Particles
        for(let i = particles.length-1; i>=0; i--) {
            let p = particles[i];
            p.x += p.x; p.y += p.y;
            p.life -= 0.05;
            if(p.life <= 0) particles.splice(i, 1);
            else {
                ctx.globalAlpha = p.life;
                ctx.fillStyle = p.color;
                ctx.fillRect(p.x, p.y, 3, 3);
                ctx.globalAlpha = 1.0;
            }
        }

        // Handle Clash Logic
        if(clashActive) {
            clashTimer--;
            clashValue -= 0.5; // Enemy pushes back constantly
            if(clashValue < 0) clashValue = 0;
            if(clashValue > 100) clashValue = 100;
            updateClashBar();
            
            if(clashTimer <= 0 || clashValue <= 0 || clashValue >= 100) {
                resolveClash();
            }
        }

        // Handle Typing effect
        if(isTyping && frameCount % 2 === 0) {
            if(textCharIndex < currentText.length) {
                typedText += currentText.charAt(textCharIndex);
                document.getElementById('dialogue-text').innerText = typedText;
                textCharIndex++;
            } else {
                isTyping = false;
                document.getElementById('dialogue-arrow').classList.remove('hidden');
            }
        }

        requestAnimationFrame(gameLoop);
    }

</script>
