    window.handleAction = function(act) {
        if (gameState !== "MENU") return;
        document.getElementById('action-menu').classList.add('hidden');
        
        if (act === 'awaken') {
            if (player.hp <= player.maxHp * 0.5 && !player.transformed) {
                document.getElementById('game-wrapper').classList.add('glitch-effect'); setTimeout(() => document.getElementById('game-wrapper').classList.remove('glitch-effect'), 1000);
                document.body.className = 'transformed-ui'; player.transformed = true; 
                player.atk = Math.floor(player.atk * player.transformData.mult); player.hp = player.maxHp;
                triggerScreenShatter();
                playAnim('PLAYER_HEAL', () => { updateHUD(); queueText(`AWAKENED: ${player.transformData.name}!\n${player.transformData.msg}`); endPlayerTurn(); }, player.transformData.color);
            }
        } 
        else if (act === 'domain') {
            document.getElementById('game-wrapper').classList.add('glitch-effect'); setTimeout(() => document.getElementById('game-wrapper').classList.remove('glitch-effect'), 500);
            triggerCutscene(`${player.name}:\nDOMAIN EXPANSION!\n${player.domain.name}`, () => {
