        document.getElementById('p-hp-bar').style.width = pPct + "%";
        document.getElementById('p-hp-bar').style.background = pPct > 50 ? "#22c55e" : (pPct > 20 ? "#eab308" : "#ef4444");
        document.getElementById('p-hp-text').innerText = `${Math.floor(player.hp)}/${player.maxHp}`;
        document.getElementById('p-lv').innerText = "Lv" + player.level;
        document.getElementById('p-money').innerText = player.money;

        // Player Domain
        let dPct = Math.min(100, player.domainMeter);
        document.getElementById('p-domain-bar').style.width = dPct + "%";
        document.getElementById('btn-domain').disabled = dPct < 100;
        
        // Player Status
        let status = [];
        if(player.invulnTurns > 0) status.push("INVINCIBLE");
        if(player.transformed) status.push(player.transformData.name);
        if(activeDomain) status.push("DOMAIN ACTIVE");
        document.getElementById('p-status').innerText = status.join(" | ");

        // Awaken / Ult Buttons
        document.getElementById('btn-awaken').disabled = player.transformed || pPct > 30;
        document.getElementById('btn-ultimate').disabled = player.domainMeter < 50; // Needs half meter

        // Enemy HP
        if(currentEnemy) {
            let ePct = Math.max(0, (currentEnemy.hp / currentEnemy.maxHp) * 100);
            document.getElementById('e-hp-bar').style.width = ePct + "%";
            document.getElementById('e-hp-bar').style.background = ePct > 50 ? "#22c55e" : (ePct > 20 ? "#eab308" : "#ef4444");
            
