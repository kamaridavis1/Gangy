    function queueText(text) { textQueue.push(text); }
    function processTextQueue() {
        if (textQueue.length > 0) {
            gameState = "TEXT"; currentText = textQueue.shift(); typedText = ""; textCharIndex = 0; isTyping = true;
            document.getElementById('dialogue-box').classList.remove('hidden');
            document.getElementById('action-menu').classList.add('hidden');
            document.getElementById('moves-menu').classList.add('hidden');
            document.getElementById('dialogue-arrow').classList.add('hidden');
        } else {
            if (onQueueEmpty) { let cb = onQueueEmpty; onQueueEmpty = null; cb(); } 
            else showActionMenu();
        }
    }

    window.advanceText = function() {
        if (gameState !== "TEXT" && gameState !== "INTRO") return;
        if (isTyping) {
            typedText = currentText; document.getElementById('dialogue-text').innerText = typedText;
            isTyping = false; textCharIndex = currentText.length; document.getElementById('dialogue-arrow').classList.remove('hidden');
        } else {
            if (gameState === "INTRO") { gameState = "BATTLE_WAIT"; queueText(`FIGHT!`); processTextQueue(); } 
            else processTextQueue();
        }
    };

    function showActionMenu() {
        gameState = "MENU";
        document.getElementById('dialogue-text').innerText = `What will\n${player.name} do?`;
        document.getElementById('dialogue-arrow').classList.add('hidden');
        document.getElementById('action-menu').classList.remove('hidden');
        document.getElementById('moves-menu').classList.add('hidden');
        updateHUD();
    }

    window.openMoves = function() {
        document.getElementById('action-menu').classList.add('hidden');
        let movesMenu = document.getElementById('moves-menu'); movesMenu.innerHTML = '';
        player.moves.forEach((m, i) => {
            let btn = document.createElement('button'); btn.className = 'menu-btn';
            btn.innerHTML = `${m.name}`; btn.style.color = m.color;
            btn.onclick = () => useMove(i); movesMenu.appendChild(btn);
        });
        let backBtn = document.createElement('button'); backBtn.className = 'menu-btn'; 
        if(player.moves.length % 2 !== 0) backBtn.style.gridColumn = 'span 2'; 
        backBtn.innerText = 'BACK'; backBtn.onclick = () => { movesMenu.classList.add('hidden'); document.getElementById('action-menu').classList.remove('hidden'); };
        movesMenu.appendChild(backBtn); movesMenu.classList.remove('hidden');
    }

    // --- BATTLE LOGIC ---
    function startEncounter() {
        currentEnemy = generateEnemy(currentFloor);
        activeDomain = null; eVis = true; pVis = true; eOff = {x:0, y:0}; pOff = {x:0, y:0};
        updateHUD();
        gameState = "INTRO"; currentText = currentEnemy.intro;
        typedText = ""; textCharIndex = 0; isTyping = true;
        document.getElementById('dialogue-box').classList.remove('hidden');
        document.getElementById('action-menu').classList.add('hidden');
        document.getElementById('moves-menu').classList.add('hidden');
    }

    window.handleAction = function(act) {
        if (gameState !== "MENU") return;
        document.getElementById('action-menu').classList.add('hidden');
        
        if (act === 'heal') {
            if (player.hp <= player.maxHp * 0.5 && !player.transformed) {
                document.getElementById('game-wrapper').classList.add('glitch-effect'); setTimeout(() => document.getElementById('game-wrapper').classList.remove('glitch-effect'), 1000);
                document.body.className = 'transformed-ui'; player.transformed = true; player.atk = Math.floor(player.atk * 1.5);
                triggerScreenShatter();
                playAnim('PLAYER_HEAL', () => { player.hp = player.maxHp; updateHUD(); queueText(`${player.name} AWAKENED! Stats drastically boosted!`); endPlayerTurn(); }, player.color);
            } else {
                queueText(`${player.name} used PLOT ARMOR!`);
                onQueueEmpty = () => { playAnim('PLAYER_HEAL', () => { player.hp = Math.min(player.maxHp, player.hp + player.maxHp*0.4); updateHUD(); queueText(`Recovered HP!`); endPlayerTurn(); }, '#22c55e'); };
                processTextQueue();
            }
        } 
        else if (act === 'domain') {
            document.getElementById('game-wrapper').classList.add('glitch-effect'); setTimeout(() => document.getElementById('game-wrapper').classList.remove('glitch-effect'), 500);
            triggerCutscene(`${player.name}:\nDOMAIN EXPANSION!\n${player.domain.name}`, () => {
                activeDomain = { owner: 'player', color1: player.domain.color1, color2: player.domain.color2, turnsLeft: 3 }; player.domainMeter = 0; document.body.className = 'domain-ui';
                createShockwave(120, 80, player.color, 15, 10);
                queueText(`The battlefield shifted! You get 3 TURNS of massive damage!`); endPlayerTurn();
            });
        } 
        else if (act === 'ultimate') {
            if (player.hp > player.maxHp * 0.5) return;
            document.getElementById('game-wrapper').classList.add('glitch-effect'); setTimeout(() => document.getElementById('game-wrapper').classList.remove('glitch-effect'), 400);
            triggerCutscene(`ULTIMATE:\n${player.ultName}!`, () => {
                queueText(player.ultMsg);
                onQueueEmpty = () => {
                    if (currentEnemy.hp <= currentEnemy.maxHp * 0.5 && !currentEnemy.ultimate.used) {
                        currentEnemy.ultimate.used = true; triggerCutscene(`ENEMY COUNTERS:\n${currentEnemy.ultimate.name}!`, startClash);
                    } else {
                        playAnim('PLAYER_ULTIMATE', () => {
                            triggerScreenShatter();
                            let dmg = getDamage(player.atk, 5.0, 'player'); currentEnemy.hp = Math.max(0, currentEnemy.hp - dmg); updateHUD();
                            queueText(`Devastating Hit! ${dmg} DMG!`); endPlayerTurn();
                        });
                    }
                };
                processTextQueue();
            });
        }
    }

    window.useMove = function(idx) {
        let m = player.moves[idx];
        document.getElementById('action-menu').classList.add('hidden'); document.getElementById('moves-menu').classList.add('hidden');
        queueText(`${player.name} used ${m.name}!`);

        onQueueEmpty = () => {
            playAnim('PLAYER_ATTACK', () => {
                if(m.type === 'buff') {
                    player.atk += Math.floor(player.atk * 0.25); queueText(`ATK sharply rose!`);
                } else if(m.type === 'heal_full') {
                    player.hp = player.maxHp; queueText(`HP fully restored!`);
                } else {
                    let dmg = getDamage(player.atk, m.power, 'player');
                    currentEnemy.hp = Math.max(0, currentEnemy.hp - dmg); queueText(`Dealt ${dmg} damage!`);
                    if (m.type === 'recoil') { let r = Math.floor(dmg * 0.2); player.hp = Math.max(0, player.hp - r); queueText(`Hit with recoil damage!`); }
                    if (m.type === 'vampire') { let v = Math.floor(dmg * 0.4); player.hp = Math.min(player.maxHp, player.hp + v); queueText(`Drained ${v} HP!`); }
                }
                updateHUD(); endPlayerTurn();
            }, m.color);
        };
        processTextQueue();
    }

    function getDamage(base, mult, attacker) {
        let d = Math.floor(base * mult * (0.85 + Math.random()*0.3));
        if (activeDomain && activeDomain.owner === attacker) d = Math.floor(d * 1.5);
        if (attacker === 'enemy' && player.vulnerable) d = Math.floor(d * 2.0);
        if (attacker === 'player' && player.vulnerable) d = Math.floor(d * 0.5);
        return d;
    }

    function endPlayerTurn() {
        onQueueEmpty = () => {
            if (currentEnemy.hp <= 0) { handleVictory(); return; }
            if (player.hp <= 0) { handleDefeat(); return; }
            player.vulnerable = false; 

            if (activeDomain && activeDomain.owner === 'player') {
                activeDomain.turnsLeft--;
                if (activeDomain.turnsLeft > 0) {
                    queueText(`DOMAIN ACTIVE! (${activeDomain.turnsLeft} turns left)`);
                    onQueueEmpty = showActionMenu; processTextQueue();
                } else {
                    document.getElementById('game-wrapper').classList.add('glitch-effect'); setTimeout(() => document.getElementById('game-wrapper').classList.remove('glitch-effect'), 500);
                    queueText(`DOMAIN COLLAPSED! ${player.name} is VULNERABLE!`); activeDomain = null; player.vulnerable = true;
                    document.body.className = player.transformed ? 'transformed-ui' : ''; 
                    onQueueEmpty = executeEnemyTurn; processTextQueue();
                }
            } else { player.domainMeter = Math.min(5, player.domainMeter + 1); executeEnemyTurn(); }
        };
        processTextQueue();
    }

    function executeEnemyTurn() {
        let e = currentEnemy;
        if (e.hp <= e.maxHp * 0.5 && !e.ultimate.used) {
            e.ultimate.used = true;
            triggerCutscene(`${e.name}:\n${e.ultimate.name}!`, () => {
                queueText(`${e.name} unleashes their Ultimate Attack!`);
                onQueueEmpty = () => {
                    if (player.hp <= player.maxHp * 0.5) {
                        queueText(`Counter with your ULTIMATE?`);
                        onQueueEmpty = () => {
                            document.getElementById('dialogue-text').innerText = "COUNTER?";
                            document.getElementById('action-menu').innerHTML = `<button class="menu-btn" style="color:red; grid-column: span 2;" onclick="acceptClash()">YES (ULTIMATE)</button><button class="menu-btn" style="grid-column: span 2;" onclick="declineClash()">NO (DEFEND)</button>`;
                            document.getElementById('action-menu').classList.remove('hidden'); gameState = "MENU";
                        }; processTextQueue();
                    } else {
                        playAnim('ENEMY_ULTIMATE', () => {
                            triggerScreenShatter();
                            let dmg = getDamage(e.atk, 5.0, 'enemy'); player.hp = Math.max(0, player.hp - dmg); updateHUD();
                            queueText(`You couldn't counter! Took ${dmg} DMG!`);
                            onQueueEmpty = () => { if(player.hp<=0) handleDefeat(); else showActionMenu(); }; processTextQueue();
                        });
                    }
                }; processTextQueue();
            }); return;
        }

        if (!activeDomain && e.domain) {
            triggerCutscene(`${e.name}: DOMAIN EXPANSION!\n${e.domain.name}`, () => {
                activeDomain = { owner: 'enemy', color1: e.domain.color1, color2: e.domain.color2, turnsLeft: 99 };
                createShockwave(120, 80, e.domain.color1, 15, 10); queueText(`The enemy expanded their Domain!`); e.domain = null;
                onQueueEmpty = showActionMenu; processTextQueue();
            }); return;
        }

        queueText(`--- ENEMY TURN ---`); queueText(`${e.name} used ${e.eMove}!`);
        onQueueEmpty = () => {
            playAnim('ENEMY_ATTACK', () => {
                let dmg = getDamage(e.atk, 1.2, 'enemy'); player.hp = Math.max(0, player.hp - dmg); updateHUD();
                queueText(`Took ${dmg} damage!`);
                onQueueEmpty = () => { if(player.hp<=0) handleDefeat(); else showActionMenu(); }; processTextQueue();
            }, e.color);
        }; processTextQueue();
    }

    // --- BEAM CLASH ---
    window.acceptClash = function() {
        document.getElementById('action-menu').classList.add('hidden'); resetActionMenu();
        document.getElementById('game-wrapper').classList.add('glitch-effect'); setTimeout(() => document.getElementById('game-wrapper').classList.remove('glitch-effect'), 500);
        triggerCutscene(`${player.name}:\n${player.ultName}!`, startClash);
    }
    window.declineClash = function() {
        document.getElementById('action-menu').classList.add('hidden'); resetActionMenu();
        playAnim('ENEMY_ULTIMATE', () => {
            triggerScreenShatter();
            let dmg = getDamage(currentEnemy.atk, 3.5, 'enemy'); player.hp = Math.max(0, player.hp - dmg); updateHUD();
            queueText(`Guarded! But still took ${dmg} DMG!`);
            onQueueEmpty = () => { if(player.hp<=0) handleDefeat(); else showActionMenu(); }; processTextQueue();
        });
    }
    function resetActionMenu() { document.getElementById('action-menu').innerHTML = `<button class="menu-btn" onclick="openMoves()">MOVES</button><button class="menu-btn" id="btn-domain" onclick="handleAction('domain')" style="color:#a855f7;">DOMAIN</button><button class="menu-btn" id="btn-heal" onclick="handleAction('heal')">HEAL</button><button class="menu-btn" id="btn-ultimate" onclick="handleAction('ultimate')" style="color:#ef4444; font-weight:bold;">ULTIMATE</button>`; }
    function startClash() { gameState = "CLASH"; clashActive = true; clashValue = 50; clashTimer = 100; document.getElementById('clash-layer').classList.remove('hidden'); updateClashUI(); }
    window.mashClash = function() { if(!clashActive) return; clashValue += 7; emitParticles(120, 80, player.color, 3, 10, 20); updateClashUI(); }
    function updateClashUI() { let bar = document.getElementById('clash-bar-fill'); bar.style.width = Math.max(0, Math.min(100, clashValue)) + '%'; bar.style.backgroundColor = clashValue > 50 ? player.color : '#ef4444'; }
    function resolveClash() {
        clashActive = false; document.getElementById('clash-layer').classList.add('hidden');
        if (clashValue >= 100 || (clashValue > 50 && clashTimer <= 0)) {
            playAnim('PLAYER_ULTIMATE', () => {
                triggerScreenShatter();
                let dmg = getDamage(player.atk, 6.0, 'player'); currentEnemy.hp = Math.max(0, currentEnemy.hp - dmg); updateHUD();
                queueText(`CLASH WON! You overwhelmed ${currentEnemy.name}! Dealt ${dmg} DMG!`); endPlayerTurn();
            });
        } else {
            playAnim('ENEMY_ULTIMATE', () => {
                triggerScreenShatter();
                let dmg = getDamage(currentEnemy.atk, 6.0, 'enemy'); player.hp = Math.max(0, player.hp - dmg); updateHUD();
                queueText(`CLASH LOST! Overpowered! Took ${dmg} DMG!`);
                onQueueEmpty = () => { if(player.hp<=0) handleDefeat(); else showActionMenu(); }; processTextQueue();
            });
        }
    }

    // --- CRAZY ANIMATIONS ---
    function triggerCutscene(text, callback) {
        gameState = "CUTSCENE"; let layer = document.getElementById('cutscene-layer'); let textEl = document.getElementById('cutscene-text');
        textEl.innerText = text; textEl.style.animation = 'none'; textEl.offsetHeight; textEl.style.animation = null;
        layer.classList.remove('hidden'); setTimeout(() => { layer.classList.add('hidden'); callback(); }, 1500);
    }

    function playAnim(type, callback, color = '#ffffff') {
        animState = type; animTimer = 0; animData.color = color;
        let int = setInterval(() => {
            animTimer++;
            if (type === 'PLAYER_ATTACK') {
                if(animTimer===1) pOff.x = 10; 
                if(animTimer===10) { pOff.x=0; animState="BEAM"; animData={x:80,y:90,w:0,h:12,color}; }
                if(animTimer>10 && animTimer<20) animData.w += 15;
                if(animTimer===20) { animState="SHAKE"; eFlash=true; emitParticles(150,30,color,15,5,20); }
                if(animTimer===35) { eFlash=false; animState=null; clearInterval(int); callback(); }
            }
            else if (type === 'ENEMY_ATTACK') {
                if(animTimer===1) eOff.x = -10; 
                if(animTimer===10) { eOff.x=0; animState="BEAM"; animData={x:150,y:30,w:0,h:18,color}; }
                if(animTimer>10 && animTimer<20) { animData.w -= 15; animData.x -= 15; }
                if(animTimer===20) { animState="SHAKE"; pFlash=true; emitParticles(30,80,color,15,5,20); }
                if(animTimer===35) { pFlash=false; animState=null; clearInterval(int); callback(); }
            }
            else if (type === 'PLAYER_HEAL') {
                if(animTimer%5===0) emitParticles(pPos.x+16, pPos.y+16, color, 6, 4, 25);
                if(animTimer===30) { animState=null; clearInterval(int); callback(); }
            }
            else if (type === 'PLAYER_ULTIMATE') {
                // Different Ultimate Types Based on Character
                let uc = player.color;
                if (player.ultType === "BEAM") {
                    if(animTimer===1) { animState="SHAKE"; emitParticles(pPos.x+16, pPos.y+16, uc, 40, 10, 50); }
                    if(animTimer===20) { animState="BEAM"; animData={x:50,y:-20,w:0,h:200,color:uc}; document.getElementById('game-wrapper').style.filter = "invert(1)"; } 
                    if(animTimer>20 && animTimer<35) animData.w += 20;
                    if(animTimer===35) { animState="SHAKE"; eFlash=true; emitParticles(150,30,uc,80,20,40); document.getElementById('game-wrapper').style.filter = "none"; createShockwave(180, 50, uc, 10, 5); }
                } else if (player.ultType === "BURST") {
                    if(animTimer===1) { animState="SHAKE"; emitParticles(pPos.x+16, pPos.y+16, uc, 60, 15, 60); }
                    if(animTimer===20) { animState="SHAKE"; eFlash=true; createShockwave(180, 50, uc, 25, 20); document.getElementById('game-wrapper').style.filter = "saturate(5) hue-rotate(90deg)"; }
                    if(animTimer===30) { createShockwave(180, 50, '#fff', 30, 10); emitParticles(180, 50, uc, 100, 25, 50); }
                    if(animTimer===40) document.getElementById('game-wrapper').style.filter = "none";
                } else if (player.ultType === "SLASH") {
                    if(animTimer===1) { animState="SHAKE"; pOff.x = 100; pOff.y = -50; }
                    if(animTimer===15) { animState="SLASH"; animData={x1: 240, y1: 0, x2: 0, y2: 160, color: uc, w: 2}; document.getElementById('game-wrapper').style.filter = "invert(1)"; }
                    if(animTimer>15 && animTimer<25) { animData.w += 5; eFlash = true; }
                    if(animTimer===25) { animState="SHAKE"; pOff.x = 0; pOff.y = 0; document.getElementById('game-wrapper').style.filter = "none"; emitParticles(180, 50, uc, 50, 15, 30); }
                } else if (player.ultType === "QUAKE") {
                    if(animTimer===1) { animState="SHAKE"; document.getElementById('game-wrapper').classList.add('shatter-shake'); }
                    if(animTimer===20) { 
                        animState="SHAKE"; document.getElementById('game-wrapper').classList.remove('shatter-shake'); eFlash=true; 
                        for(let q=0; q<5; q++) createShockwave(180, 100, uc, 15+q*2, 10);
                        emitParticles(180, 100, '#444', 100, 15, 40); 
                    }
                } else if (player.ultType === "GLITCH") {
                    if(animTimer===1) { animState="GLITCH"; document.getElementById('game-wrapper').classList.add('glitch-effect'); }
                    if(animTimer===30) { animState="SHAKE"; eFlash=true; createShockwave(180, 50, uc, 50, 5); document.getElementById('game-wrapper').classList.remove('glitch-effect'); }
                }

                if(animTimer===65) { eFlash=false; animState=null; clearInterval(int); callback(); }
            }
            else if (type === 'ENEMY_ULTIMATE') {
                let ec = currentEnemy.color;
                if(animTimer===1) { animState="SHAKE"; emitParticles(ePos.x+16, ePos.y+16, ec, 40, 10, 50); }
                if(animTimer===20) { animState="BEAM"; animData={x:190,y:-20,w:0,h:200,color:ec}; document.getElementById('game-wrapper').style.filter = "invert(1) hue-rotate(180deg)"; } 
                if(animTimer>20 && animTimer<35) { animData.w -= 20; animData.x -= 20; }
                if(animTimer===35) { animState="SHAKE"; pFlash=true; emitParticles(30,80,ec,80,20,40); document.getElementById('game-wrapper').style.filter = "none"; createShockwave(60, 120, ec, 10, 5); }
                if(animTimer===65) { pFlash=false; animState=null; clearInterval(int); callback(); }
            }
            else if (type === 'ENEMY_FAINT') {
                eOff.y += 4; emitParticles(ePos.x+16, ePos.y+eOff.y, '#ffffff', 2, 1, 10);
                if (animTimer === 30) { eVis = false; animState=null; clearInterval(int); callback(); }
            }
        }, 1000/60); 
    }

    // --- PROGRESSION & LOOT ---
    function handleVictory() {
        playAnim('ENEMY_FAINT', () => {
            queueText(`You obliterated ${currentEnemy.name}!`);
            queueText(`${player.name} grew to level ${player.level + 1}!`);
            onQueueEmpty = () => { showLootScreen(); };
            processTextQueue();
        });
    }

    function handleDefeat() {
        queueText(`${player.name} was overwhelmed...`);
        onQueueEmpty = () => { 
            document.getElementById('death-stats').innerText = `You reached TOWER FLOOR ${currentFloor}.`;
            document.getElementById('game-over-screen').classList.remove('hidden'); gameState = "GAMEOVER"; 
        };
        processTextQueue();
    }

    function showLootScreen() {
        gameState = "LOOT"; document.getElementById('loot-screen').classList.remove('hidden');
        let container = document.getElementById('loot-container'); container.innerHTML = '';
        
        let rewards = [];
        while(rewards.length < 3) {
            let randMove = ANIME_MOVES[Math.floor(Math.random() * ANIME_MOVES.length)];
            if(!rewards.find(r => r.move.name === randMove.name)) rewards.push({type: 'move', move: randMove, name: randMove.name, desc: randMove.desc, color: randMove.color});
        }

        rewards.forEach(r => {
            let card = document.createElement('div'); card.className = 'loot-card';
            card.innerHTML = `<div class="loot-title" style="color:${r.color}">${r.name}</div><div class="loot-desc">${r.desc}</div><div class="loot-type">${r.move.type.toUpperCase()}</div>`;
            card.onclick = () => claimLoot(r); container.appendChild(card);
        });
    }

    window.skipLoot = function() { document.getElementById('loot-screen').classList.add('hidden'); advanceFloor(); }

    function claimLoot(reward) {
        if (player.moves.find(m => m.name === reward.move.name)) return alert("You already know this move!");
        
        if (player.moves.length >= 4) {
            pendingLootMove = reward.move; document.getElementById('loot-screen').classList.add('hidden'); showReplaceScreen();
        } else {
            player.moves.push(reward.move); document.getElementById('loot-screen').classList.add('hidden'); advanceFloor();
        }
    }

    function showReplaceScreen() {
        gameState = "REPLACE"; document.getElementById('replace-screen').classList.remove('hidden');
        document.getElementById('replace-prompt').innerText = `Learn [${pendingLootMove.name}]. Which move will you forget?`;
        let grid = document.getElementById('replace-grid'); grid.innerHTML = '';
        
        player.moves.forEach((m, i) => {
            let btn = document.createElement('button'); btn.className = 'big-btn'; btn.style.width = '100%'; btn.style.fontSize = '1.2vw';
            btn.innerHTML = `<span style="color:${m.color}">${m.name}</span>`;
            btn.onclick = () => { player.moves[i] = pendingLootMove; document.getElementById('replace-screen').classList.add('hidden'); advanceFloor(); };
            grid.appendChild(btn);
        });
    }

    window.cancelReplace = function() { document.getElementById('replace-screen').classList.add('hidden'); advanceFloor(); }

    function advanceFloor() {
        currentFloor++; player.level++;
        player.hp = Math.min(player.maxHp, player.hp + Math.floor(player.maxHp * 0.2));
        player.maxHp += 10; player.atk += 5; 
        startEncounter();
    }

    // --- MAIN LOOP ---
    function gameLoop() {
        frameCount++;
        if (gameState === "TEXT" || gameState === "INTRO") {
            if (isTyping && frameCount % typeSpeed === 0) {
                typedText += currentText.charAt(textCharIndex); document.getElementById('dialogue-text').innerText = typedText; textCharIndex++;
                if (textCharIndex >= currentText.length) { isTyping = false; document.getElementById('dialogue-arrow').classList.remove('hidden'); }
            }
        } else if (gameState === "CLASH") {
            clashTimer--; clashValue -= 1.5; updateClashUI();
            if(frameCount%2===0) emitParticles(120 + (clashValue-50)*2, 80, (Math.random()>0.5?player.color:'#ef4444'), 4, 8, 15);
            if (clashValue >= 100 || clashValue <= 0 || clashTimer <= 0) resolveClash();
        }
        updateParticles(); renderGame(); requestAnimationFrame(gameLoop);
    }
    
    requestAnimationFrame(gameLoop);

</script>
</body>
