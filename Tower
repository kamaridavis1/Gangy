<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>GANGY TOWER - DELUXE</title>
    <link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap" rel="stylesheet">
    <style>
        :root { --bg-color: #050505; --gb-white: #f8f8f8; --gb-black: #181818; --gb-gray: #686868; --gb-lightgray: #a8a8a8; }
        body, html { margin: 0; padding: 0; width: 100%; height: 100%; background-color: var(--bg-color); display: flex; justify-content: center; align-items: center; font-family: 'Press Start 2P', monospace; color: var(--gb-black); user-select: none; touch-action: none; overflow: hidden; }
        
        body.domain-ui { --bg-color: #0f001a; --gb-white: #1a0033; --gb-black: #e6ccff; --gb-gray: #9933ff; --gb-lightgray: #d9b3ff; animation: domainPulse 2s infinite alternate; }
        @keyframes domainPulse { 0% { box-shadow: inset 0 0 5vw #a855f7; } 100% { box-shadow: inset 0 0 15vw #6b21a8; } }
        body.transformed-ui { --bg-color: #1a0000; --gb-white: #000; --gb-black: #fca5a5; --gb-gray: #ef4444; --gb-lightgray: #7f1d1d; }

        #game-wrapper { position: relative; width: 100%; max-width: 900px; aspect-ratio: 3 / 2; background-color: var(--gb-white); overflow: hidden; border: 0.5vw solid var(--gb-black); box-shadow: 0 10px 50px rgba(0,0,0,0.9); image-rendering: pixelated; transition: all 0.1s; }
        #game-wrapper::after { content: ""; position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.15) 50%); background-size: 100% 4px; z-index: 5; pointer-events: none; }
        canvas { position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 1; }
        #shatterCanvas { position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 45; pointer-events: none; }
        #ui-layer { position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 10; pointer-events: none; display: flex; flex-direction: column; }
        .hidden { display: none !important; }

        #top-bar { position: absolute; top: 0.5vw; left: 50%; transform: translateX(-50%); display: flex; gap: 1vw; z-index: 15; }
        .top-indicator { background: var(--gb-black); color: var(--gb-white); padding: 0.5vw 1vw; font-size: 1vw; border-radius: 0.5vw; border: 0.2vw solid var(--gb-gray); text-align: center; }
        .hud-box { position: absolute; background: var(--gb-white); border: 0.4vw solid var(--gb-black); border-radius: 0.5vw; padding: 1vw; box-shadow: 0.4vw 0.4vw 0 rgba(0,0,0,0.3); z-index: 12; }
        .hud-name { font-size: 1.4vw; margin-bottom: 0.5vw; text-transform: uppercase; color: var(--gb-black); }
        .hud-lv { font-size: 0.9vw; float: right; color: var(--gb-black); }
        .hp-container { display: flex; align-items: center; margin-bottom: 0.5vw; background: var(--gb-black); border-radius: 0.3vw; padding: 0.2vw 0.5vw; }
        .hp-label { color: #facc15; font-size: 1vw; margin-right: 0.5vw; }
        .hp-bar-bg { flex-grow: 1; height: 1vw; background: var(--gb-gray); border: 0.2vw solid var(--gb-black); position: relative; }
        .hp-bar-fill { height: 100%; background: #22c55e; width: 100%; transition: width 0.3s; }
        .hp-text { font-size: 1.2vw; text-align: right; color: var(--gb-black); margin-bottom: 0.5vw; }
        .status-text { font-size: 0.8vw; color: #3b82f6; text-align: right; }

        #enemy-hud { top: 3vw; left: 2vw; width: 35%; }
        #player-hud { bottom: 33%; right: 2vw; width: 40%; }
        .vulnerable-shake { animation: vulnShake 0.3s infinite; border-color: #ef4444 !important; background-color: #fee2e2 !important; }
        @keyframes vulnShake { 0%{transform:translateX(0);} 25%{transform:translateX(-0.5vw);} 75%{transform:translateX(0.5vw);} }

        #bottom-panel { position: absolute; bottom: 0; left: 0; width: 100%; height: 30%; background: var(--gb-white); border-top: 0.5vw solid var(--gb-black); display: flex; pointer-events: auto; box-sizing: border-box; z-index: 15; }
        #dialogue-box { flex: 1; padding: 2vw; font-size: 1.4vw; line-height: 1.6; cursor: pointer; border-right: 0.5vw solid var(--gb-black); color: var(--gb-black); position:relative;}
        #action-menu, #moves-menu, #items-menu { width: 50%; padding: 1vw; display: grid; grid-template-columns: 1fr 1fr; gap: 0.5vw; box-sizing: border-box; align-content: center; }

        .menu-btn { background: var(--gb-white); border: 0.3vw solid var(--gb-black); color: var(--gb-black); border-radius: 0.5vw; font-family: 'Press Start 2P', monospace; font-size: 0.8vw; cursor: pointer; text-transform: uppercase; transition: 0.1s; padding: 0.8vw 0.5vw; }
        .menu-btn:hover { background: var(--gb-lightgray); transform: scale(1.03); }
        .menu-btn:active { background: var(--gb-gray); color: white; }
        .menu-btn:disabled { opacity: 0.4; cursor: not-allowed; }
        .btn-highlight { border-color: #ef4444; color: #ef4444; animation: pulseBtn 1s infinite alternate; }
        @keyframes pulseBtn { from {transform: scale(1);} to {transform: scale(1.05); box-shadow: 0 0 10px #ef4444;} }

        .glitch-effect { animation: guiGlitch 0.15s both infinite; }
        @keyframes guiGlitch { 0% { filter: invert(0) drop-shadow(0 0 0 red); transform: translate(0); } 25% { filter: invert(1) hue-rotate(90deg) drop-shadow(1vw 0 0 red); transform: translate(-1vw, 1vw); } 50% { filter: hue-rotate(180deg) drop-shadow(-1vw 0 0 blue); transform: translate(1vw, -1vw); } 100% { filter: invert(0) drop-shadow(0 0 0 red); transform: translate(0); } }
        .shatter-shake { animation: shatterShake 0.05s infinite !important; }
        @keyframes shatterShake { 0% { transform: translate(3vw, 3vw) rotate(2deg); filter: invert(1) saturate(5); } 25% { transform: translate(-3vw, -3vw) rotate(-2deg); filter: invert(0) hue-rotate(180deg); } 50% { transform: translate(3vw, -3vw) rotate(2deg); filter: sepia(1) hue-rotate(300deg) saturate(10); } 75% { transform: translate(-3vw, 3vw) rotate(-2deg); filter: invert(1) brightness(2); } 100% { transform: translate(0, 0) rotate(0); filter: invert(0); } }
        #flash-overlay { position: absolute; top:0; left:0; width:100%; height:100%; background: white; z-index: 44; opacity: 0; pointer-events: none; transition: opacity 0.05s; }
        .super-flash { animation: superFlashAnim 0.5s ease-out; }
        @keyframes superFlashAnim { 0% { opacity: 1; background: white; } 50% { opacity: 1; background: red; } 100% { opacity: 0; background: white; } }

        #cutscene-layer, #clash-layer { position: absolute; top:0; left:0; width:100%; height:100%; z-index: 40; display: flex; flex-direction: column; justify-content: center; align-items: center; background: rgba(0,0,0,0.85); pointer-events: auto; }
        .cinematic-text { color: white; font-size: 4vw; text-shadow: 0.5vw 0.5vw 0 #ef4444; animation: cinematicSlide 0.4s ease-out forwards; text-align: center; line-height: 1.2; }
        @keyframes cinematicSlide { 0% { transform: scale(5) rotate(-10deg); opacity: 0; } 100% { transform: scale(1) rotate(0); opacity: 1; } }
        #clash-bar-container { width: 80%; height: 4vw; background: #333; border: 0.5vw solid white; margin-top: 2vw; box-shadow: 0 0 2vw #3b82f6; }
        #clash-bar-fill { height: 100%; width: 50%; background: #3b82f6; transition: width 0.1s; }
        .mash-btn { margin-top: 3vw; padding: 2vw 4vw; font-size: 3vw; background: #ef4444; color: white; border: 0.5vw solid white; cursor: pointer; font-family: 'Press Start 2P'; border-radius: 1vw; }

        .full-screen { position: absolute; top: 0; left: 0; width: 100%; height: 100%; display: flex; flex-direction: column; justify-content: center; align-items: center; text-align: center; pointer-events: auto; z-index: 50; background: var(--gb-white); box-sizing: border-box; }
        h1 { font-size: 4vw; color: var(--gb-black); margin-bottom: 1vw; text-shadow: 0.4vw 0.4vw 0 var(--gb-lightgray); }
        h2 { font-size: 1.5vw; color: var(--gb-gray); margin-bottom: 2vw; line-height: 1.5; }
        .big-btn { padding: 1.5vw 3vw; font-size: 1.5vw; background: var(--gb-black); color: var(--gb-white); border: 0.5vw solid var(--gb-gray); cursor: pointer; font-family: 'Press Start 2P'; margin-bottom: 1vw; width: 75%; transition: 0.2s; }
        .big-btn:hover { background: var(--gb-gray); transform: scale(1.05); }

        .slider-container { margin: 2vw 0; display: flex; flex-direction: column; align-items: center; width: 60%; }
        input[type=range] { width: 100%; margin-top: 1vw; }
        .credits { position: absolute; bottom: 1vw; right: 1vw; font-size: 1vw; color: var(--gb-gray); }

        .shop-grid, #loot-container, #replace-grid { display: flex; flex-wrap: wrap; gap: 1vw; width: 95%; justify-content: center; margin-bottom: 2vw; }
        .card { background: var(--gb-black); color: white; border: 0.4vw solid var(--gb-gray); border-radius: 1vw; width: 30%; padding: 1vw; display: flex; flex-direction: column; align-items: center; cursor: pointer; transition: 0.2s; box-sizing: border-box; position: relative; overflow: hidden; }
        .card:hover { transform: translateY(-0.5vw) scale(1.05); border-color: white; box-shadow: 0 1vw 2vw rgba(0,0,0,0.8); z-index: 10; }
        .card-title { font-size: 1vw; color: #facc15; margin-bottom: 0.5vw; text-align: center; height: 2.5vw; }
        .card-desc { font-size: 0.7vw; color: #cbd5e1; text-align: center; line-height: 1.4; margin-bottom:0.5vw; }
        .card-price { font-size: 0.8vw; color: #4ade80; margin-top: auto; }

        .blink { animation: blinker 1s linear infinite; }
        @keyframes blinker { 50% { opacity: 0; } }
    </style>
</head>
<body>

<div id="game-wrapper">
    <canvas id="gameCanvas" width="240" height="160"></canvas>
    <canvas id="shatterCanvas" width="900" height="600"></canvas>
    <div id="flash-overlay"></div>

    <div id="ui-layer">
        <div id="top-bar" class="hidden">
            <div class="top-indicator">FLOOR: <span id="floor-num">1</span></div>
            <div class="top-indicator" style="color:#4ade80;">$ <span id="p-money">0</span></div>
        </div>

        <div id="battle-ui" class="hidden">
            <div id="enemy-hud" class="hud-box">
                <div class="hud-name" id="e-name">Enemy</div>
                <div class="hud-lv" id="e-lv">Lv1</div>
                <div class="hp-container"><span class="hp-label">HP</span><div class="hp-bar-bg"><div class="hp-bar-fill" id="e-hp-bar"></div></div></div>
            </div>

            <div id="player-hud" class="hud-box">
                <div class="hud-name" id="p-name">PLAYER</div>
                <div class="hud-lv" id="p-lv">Lv1</div>
                <div class="hp-container"><span class="hp-label">HP</span><div class="hp-bar-bg"><div class="hp-bar-fill" id="p-hp-bar"></div></div></div>
                <div class="hp-container" style="margin-bottom:0.2vw;"><span class="hp-label" style="color:#a855f7;">DOM</span><div class="hp-bar-bg" style="background:#333;"><div class="hp-bar-fill" id="p-domain-bar" style="background:#a855f7; width:0%;"></div></div></div>
                <div class="hp-text" id="p-hp-text">100/100</div>
                <div class="status-text" id="p-status"></div>
            </div>

            <div id="bottom-panel">
                <div id="dialogue-box" onclick="advanceText()"><span id="dialogue-text"></span><span id="dialogue-arrow" class="blink hidden">▼</span></div>
                <div id="action-menu" class="hidden">
                    <button class="menu-btn" onclick="openMenu('moves')">MOVES</button>
                    <button class="menu-btn" onclick="openMenu('items')">ITEMS</button>
                    <button class="menu-btn" id="btn-domain" onclick="handleAction('domain')" style="color:#a855f7;">DOMAIN</button>
                    <button class="menu-btn" id="btn-awaken" onclick="handleAction('awaken')" style="color:#eab308;">AWAKEN</button>
                    <button class="menu-btn" id="btn-ultimate" onclick="handleAction('ultimate')" style="color:#ef4444; font-weight:bold; grid-column: span 2;">ULTIMATE</button>
                </div>
                <div id="moves-menu" class="hidden"></div>
                <div id="items-menu" class="hidden"></div>
            </div>
        </div>

        <div id="cutscene-layer" class="hidden"><h1 id="cutscene-text" class="cinematic-text">DOMAIN EXPANSION</h1></div>
        <div id="clash-layer" class="hidden">
            <h1 style="color:white; font-size:3vw; text-shadow: none;">BEAM CLASH!</h1>
            <div id="clash-bar-container"><div id="clash-bar-fill"></div></div>
            <button class="mash-btn" onclick="mashClash()">MASH CLICK!</button>
        </div>

        <div id="start-screen" class="full-screen">
            <h1 style="font-size: 5vw; color: #3b82f6;">GANGY TOWER</h1>
            <h2>Climb infinitely. Survive. Awaken.</h2>
            <div class="slider-container">
                <label for="diff-slider" style="font-size: 1.2vw; color: #a8a8a8;">DIFFICULTY: <span id="diff-label">NORMAL</span></label>
                <input type="range" id="diff-slider" min="0.5" max="2.0" step="0.5" value="1.0" oninput="updateDiff()">
            </div>
            <button class="big-btn" onclick="initGame()">ENTER TOWER</button>
            <div class="credits">Made by Kamari Davis</div>
        </div>

        <div id="loot-screen" class="full-screen hidden" style="background:var(--gb-black); color:white;">
            <h1 style="color:white; text-shadow:none; font-size:3vw;">FLOOR CLEARED!</h1>
            <h2 style="color:#a8a8a8; font-size: 1vw;">Select 1 technique to learn:</h2>
            <div id="loot-container"></div>
            <button class="big-btn" style="background:#333; width: 40%; font-size: 1vw; padding: 1vw;" onclick="skipMenu('loot')">SKIP</button>
        </div>

        <div id="shop-screen" class="full-screen hidden" style="background:#1e3a8a; color:white;">
            <h1 style="color:#facc15; text-shadow:none; font-size:3vw;">MYSTERIOUS SHOP</h1>
            <h2 style="color:#bfdbfe; font-size: 1.2vw;">Buy items & techniques! (Money: $<span id="shop-money"></span>)</h2>
            <div id="shop-grid" class="shop-grid"></div>
            <button class="big-btn" style="background:#1e40af; width: 40%; font-size: 1vw; padding: 1vw;" onclick="skipMenu('shop')">LEAVE SHOP</button>
        </div>

        <div id="replace-screen" class="full-screen hidden" style="background:#1e1b4b; color:white;">
            <h1 style="color:white; text-shadow:none; font-size:2.5vw;">MOVE SLOTS FULL</h1>
            <h2 style="color:#a5b4fc; margin-bottom: 2vw;" id="replace-prompt">Choose a move to forget:</h2>
            <div id="replace-grid"></div>
            <button class="big-btn" style="background:#312e81; width: 40%; font-size: 1vw;" onclick="cancelReplace()">CANCEL</button>
        </div>

        <div id="game-over-screen" class="full-screen hidden" style="background:#450a0a;">
            <h1 style="color:#fca5a5; text-shadow:none;">DEFEATED</h1>
            <h2 style="color:#fecaca;" id="death-stats">You reached Floor X.</h2>
            <button class="big-btn" style="background:#fca5a5; color:#450a0a;" onclick="location.reload()">REINCARNATE</button>
        </div>
    </div>
</div>

