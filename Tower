            template = ANIME_ENEMIES[Math.floor(Math.random() * ANIME_ENEMIES.length)];
        }

        let eMaxHp = currentFloor === 100 ? 9999 : Math.floor(150 * floorMult * (isBoss ? 3 : 1));
        let eAtk = currentFloor === 100 ? 200 : Math.floor(25 * floorMult * (isBoss ? 1.5 : 1));
        
        let eSkills = template.moves.map(mName => JSON.parse(JSON.stringify(ALL_ANIME_ABILITIES.find(a => a.n === mName) || BASIC_ATTACK)));
