<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Anime Outfit Collector</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body {
            margin: 0;
            overflow: hidden;
            background-color: #1a202c; /* Tailwind gray-900 */
            touch-action: none; /* Prevent scrolling on touch devices */
        }
        canvas {
            display: block;
        }
        #ui-layer {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            padding: 1.5rem;
            box-sizing: border-box;
        }
        .pointer-events-auto {
            pointer-events: auto;
        }
    </style>
</head>
<body>

    <!-- UI Overlay -->
    <div id="ui-layer">
        <div class="flex justify-between items-start">
            <div>
                <h1 class="text-3xl font-bold text-white drop-shadow-md">Anime Sprite-less Game</h1>
                <p class="text-gray-300 font-medium text-lg mt-1">Outfit: <span id="outfit-name" class="text-yellow-400 font-bold">Loading...</span></p>
                <p class="text-white font-bold text-xl mt-2">Score: <span id="score">0</span></p>
            </div>
            <button id="reroll-btn" class="pointer-events-auto bg-indigo-600 hover:bg-indigo-500 text-white font-bold py-2 px-4 rounded-full shadow-lg transition-transform transform hover:scale-105 active:scale-95 border-2 border-indigo-400">
                ✨ Change Outfit
            </button>
        </div>
        
        <div class="text-center text-gray-400 text-sm mb-4 bg-gray-900/50 p-2 rounded-xl inline-block self-center backdrop-blur-sm">
            Use <b>WASD</b> / <b>Arrow Keys</b> to move. On mobile, <b>Tap</b> or <b>Drag</b> to move.
        </div>
    </div>

    <!-- Game Canvas -->
    <canvas id="gameCanvas"></canvas>

    <script>
        const canvas = document.getElementById('gameCanvas');
        const ctx = canvas.getContext('2d');
        const outfitNameDisplay = document.getElementById('outfit-name');
        const scoreDisplay = document.getElementById('score');
        const rerollBtn = document.getElementById('reroll-btn');

        // Game State
        let score = 0;
        let width, height;
        let lastTime = performance.now();
        let particles = []; // Moved to the top so it's initialized before setRandomOutfit is called
        
        // Input tracking
        const keys = { w: false, a: false, s: false, d: false, ArrowUp: false, ArrowLeft: false, ArrowDown: false, ArrowRight: false };
        let touchTarget = null;

        // Resize handler
        function resize() {
            width = window.innerWidth;
            height = window.innerHeight;
            canvas.width = width;
            canvas.height = height;
        }
        window.addEventListener('resize', resize);
        resize();

        // Player setup
        const player = {
            x: width / 2,
            y: height / 2,
            speed: 300, // pixels per second
            size: 1, // scale
            isMoving: false,
            facingRight: true,
            currentOutfitIndex: 0,
            trailTimer: 0
        };

        // Collectibles
        const collectibles = [];
        function spawnCollectible() {
            collectibles.push({
                x: Math.random() * (width - 100) + 50,
                y: Math.random() * (height - 100) + 50,
                radius: 10,
                baseY: 0,
                timeOffset: Math.random() * 1000
            });
        }
        for(let i=0; i<5; i++) spawnCollectible();

        // --- PROCEDURAL OUTFIT DEFINITIONS ---
        // We draw everything using pure canvas operations. No images.
        const skinColor = "#ffcd94";
        
        const outfits = [
            {
                name: "Hidden Leaf Ninja",
                draw: (ctx, time, isMoving) => {
                    // Spiky blonde hair (back)
                    ctx.fillStyle = "#FFD700";
                    ctx.beginPath();
                    ctx.moveTo(-15, -25); ctx.lineTo(-25, -45); ctx.lineTo(-10, -35); ctx.lineTo(0, -50); ctx.lineTo(10, -35); ctx.lineTo(25, -45); ctx.lineTo(15, -25);
                    ctx.fill();

                    // Headband
                    ctx.fillStyle = "#0052A5"; // Blue fabric
                    ctx.fillRect(-14, -30, 28, 10);
                    ctx.fillStyle = "#C0C0C0"; // Metal plate
                    ctx.fillRect(-8, -28, 16, 6);

                    // Orange Tracksuit Torso
                    ctx.fillStyle = "#FF6600";
                    ctx.fillRect(-14, -5, 28, 25);
                    
                    // Blue shoulder accents
                    ctx.fillStyle = "#0052A5";
                    ctx.fillRect(-14, -5, 8, 8);
                    ctx.fillRect(6, -5, 8, 8);

                    // Arms (Orange sleeves)
                    let armSwing = isMoving ? Math.sin(time * 0.015) * 15 : 0;
                    ctx.save(); ctx.translate(-14, 0); ctx.rotate(-armSwing * Math.PI / 180); ctx.fillStyle = "#FF6600"; ctx.fillRect(-8, 0, 8, 18); ctx.fillStyle = skinColor; ctx.fillRect(-6, 18, 5, 5); ctx.restore(); // Left Arm
                    ctx.save(); ctx.translate(14, 0); ctx.rotate(armSwing * Math.PI / 180); ctx.fillStyle = "#FF6600"; ctx.fillRect(0, 0, 8, 18); ctx.fillStyle = skinColor; ctx.fillRect(1, 18, 5, 5); ctx.restore(); // Right Arm

                    // Legs (Orange pants)
                    let legSwing = isMoving ? Math.sin(time * 0.015) * 15 : 0;
                    ctx.save(); ctx.translate(-8, 20); ctx.rotate(legSwing * Math.PI / 180); ctx.fillStyle = "#FF6600"; ctx.fillRect(-6, 0, 10, 18); ctx.fillStyle = "#333"; ctx.fillRect(-6, 15, 10, 5); ctx.restore(); // Left Leg
                    ctx.save(); ctx.translate(8, 20); ctx.rotate(-legSwing * Math.PI / 180); ctx.fillStyle = "#FF6600"; ctx.fillRect(-4, 0, 10, 18); ctx.fillStyle = "#333"; ctx.fillRect(-4, 15, 10, 5); ctx.restore(); // Right Leg
                }
            },
            {
                name: "Magical Girl",
                draw: (ctx, time, isMoving) => {
                    // Massive Pink Twintails
                    ctx.fillStyle = "#FF69B4";
                    // Left tail
                    ctx.beginPath(); ctx.ellipse(-25, -15, 8, 25, Math.PI / -6, 0, Math.PI * 2); ctx.fill();
                    // Right tail
                    ctx.beginPath(); ctx.ellipse(25, -15, 8, 25, Math.PI / 6, 0, Math.PI * 2); ctx.fill();
                    
                    // Pink Dress Bodice
                    ctx.fillStyle = "#FF1493";
                    ctx.beginPath(); ctx.moveTo(-12, -5); ctx.lineTo(12, -5); ctx.lineTo(10, 15); ctx.lineTo(-10, 15); ctx.fill();
                    // White chest bow
                    ctx.fillStyle = "white";
                    ctx.beginPath(); ctx.moveTo(0, 0); ctx.lineTo(-8, -5); ctx.lineTo(-8, 5); ctx.fill();
                    ctx.beginPath(); ctx.moveTo(0, 0); ctx.lineTo(8, -5); ctx.lineTo(8, 5); ctx.fill();
                    ctx.fillStyle = "#FFD700"; ctx.beginPath(); ctx.arc(0, 0, 3, 0, Math.PI * 2); ctx.fill();

                    // Frilly Skirt (multiple overlapping white and pink circles)
                    ctx.fillStyle = "white";
                    for(let i=-1; i<=1; i++) { ctx.beginPath(); ctx.arc(i*12, 18, 12, 0, Math.PI * 2); ctx.fill(); }
                    ctx.fillStyle = "#FF69B4";
                    for(let i=-1; i<=1; i++) { ctx.beginPath(); ctx.arc(i*10, 16, 10, 0, Math.PI * 2); ctx.fill(); }

                    // Arms with long gloves
                    let armSwing = isMoving ? Math.sin(time * 0.015) * 15 : 0;
                    ctx.save(); ctx.translate(-12, -2); ctx.rotate(-armSwing * Math.PI / 180); ctx.fillStyle = skinColor; ctx.fillRect(-6, 0, 6, 8); ctx.fillStyle = "white"; ctx.fillRect(-6, 8, 6, 12); ctx.restore(); // Left Arm
                    
                    // Right Arm holds a Magic Wand!
                    ctx.save(); ctx.translate(12, -2); ctx.rotate(armSwing * Math.PI / 180); 
                    ctx.fillStyle = skinColor; ctx.fillRect(0, 0, 6, 8); ctx.fillStyle = "white"; ctx.fillRect(0, 8, 6, 12); 
                    // Wand
                    ctx.fillStyle = "#FFD700"; ctx.fillRect(2, -15, 2, 30);
                    ctx.fillStyle = "#FF1493"; // Glowing gem
                    let glow = Math.abs(Math.sin(time * 0.005)) * 5;
                    ctx.shadowColor = "#FF69B4"; ctx.shadowBlur = glow + 10;
                    ctx.beginPath(); ctx.arc(3, -15, 6, 0, Math.PI * 2); ctx.fill();
                    ctx.shadowBlur = 0; // reset
                    ctx.restore();

                    // Legs with boots
                    let legSwing = isMoving ? Math.sin(time * 0.015) * 15 : 0;
                    ctx.save(); ctx.translate(-6, 22); ctx.rotate(legSwing * Math.PI / 180); ctx.fillStyle = skinColor; ctx.fillRect(-4, 0, 8, 10); ctx.fillStyle = "#FF1493"; ctx.fillRect(-5, 10, 10, 8); ctx.restore(); // Left Leg
                    ctx.save(); ctx.translate(6, 22); ctx.rotate(-legSwing * Math.PI / 180); ctx.fillStyle = skinColor; ctx.fillRect(-4, 0, 8, 10); ctx.fillStyle = "#FF1493"; ctx.fillRect(-5, 10, 10, 8); ctx.restore(); // Right Leg
                }
            },
            {
                name: "Mecha Pilot Plugsuit",
                draw: (ctx, time, isMoving) => {
                    // Sleek sci-fi hair (blue)
                    ctx.fillStyle = "#00FFFF";
                    ctx.beginPath(); ctx.arc(0, -22, 14, Math.PI, Math.PI * 2); ctx.fill();
                    ctx.beginPath(); ctx.moveTo(-14, -22); ctx.lineTo(-18, -5); ctx.lineTo(-8, -15); ctx.fill(); // side bangs

                    // Sci-fi visor
                    ctx.fillStyle = "rgba(255, 0, 0, 0.7)";
                    ctx.fillRect(-12, -20, 24, 8);
                    
                    // Form-fitting white plugsuit with glowing cyan lines
                    ctx.fillStyle = "#E0E0E0";
                    ctx.fillRect(-12, -5, 24, 28);
                    
                    // Glowing accents
                    let glow = Math.abs(Math.sin(time * 0.003)) * 5;
                    ctx.shadowColor = "#00FFFF"; ctx.shadowBlur = glow + 5;
                    ctx.fillStyle = "#00FFFF";
                    ctx.fillRect(-4, -5, 8, 10); // chest triangle
                    ctx.fillRect(-12, 10, 24, 2); // belt line
                    ctx.shadowBlur = 0;

                    // Shoulders
                    ctx.fillStyle = "#333333";
                    ctx.beginPath(); ctx.arc(-14, -2, 6, 0, Math.PI * 2); ctx.fill();
                    ctx.beginPath(); ctx.arc(14, -2, 6, 0, Math.PI * 2); ctx.fill();

                    // Arms
                    let armSwing = isMoving ? Math.sin(time * 0.015) * 15 : 0;
                    ctx.save(); ctx.translate(-14, 0); ctx.rotate(-armSwing * Math.PI / 180); ctx.fillStyle = "#E0E0E0"; ctx.fillRect(-6, 0, 6, 20); ctx.fillStyle = "#333333"; ctx.fillRect(-7, 15, 8, 5); ctx.restore();
                    ctx.save(); ctx.translate(14, 0); ctx.rotate(armSwing * Math.PI / 180); ctx.fillStyle = "#E0E0E0"; ctx.fillRect(0, 0, 6, 20); ctx.fillStyle = "#333333"; ctx.fillRect(-1, 15, 8, 5); ctx.restore();

                    // Legs
                    let legSwing = isMoving ? Math.sin(time * 0.015) * 15 : 0;
                    ctx.save(); ctx.translate(-7, 22); ctx.rotate(legSwing * Math.PI / 180); ctx.fillStyle = "#E0E0E0"; ctx.fillRect(-5, 0, 10, 12); ctx.fillStyle = "#333333"; ctx.fillRect(-6, 12, 12, 8); ctx.restore();
                    ctx.save(); ctx.translate(7, 22); ctx.rotate(-legSwing * Math.PI / 180); ctx.fillStyle = "#E0E0E0"; ctx.fillRect(-5, 0, 10, 12); ctx.fillStyle = "#333333"; ctx.fillRect(-6, 12, 12, 8); ctx.restore();
                }
            },
            {
                name: "School Sailor Fuku",
                draw: (ctx, time, isMoving) => {
                    // Classic dark straight hair
                    ctx.fillStyle = "#111111";
                    ctx.beginPath(); ctx.arc(0, -20, 15, Math.PI, Math.PI * 2); ctx.fill(); // top
                    ctx.fillRect(-15, -20, 30, 20); // back hair
                    ctx.fillRect(-16, -20, 6, 15); // left bang
                    
                    // White shirt
                    ctx.fillStyle = "white";
                    ctx.fillRect(-12, -5, 24, 15);

                    // Navy Sailor Collar
                    ctx.fillStyle = "#000080";
                    ctx.beginPath(); ctx.moveTo(-12, -5); ctx.lineTo(12, -5); ctx.lineTo(0, 8); ctx.fill();
                    // White stripe on collar
                    ctx.strokeStyle = "white"; ctx.lineWidth = 1;
                    ctx.beginPath(); ctx.moveTo(-10, -5); ctx.lineTo(0, 5); ctx.lineTo(10, -5); ctx.stroke();

                    // Red Ribbon
                    ctx.fillStyle = "red";
                    ctx.beginPath(); ctx.moveTo(0, 5); ctx.lineTo(-6, 10); ctx.lineTo(-2, 12); ctx.lineTo(0, 8); ctx.fill();
                    ctx.beginPath(); ctx.moveTo(0, 5); ctx.lineTo(6, 10); ctx.lineTo(2, 12); ctx.lineTo(0, 8); ctx.fill();
                    ctx.beginPath(); ctx.arc(0, 6, 2, 0, Math.PI*2); ctx.fill(); // knot

                    // Pleated Navy Skirt
                    ctx.fillStyle = "#000080";
                    ctx.beginPath(); ctx.moveTo(-10, 10); ctx.lineTo(10, 10); ctx.lineTo(15, 25); ctx.lineTo(-15, 25); ctx.fill();
                    // Pleat lines
                    ctx.strokeStyle = "#000050"; ctx.lineWidth = 1;
                    for(let i=-10; i<=10; i+=5) { ctx.beginPath(); ctx.moveTo(i*0.6, 10); ctx.lineTo(i, 25); ctx.stroke(); }

                    // Arms
                    let armSwing = isMoving ? Math.sin(time * 0.015) * 15 : 0;
                    ctx.save(); ctx.translate(-12, -2); ctx.rotate(-armSwing * Math.PI / 180); ctx.fillStyle = "white"; ctx.fillRect(-6, 0, 6, 8); ctx.fillStyle = skinColor; ctx.fillRect(-5, 8, 4, 10); ctx.restore(); // Left Arm
                    ctx.save(); ctx.translate(12, -2); ctx.rotate(armSwing * Math.PI / 180); ctx.fillStyle = "white"; ctx.fillRect(0, 0, 6, 8); ctx.fillStyle = skinColor; ctx.fillRect(1, 8, 4, 10); ctx.restore(); // Right Arm

                    // Legs with dark socks
                    let legSwing = isMoving ? Math.sin(time * 0.015) * 15 : 0;
                    ctx.save(); ctx.translate(-6, 25); ctx.rotate(legSwing * Math.PI / 180); ctx.fillStyle = skinColor; ctx.fillRect(-4, 0, 6, 5); ctx.fillStyle = "#111"; ctx.fillRect(-4, 5, 6, 10); ctx.fillStyle = "#444"; ctx.fillRect(-5, 13, 8, 4); ctx.restore(); // Left Leg
                    ctx.save(); ctx.translate(6, 25); ctx.rotate(-legSwing * Math.PI / 180); ctx.fillStyle = skinColor; ctx.fillRect(-2, 0, 6, 5); ctx.fillStyle = "#111"; ctx.fillRect(-2, 5, 6, 10); ctx.fillStyle = "#444"; ctx.fillRect(-3, 13, 8, 4); ctx.restore(); // Right Leg
                }
            }
        ];

        // Particles system functions
        function createParticles(x, y, amount, color) {
            for(let i=0; i<amount; i++) {
                particles.push({
                    x: x, y: y,
                    vx: (Math.random() - 0.5) * 400,
                    vy: (Math.random() - 0.5) * 400,
                    life: 1.0,
                    color: color,
                    type: 'basic',
                    size: Math.random() * 3 + 2
                });
            }
        }

        function spawnTrailParticle(x, y, outfitIndex) {
            let p = {
                x: x + (Math.random() - 0.5) * 15,
                y: y + (Math.random() - 0.5) * 15,
                vx: 0,
                vy: 0,
                life: 1.0,
                type: outfitIndex,
                size: Math.random() * 4 + 2,
                rotation: Math.random() * Math.PI * 2
            };
            
            if (outfitIndex === 0) { // Ninja (Smoke)
                p.color = "rgba(160, 160, 160, 0.7)";
                p.vx = (Math.random() - 0.5) * 20;
                p.vy = -Math.random() * 40; 
                p.size = Math.random() * 10 + 5;
            } else if (outfitIndex === 1) { // Magical Girl (Stars)
                p.color = Math.random() > 0.5 ? "#FF69B4" : "#FFD700";
                p.vx = (Math.random() - 0.5) * 60;
                p.vy = (Math.random() - 0.5) * 60;
            } else if (outfitIndex === 2) { // Mecha (Neon squares)
                p.color = "#00FFFF";
                p.size = Math.random() * 6 + 3;
                p.vx = (Math.random() - 0.5) * 10;
                p.vy = (Math.random() - 0.5) * 10;
            } else if (outfitIndex === 3) { // Sailor (Cherry Blossoms)
                p.color = "#FFB7C5";
                p.vx = 60 + Math.random() * 40; // Blows away with the wind
                p.vy = 30 + Math.random() * 30;
                p.rotSpeed = (Math.random() - 0.5) * 5;
            }
            particles.push(p);
        }

        // Assign random initial outfit
        function setRandomOutfit() {
            let nextIndex = Math.floor(Math.random() * outfits.length);
            if (nextIndex === player.currentOutfitIndex && outfits.length > 1) {
                nextIndex = (nextIndex + 1) % outfits.length;
            }
            player.currentOutfitIndex = nextIndex;
            outfitNameDisplay.textContent = outfits[player.currentOutfitIndex].name;
            
            // Pop effect
            outfitNameDisplay.style.transform = 'scale(1.5)';
            setTimeout(() => outfitNameDisplay.style.transform = 'scale(1)', 200);
            
            createParticles(player.x, player.y, 20, "#FFF");
        }
        setRandomOutfit(); // Now safe to call since particles is already defined
        rerollBtn.addEventListener('click', setRandomOutfit);

        // Input listeners
        window.addEventListener('keydown', (e) => { if (keys.hasOwnProperty(e.key)) keys[e.key] = true; });
        window.addEventListener('keyup', (e) => { if (keys.hasOwnProperty(e.key)) keys[e.key] = false; });
        
        // Touch/Mouse for movement
        canvas.addEventListener('mousedown', (e) => touchTarget = { x: e.clientX, y: e.clientY });
        canvas.addEventListener('mousemove', (e) => { if (touchTarget) touchTarget = { x: e.clientX, y: e.clientY }; });
        window.addEventListener('mouseup', () => touchTarget = null);
        
        canvas.addEventListener('touchstart', (e) => touchTarget = { x: e.touches[0].clientX, y: e.touches[0].clientY }, {passive: false});
        canvas.addEventListener('touchmove', (e) => { touchTarget = { x: e.touches[0].clientX, y: e.touches[0].clientY }; e.preventDefault(); }, {passive: false});
        window.addEventListener('touchend', () => touchTarget = null);

        function update(dt) {
            // Movement logic
            let dx = 0, dy = 0;

            if (keys.w || keys.ArrowUp) dy -= 1;
            if (keys.s || keys.ArrowDown) dy += 1;
            if (keys.a || keys.ArrowLeft) dx -= 1;
            if (keys.d || keys.ArrowRight) dx += 1;

            if (touchTarget) {
                const tx = touchTarget.x - player.x;
                const ty = touchTarget.y - player.y;
                const dist = Math.sqrt(tx*tx + ty*ty);
                if (dist > 10) {
                    dx = tx / dist;
                    dy = ty / dist;
                }
            }

            // Normalize diagonal speed
            if (dx !== 0 && dy !== 0) {
                const length = Math.sqrt(dx*dx + dy*dy);
                dx /= length;
                dy /= length;
            }

            player.x += dx * player.speed * dt;
            player.y += dy * player.speed * dt;
            player.isMoving = (dx !== 0 || dy !== 0);

            if (dx > 0) player.facingRight = true;
            if (dx < 0) player.facingRight = false;

            // Spawn movement trail based on outfit
            if (player.isMoving) {
                player.trailTimer -= dt;
                if (player.trailTimer <= 0) {
                    spawnTrailParticle(player.x, player.y + 10, player.currentOutfitIndex);
                    player.trailTimer = 0.04; // Spawn rate
                }
            }

            // Boundaries
            player.x = Math.max(30, Math.min(width - 30, player.x));
            player.y = Math.max(50, Math.min(height - 30, player.y));

            // Collectibles logic
            for (let i = collectibles.length - 1; i >= 0; i--) {
                let c = collectibles[i];
                let dist = Math.sqrt((player.x - c.x)**2 + (player.y - c.y)**2);
                if (dist < 35) { // Collision radius
                    score += 10;
                    scoreDisplay.textContent = score;
                    scoreDisplay.classList.add('text-green-400', 'scale-125');
                    setTimeout(() => scoreDisplay.classList.remove('text-green-400', 'scale-125'), 200);
                    
                    createParticles(c.x, c.y, 15, "#00FFFF");
                    collectibles.splice(i, 1);
                    spawnCollectible();
                }
            }

            // Particles logic
            for (let i = particles.length - 1; i >= 0; i--) {
                let p = particles[i];
                p.x += p.vx * dt;
                p.y += p.vy * dt;
                if (p.type === 3) p.rotation += p.rotSpeed * dt; // Rotate petals
                if (p.type === 0) p.size += dt * 15; // Smoke expands
                p.life -= dt * (p.type === 'basic' ? 1.5 : 1.0); // Trails last a bit longer
                if (p.life <= 0) particles.splice(i, 1);
            }
        }

        // --- DRAWING THE CHARACTER ---
        function drawBaseCharacter(ctx, x, y, time, isMoving, outfitIndex, facingRight) {
            ctx.save();
            ctx.translate(x, y);

            // Add a little walking bounce to the entire body
            let bounce = isMoving ? Math.abs(Math.sin(time * 0.015)) * -4 : 0;
            ctx.translate(0, bounce);

            if (!facingRight) {
                ctx.scale(-1, 1); // Flip horizontally
            }

            // Draw Base Head & Neck (drawn underneath outfits)
            ctx.fillStyle = skinColor;
            ctx.beginPath(); ctx.arc(0, -18, 12, 0, Math.PI * 2); ctx.fill(); // Head
            ctx.fillRect(-4, -8, 8, 6); // Neck

            // Eyes (simple anime dots/lines)
            ctx.fillStyle = "#111";
            ctx.beginPath(); ctx.ellipse(4, -20, 2, 4, 0, 0, Math.PI * 2); ctx.fill(); // Right eye
            if (facingRight) {
                ctx.beginPath(); ctx.ellipse(-4, -20, 2, 4, 0, 0, Math.PI * 2); ctx.fill(); // Left eye (only draw both if facing right-ish, else side profile cheat)
            }
            
            // Draw the selected outfit (Outfit handles clothes, hair, accessories, and limbs)
            outfits[outfitIndex].draw(ctx, time, isMoving);

            ctx.restore();
        }

        function draw(time) {
            // Clear screen with stylized gradient background
            const bgGrad = ctx.createRadialGradient(width/2, height/2, 0, width/2, height/2, Math.max(width, height));
            bgGrad.addColorStop(0, "#1e1b4b"); // Tailwind indigo-950
            bgGrad.addColorStop(1, "#020617"); // Tailwind slate-950
            ctx.fillStyle = bgGrad;
            ctx.fillRect(0, 0, width, height);

            // Draw beautiful glowing arena floor
            ctx.save();
            ctx.translate(width/2, height/2);
            
            // Inner grid lines - perspective effect! (fake 3D)
            ctx.shadowBlur = 0;
            ctx.strokeStyle = "rgba(99, 102, 241, 0.15)";
            ctx.lineWidth = 2;
            ctx.beginPath();
            
            // Draw concentric rings
            for (let r = 50; r < Math.max(width, height); r += 80) {
                ctx.arc(0, 0, r, 0, Math.PI * 2);
            }
            
            // Draw radial lines
            for (let a = 0; a < Math.PI * 2; a += Math.PI / 8) {
                ctx.moveTo(0, 0);
                // Extend past screen
                ctx.lineTo(Math.cos(a) * Math.max(width, height), Math.sin(a) * Math.max(width, height));
            }
            ctx.stroke();

            // Center glowing emblem
            ctx.shadowColor = "#6366f1";
            ctx.shadowBlur = 30;
            ctx.strokeStyle = "rgba(167, 139, 250, 0.6)"; // purple-400
            ctx.lineWidth = 4;
            ctx.beginPath();
            ctx.arc(0, 0, 100, 0, Math.PI * 2);
            ctx.stroke();
            ctx.beginPath();
            ctx.arc(0, 0, 120, 0, Math.PI * 2);
            ctx.stroke();

            ctx.restore();

            // Draw Collectibles
            collectibles.forEach(c => {
                c.baseY = Math.sin((time + c.timeOffset) * 0.005) * 5; // Hover effect
                
                ctx.save();
                ctx.translate(c.x, c.y + c.baseY);
                
                // Glow
                let pulse = (Math.sin(time * 0.005) + 1) * 0.5;
                ctx.shadowColor = "#00FFFF";
                ctx.shadowBlur = 10 + pulse * 10;
                
                // Orb
                ctx.fillStyle = "#E0FFFF";
                ctx.beginPath();
                ctx.arc(0, 0, c.radius, 0, Math.PI * 2);
                ctx.fill();
                
                // Inner core
                ctx.fillStyle = "white";
                ctx.shadowBlur = 0;
                ctx.beginPath();
                ctx.arc(2, -2, c.radius * 0.4, 0, Math.PI * 2);
                ctx.fill();

                ctx.restore();
            });

            // Draw Particles
            particles.forEach(p => {
                ctx.globalAlpha = Math.max(0, p.life);
                ctx.fillStyle = p.color;
                
                ctx.save();
                ctx.translate(p.x, p.y);
                
                if (p.type === 1) {
                    // Draw Star for Magical Girl
                    ctx.beginPath();
                    for (let i = 0; i < 5; i++) {
                        ctx.lineTo(Math.cos((18 + i * 72) * Math.PI / 180) * p.size, -Math.sin((18 + i * 72) * Math.PI / 180) * p.size);
                        ctx.lineTo(Math.cos((54 + i * 72) * Math.PI / 180) * (p.size * 0.4), -Math.sin((54 + i * 72) * Math.PI / 180) * (p.size * 0.4));
                    }
                    ctx.closePath();
                    ctx.fill();
                } else if (p.type === 2) {
                    // Draw Neon Square for Mecha
                    ctx.shadowColor = p.color;
                    ctx.shadowBlur = 5;
                    ctx.fillRect(-p.size/2, -p.size/2, p.size, p.size);
                } else if (p.type === 3) {
                    // Draw Petal for Sailor
                    ctx.rotate(p.rotation);
                    ctx.beginPath();
                    ctx.ellipse(0, 0, p.size, p.size / 2, 0, 0, Math.PI * 2);
                    ctx.fill();
                } else {
                    // Basic / Smoke (Circles)
                    ctx.beginPath();
                    ctx.arc(0, 0, p.size || 3, 0, Math.PI * 2);
                    ctx.fill();
                }
                ctx.restore();
            });
            ctx.globalAlpha = 1.0;

            // Draw Character Procedurally
            // We use shadow for character presence
            ctx.fillStyle = "rgba(0,0,0,0.3)";
            ctx.beginPath();
            ctx.ellipse(player.x, player.y + 35, 15, 6, 0, 0, Math.PI*2);
            ctx.fill();

            drawBaseCharacter(ctx, player.x, player.y, time, player.isMoving, player.currentOutfitIndex, player.facingRight);
        }

        function loop(time) {
            let dt = (time - lastTime) / 1000;
            lastTime = time;
            
            // cap dt to prevent big jumps if tab is inactive
            if (dt > 0.1) dt = 0.1;

            update(dt);
            draw(time);
            
            requestAnimationFrame(loop);
        }

        // Start loop
        requestAnimationFrame((time) => {
            lastTime = time;
            loop(time);
        });

    </script>
</body>
</html>
