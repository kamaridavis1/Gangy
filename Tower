    // --- ENEMY GENERATOR ---
    function generateEnemy(floor) {
        const prefixes = ["ROGUE", "CURSED", "ELITE", "CORRUPTED", "DEMON", "SHADOW", "COSMIC", "FALLEN", "AWAKENED", "HAKAI"];
        const archetypes = ["SHINOBI", "SPIRIT", "SAIYAN", "PIRATE", "HOLLOW", "STAND USER", "HASHIRA", "VILLAIN", "ESPER", "DRAGON"];
        let name = prefixes[Math.floor(Math.random()*prefixes.length)] + " " + archetypes[Math.floor(Math.random()*archetypes.length)];
        
        let hpScale = 80 + (floor * 50); let atkScale = 15 + (floor * 10);
        let isBoss = (floor % 5 === 0);
        if (isBoss) { name = "BOSS: " + name; hpScale *= 1.8; atkScale *= 1.3; }

        let pColor = ['#ef4444', '#3b82f6', '#10b981', '#a855f7', '#f59e0b', '#ec4899', '#ffffff'][Math.floor(Math.random()*7)];
        
        return {
            name: name, level: floor, maxHp: Math.floor(hpScale), hp: Math.floor(hpScale), atk: Math.floor(atkScale),
            sprite: spr_enemies[Math.floor(Math.random() * spr_enemies.length)], color: pColor, 
            eMove: ["SLICING WAVE", "ENERGY BLAST", "BRUTAL STRIKE", "DARK ORB", "METEOR CRASH"][Math.floor(Math.random()*5)],
            intro: `Floor ${floor} Guardian appears!`,
            domain: (isBoss || Math.random() < (floor * 0.05)) ? { name: "MALEVOLENT SHRINE", color1: "#450a0a", color2: "#000" } : null,
            ultimate: { name: "DEATH BLOW", used: false }
        };
    }

    // --- RENDERING & CRAZY EFFECTS ---
    function triggerScreenShatter() {
        // Flashbang
        let flash = document.getElementById('flash-overlay');
        flash.classList.remove('super-flash');
        void flash.offsetWidth; // trigger reflow
        flash.classList.add('super-flash');

        // Intense Shake & Inversion
        let wrapper = document.getElementById('game-wrapper');
        wrapper.classList.add('shatter-shake');
        setTimeout(() => wrapper.classList.remove('shatter-shake'), 1200);

        // Exploding Shards
        glassShards = [];
        let cx = 450; let cy = 300; 
        for(let i=0; i<80; i++) { // Double shards
            let angle = Math.random() * Math.PI * 2;
            let speed = 10 + Math.random() * 30; // Faster
            let points = []; let numPts = 3 + Math.floor(Math.random()*5);
            for(let p=0; p<numPts; p++) points.push({ x: (Math.random()-0.5)*120, y: (Math.random()-0.5)*120 });
            glassShards.push({
                x: cx + (Math.random()-0.5)*50, y: cy + (Math.random()-0.5)*50,
                vx: Math.cos(angle)*speed, vy: Math.sin(angle)*speed,
                rot: Math.random()*Math.PI*2, vrot: (Math.random()-0.5)*1.5,
                points: points, life: 80
            });
        }
    }

    function emitParticles(x, y, color, count, speed=2, life=30) {
        for(let i=0; i<count; i++) particles.push({ x, y, vx: (Math.random()-0.5)*speed*2, vy: (Math.random()-0.5)*speed*2, color, life: life + Math.random()*15, maxLife: life });
    }
    function createShockwave(x, y, color, speed=5, width=3) {
        shockwaves.push({ x, y, radius: 1, maxRadius: 200, color, speed, width, life: 1.0 });
    }

    function updateParticles() {
        for(let i = particles.length-1; i>=0; i--) {
            let p = particles[i]; p.x += p.vx; p.y += p.vy; p.life--;
            if (p.life <= 0) particles.splice(i, 1);
        }
        for(let i = shockwaves.length-1; i>=0; i--) {
            let s = shockwaves[i]; s.radius += s.speed; s.life -= 0.05;
            if (s.life <= 0 || s.radius >= s.maxRadius) shockwaves.splice(i, 1);
        }
    }

    function darkenColor(hex, factor) {
        if(!hex || hex === 'none') return '#000';
        let r = parseInt(hex.slice(1,3), 16) * factor; let g = parseInt(hex.slice(3,5), 16) * factor; let b = parseInt(hex.slice(5,7), 16) * factor;
        return `rgb(${Math.floor(r)},${Math.floor(g)},${Math.floor(b)})`;
    }

    function drawSprite(arr, x, y, scale=4, flash=false, isTransformed=false, overrideColor=null) {
        if (!arr) return;
        ctx.fillStyle = 'rgba(0,0,0,0.4)';
        for(let r=0; r<16; r++) for(let c=0; c<16; c++) if(arr[r][c] !== '0') ctx.fillRect(x + c*scale + scale, y + r*scale + scale*2, scale, scale);
        
        if (isTransformed) { ctx.shadowColor = '#eab308'; ctx.shadowBlur = 15; }
        for (let r=0; r<16; r++) {
            for (let c=0; c<16; c++) {
                let ch = arr[r][c];
                if (ch !== '0') {
                    let fill = flash ? '#ffffff' : colors[ch];
                    if (ch === '2' && overrideColor) fill = overrideColor; // Color base skin/clothes
                    if (!flash && r > 9 && ch !== '1') fill = darkenColor(fill, 0.6);
                    ctx.fillStyle = fill; ctx.fillRect(x + c*scale, y + r*scale, scale, scale);
                }
            }
        }
        ctx.shadowBlur = 0;
    }

    function renderGame() {
        ctx.clearRect(0, 0, 240, 160);
        let camX = 0, camY = 0;
        if (animState === "SHAKE") { camX = (Math.random() - 0.5) * 12; camY = (Math.random() - 0.5) * 12; }
        ctx.save(); ctx.translate(camX, camY);

        // BG
        if (activeDomain) {
            let grad = ctx.createRadialGradient(120, 80, 10, 120, 80, 150 + Math.sin(frameCount*0.05)*20);
            grad.addColorStop(0, activeDomain.color1); grad.addColorStop(1, activeDomain.color2);
            ctx.fillStyle = grad; ctx.fillRect(0,0,240,160);
            if (frameCount%3===0) emitParticles(Math.random()*240, 160, '#ffffff', 2, 0.8, 60);
        } else {
            let skyGrad = ctx.createLinearGradient(0,0,0,100);
            skyGrad.addColorStop(0, '#1e1b4b'); skyGrad.addColorStop(1, '#4c1d95'); // Night sky vibe
            ctx.fillStyle = skyGrad; ctx.fillRect(0, 0, 240, 100);
            let floorGrad = ctx.createLinearGradient(0,100,0,160);
            floorGrad.addColorStop(0, '#312e81'); floorGrad.addColorStop(1, '#1e1b4b');
            ctx.fillStyle = floorGrad; ctx.fillRect(0, 100, 240, 60);
            ctx.fillStyle = 'rgba(0,0,0,0.4)';
            ctx.beginPath(); ctx.ellipse(180, 75, 45, 12, 0, 0, Math.PI*2); ctx.fill();
            ctx.beginPath(); ctx.ellipse(60, 145, 50, 15, 0, 0, Math.PI*2); ctx.fill();
        }

        // Sprites
        if (eVis && currentEnemy) drawSprite(currentEnemy.sprite, ePos.x + eOff.x, ePos.y + eOff.y, 4, eFlash, false, currentEnemy.color);
        let pSprite = player.transformed ? spr_awaken : spr_base;
        if (pVis) drawSprite(pSprite, pPos.x + pOff.x, pPos.y + pOff.y, 4, pFlash, player.transformed, player.color);

        // Shockwaves
        shockwaves.forEach(s => {
            ctx.beginPath(); ctx.arc(s.x, s.y, s.radius, 0, Math.PI*2);
            ctx.strokeStyle = `rgba(${parseInt(s.color.slice(1,3),16)},${parseInt(s.color.slice(3,5),16)},${parseInt(s.color.slice(5,7),16)},${s.life})`;
            ctx.lineWidth = s.width; ctx.stroke();
        });

        // Particles
        particles.forEach(p => { ctx.fillStyle = p.color; let size = Math.max(1, (p.life/p.maxLife) * 4); ctx.fillRect(p.x, p.y, size, size); });

        // Anim Specific Drawing
        if (animState === "BEAM") {
            ctx.fillStyle = animData.color; ctx.fillRect(animData.x, animData.y, animData.w, animData.h);
            ctx.fillStyle = '#fff'; ctx.fillRect(animData.x, animData.y + animData.h/4, animData.w, animData.h/2);
            emitParticles(animData.x + (animData.w > 0 ? animData.w : 0), animData.y + animData.h/2, animData.color, 5, 8, 20);
        } else if (animState === "SLASH") {
            ctx.strokeStyle = '#fff'; ctx.lineWidth = animData.w;
            ctx.beginPath(); ctx.moveTo(animData.x1, animData.y1); ctx.lineTo(animData.x2, animData.y2); ctx.stroke();
            ctx.strokeStyle = animData.color; ctx.lineWidth = animData.w/2;
            ctx.beginPath(); ctx.moveTo(animData.x1, animData.y1); ctx.lineTo(animData.x2, animData.y2); ctx.stroke();
        } else if (animState === "GLITCH") {
            for(let i=0; i<10; i++) {
                ctx.fillStyle = ['#f00', '#0f0', '#00f', '#fff'][Math.floor(Math.random()*4)];
                ctx.fillRect(Math.random()*240, Math.random()*160, Math.random()*40, Math.random()*10);
            }
        }

        ctx.restore();

        // Shatter Canvas Rendering
        sCtx.clearRect(0,0,900,600);
        if (glassShards.length > 0) {
            for(let i = glassShards.length-1; i>=0; i--) {
                let s = glassShards[i];
                s.x += s.vx; s.y += s.vy; s.rot += s.vrot; s.life--;
                
                sCtx.save(); sCtx.translate(s.x, s.y); sCtx.rotate(s.rot);
                sCtx.beginPath(); sCtx.moveTo(s.points[0].x, s.points[0].y);
                for(let j=1; j<s.points.length; j++) sCtx.lineTo(s.points[j].x, s.points[j].y);
                sCtx.closePath();
                
                sCtx.fillStyle = `rgba(255, 255, 255, ${s.life/80})`; sCtx.fill(); 
                sCtx.strokeStyle = `rgba(100, 200, 255, ${(s.life/80)*0.8})`; sCtx.lineWidth = 3; sCtx.stroke();
                sCtx.restore();

                if (s.life <= 0) glassShards.splice(i, 1);
            }
        }
    }

