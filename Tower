<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>GANGY TOWER - ANIME DELUXE</title>
    <link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap" rel="stylesheet">
    <style>
        :root {
            --ui-bg: rgba(10, 10, 20, 0.95);
            --ui-border: #6366f1;
            --text-main: #f8f8f8;
            --hp-green: #22c55e;
            --hp-red: #ef4444;
            --mp-blue: #3b82f6;
            --domain-purple: #a855f7;
            --gold: #facc15;
            --bg-color: #000;
        }

        * { box-sizing: border-box; }
        
        body, html {
            margin: 0; padding: 0; width: 100%; height: 100%;
            background-color: var(--bg-color);
            font-family: 'Press Start 2P', monospace;
            color: var(--text-main);
            user-select: none; touch-action: none;
            overflow: hidden;
            display: flex; justify-content: center; align-items: center;
        }

        #game-container {
            position: relative; width: 100%; max-width: 800px; height: 100%; max-height: 600px;
            background: #111; box-shadow: 0 0 30px rgba(99, 102, 241, 0.2); overflow: hidden; border: 2px solid #333;
        }

        canvas { display: block; width: 100%; height: 100%; image-rendering: pixelated; }

        .screen { position: absolute; top: 0; left: 0; width: 100%; height: 100%; display: flex; flex-direction: column; pointer-events: none; transition: opacity 0.3s ease; z-index: 10; }
        .screen > * { pointer-events: auto; }
        .hidden { opacity: 0; pointer-events: none !important; display: none !important; }

        #crt-overlay {
            position: absolute; top: 0; left: 0; width: 100%; height: 100%;
            background: linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.25) 50%), linear-gradient(90deg, rgba(255, 0, 0, 0.06), rgba(0, 255, 0, 0.02), rgba(0, 0, 255, 0.06));
            background-size: 100% 4px, 6px 100%; pointer-events: none; z-index: 999; opacity: 0.8; mix-blend-mode: overlay;
        }

        .menu-bg { background: linear-gradient(to bottom, #0f172a, #000); justify-content: center; align-items: center; }
        .title-text { font-size: 32px; color: var(--gold); text-shadow: 4px 4px 0px #4338ca, -2px -2px 0px #fff; line-height: 1.5; animation: float 3s infinite ease-in-out; text-align: center;}
        .title-sub { font-size: 12px; color: #ec4899; text-shadow: 2px 2px 0px #000; letter-spacing: 2px; text-align: center; margin-bottom: 10px; }
        .credits-text { font-size: 10px; color: #94a3b8; text-align: center; margin-bottom: 10px; letter-spacing: 1px; }

        @keyframes float { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-10px); } }

        .btn {
            background: rgba(0,0,0,0.8); color: var(--text-main); border: 2px solid var(--text-main);
            padding: 15px 20px; margin: 10px; font-family: inherit; font-size: 12px; cursor: pointer;
            text-transform: uppercase; transition: all 0.1s; box-shadow: 4px 4px 0px rgba(255,255,255,0.2); width: 80%; max-width: 350px; text-align: center;
        }
        .btn:hover:not(:disabled) { background: var(--text-main); color: #000; transform: translate(-2px, -2px); box-shadow: 6px 6px 0px var(--ui-border); }
        .btn:disabled { border-color: #555; color: #555; cursor: not-allowed; box-shadow: none; }

        .menu-panel { background: var(--ui-bg); border: 4px solid var(--ui-border); padding: 20px; width: 90%; max-width: 550px; text-align: center; font-size: 10px; box-shadow: inset 0 0 20px rgba(0,0,0,0.8); max-height: 90%; overflow-y: auto; margin: auto;}
        .highlight { color: var(--gold); } 

        .hud-top { position: absolute; top: 0; left: 0; width: 100%; display: flex; justify-content: space-between; padding: 10px; margin-top: 15px; }
        .health-box { background: var(--ui-bg); border: 2px solid #fff; padding: 8px; width: 45%; max-width: 280px; box-shadow: 4px 4px 0 #000; }
        .health-box.boss { border-color: #ef4444; box-shadow: 4px 4px 0 #7f1d1d; background: rgba(50, 0, 0, 0.9); }
        .name-row { display: flex; justify-content: space-between; font-size: 10px; margin-bottom: 4px; }
        
        .bar-bg { width: 100%; height: 10px; background: #222; border: 1px solid #000; position: relative; overflow: hidden; margin-bottom: 2px;}
        .bar-fill { height: 100%; transition: width 0.2s ease-out; background: linear-gradient(to bottom, #4ade80, #16a34a); }
        .bar-fill.low { background: linear-gradient(to bottom, #f87171, #dc2626); }
        
        .mp-bar-bg { width: 100%; height: 6px; background: #222; border: 1px solid #000; position: relative; overflow: hidden; }
        .mp-bar-fill { height: 100%; transition: width 0.2s; background: linear-gradient(to bottom, #60a5fa, #2563eb); }
        .mp-text { font-size: 8px; color: var(--mp-blue); }

        .tower-info { position: absolute; top: 5px; left: 50%; transform: translateX(-50%); text-align: center; font-size: 10px; color: var(--gold); text-shadow: 2px 2px 0 #000; display: flex; flex-direction: column; gap: 4px; }
        
        #speedrun-ui { position: absolute; top: 5px; left: 10px; font-size: 10px; color: #fff; text-shadow: 1px 1px 0 #000; z-index: 100; display: none;}
        #floor-timer-ui { position: absolute; top: 5px; right: 10px; font-size: 14px; color: var(--hp-red); text-shadow: 2px 2px 0 #000; z-index: 100; animation: pulse 1s infinite alternate;}

        .hud-bottom { position: absolute; bottom: 0; left: 0; width: 100%; display: flex; flex-direction: column; }
        .dialogue-box { background: var(--ui-bg); border-top: 4px solid var(--ui-border); padding: 15px; min-height: 80px; font-size: 12px; line-height: 1.8; display: flex; align-items: center; justify-content: center; text-align: center; cursor: pointer; box-shadow: 0 -5px 20px rgba(0,0,0,0.5); }
        .blink { animation: blink 1s infinite; color: var(--gold); font-size: 10px; vertical-align: middle; margin-left: 5px; }
        @keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0; } }
        @keyframes pulse { 0% { opacity: 0.8; transform: scale(1); } 100% { opacity: 1; transform: scale(1.05); } }

        .menu-grid-2x2 { display: grid; grid-template-columns: 1fr 1fr; background: #000; border-top: 2px solid #333; }
        .menu-grid-list { display: grid; grid-template-columns: 1fr; background: #000; border-top: 2px solid #333; max-height: 140px; overflow-y: auto;}
        .action-btn { background: #111; color: #fff; border: 1px solid #333; padding: 15px 5px; font-family: inherit; font-size: 10px; cursor: pointer; transition: background 0.2s; text-transform: uppercase; }
        .action-btn:hover:not(:disabled) { background: #222; border-color: #fff; z-index: 2; }
        .action-btn:disabled { filter: grayscale(1); opacity: 0.6; cursor: not-allowed; }
        
        .domain-container { width: 100%; background: #111; padding: 4px 10px; border-top: 2px solid #333; display: flex; align-items: center; gap: 10px; }
        .domain-bar-bg { flex: 1; height: 8px; background: #000; border: 1px solid #333; overflow: hidden; }
        .domain-bar-fill { height: 100%; background: linear-gradient(90deg, #7e22ce, #d946ef); width: 0%; transition: width 0.3s ease; }
        .domain-bar-fill.full { animation: domainGlow 1s infinite alternate; }
        @keyframes domainGlow { from { box-shadow: 0 0 5px var(--domain-purple); background: #d946ef; } to { box-shadow: 0 0 15px #f0abfc; background: #fdf4ff; } }

        .special-actions { display: flex; width: 100%; border-top: 2px solid #333; }
        .special-actions button { flex: 1; font-size: 9px; padding: 12px 5px; border: none; border-right: 1px solid #333; background: #0a0a0a; color: #fff; cursor: pointer; text-transform: uppercase;}
        .special-actions button:hover:not(:disabled) { background: #1a1a1a; }

        #qte-ui { position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 9999; display: flex; flex-direction: column; justify-content: center; align-items: center; background: rgba(0,0,0,0.4); }
        .qte-box { background: rgba(0,0,0,0.8); border: 6px solid var(--hp-red); padding: 30px 50px; border-radius: 10px; text-align: center; animation: pulseQTE 0.2s infinite alternate; cursor: pointer;}
        .qte-key { font-size: 64px; color: #fff; text-shadow: 0 0 20px #ef4444, 4px 4px 0 #000; }
        .qte-label { font-size: 14px; color: var(--hp-red); margin-top: 10px; letter-spacing: 2px; }
        @keyframes pulseQTE { from { transform: scale(1); box-shadow: 0 0 20px #ef4444; } to { transform: scale(1.1); box-shadow: 0 0 50px #ef4444; } }

        .draft-grid { display: grid; grid-template-columns: 1fr; gap: 10px; margin-top: 20px; }
        .draft-card { background: #111; border: 2px solid #444; padding: 15px; cursor: pointer; text-align: left; transition: 0.2s; position: relative; }
        .draft-card:hover { border-color: var(--gold); background: #222; transform: scale(1.02); }
        .draft-title { font-size: 12px; margin-bottom: 8px; color: #fff; text-transform: uppercase;}
        .draft-desc { font-size: 9px; color: #aaa; line-height: 1.4; }
        .draft-type { position: absolute; top: 10px; right: 10px; font-size: 8px; opacity: 0.7; }

        .roster-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-top: 15px; }
        .roster-card { background: rgba(0,0,0,0.6); border: 2px solid #555; padding: 10px; cursor: pointer; text-align: left; transition: 0.2s; }
        .roster-card:hover:not(.dead) { border-color: var(--text-main); transform: scale(1.02); }
        .roster-card.active { border-color: var(--gold); background: rgba(250, 204, 21, 0.1); }
        .roster-card.dead { opacity: 0.4; cursor: not-allowed; border-color: #f87171; background: rgba(255,0,0,0.1); }
        .roster-name { font-size: 10px; margin-bottom: 5px; color: #fff; }

        .settings-box { margin-bottom: 20px; padding: 10px; border: 1px dashed #555; font-size: 10px; }
        .settings-box label { display: flex; align-items: center; justify-content: center; cursor: pointer; color: #fff;}
        .settings-box input { margin-right: 10px; cursor: pointer; width: 16px; height: 16px; accent-color: var(--gold); }

        @media (max-width: 600px) {
            .title-text { font-size: 24px; }
            .health-box { width: 48%; padding: 6px; }
            .name-row { font-size: 8px; }
            .mp-text { font-size: 6px; }
            .dialogue-box { font-size: 10px; min-height: 70px; padding: 10px; }
            .action-btn { font-size: 8px; padding: 12px 2px; }
            .draft-grid { grid-template-columns: 1fr; }
            #floor-timer-ui { font-size: 12px; }
        }
    </style>
</head>
<body>

<div id="game-container">
    <canvas id="game-canvas" width="600" height="400"></canvas>
    <div id="crt-overlay"></div>

    <div id="speedrun-ui">00:00.00</div>
    <div id="floor-timer-ui" class="hidden">100.0s</div>

    <!-- MAIN MENU -->
    <div id="screen-menu" class="screen menu-bg">
        <div class="title-text">GANGY TOWER</div>
        <div class="title-sub">ANIME DELUXE</div>
        <div class="credits-text">MADE BY KAMARI DAVIS</div>
        <div class="settings-box">
            <label><input type="checkbox" id="speedrun-toggle"> ENABLE SPEEDRUN TIMER</label>
        </div>
        <button class="btn" onclick="initGameData()">ENTER TOWER</button>
    </div>

    <!-- LEAD SELECT -->
    <div id="screen-lead-select" class="screen menu-bg hidden">
        <div class="menu-panel">
            <h2 style="color: var(--gold); margin-top:0; font-size: 14px;">SELECT LEAD FIGHTER</h2>
            <div id="lead-grid" class="roster-grid"></div>
        </div>
    </div>

    <!-- SWAP MENU -->
    <div id="screen-swap" class="screen menu-bg hidden" style="background: rgba(0,0,0,0.9);">
        <div class="menu-panel" style="border-color: #3b82f6;">
            <h2 style="color: #60a5fa; margin-top:0; font-size: 14px;">PARTY ROSTER</h2>
            <div id="swap-grid" class="roster-grid"></div>
            <button class="btn" id="btn-cancel-swap" style="margin-top: 15px; border-color: #ef4444; color: #ef4444;" onclick="cancelSwap()">CANCEL</button>
        </div>
    </div>

    <!-- ABILITY DRAFT -->
    <div id="screen-draft" class="screen menu-bg hidden">
        <div class="menu-panel">
            <h2 style="color: var(--domain-purple); margin-top:0;">LEVEL UP!</h2>
            <p style="color: #ccc; margin-bottom: 15px;">Select a new ability for <span id="draft-char-name"></span></p>
            <div id="draft-grid" class="draft-grid"></div>
        </div>
    </div>

    <!-- SHOP -->
    <div id="screen-shop" class="screen menu-bg hidden">
        <div class="menu-panel">
            <h2 style="color: var(--gold); margin-top:0;">REST AREA</h2>
            <div style="font-size: 12px; margin: 10px 0;">GOLD: <span id="shop-gold" class="highlight">0</span></div>
            <div style="font-size: 10px; color: #aaa; margin-bottom: 15px;">Active: <span id="shop-active-name" style="color: #fff; transition: 0.3s"></span> | Potions: <span id="shop-potions" style="color: var(--hp-green);">0</span></div>
            
            <button class="btn" style="width:100%; margin:5px 0" onclick="buyItem('potion')">BUY POTION <span class="highlight">50g</span></button>
            <button class="btn" style="width:100%; margin:5px 0" id="buy-revive" onclick="buyItem('revive')">REVIVE MATE <span class="highlight">200g</span></button>
            <button class="btn" style="width:100%; margin:5px 0" onclick="buyItem('atk')">ATK +15 <span class="highlight">150g</span></button>
            
            <button class="btn" style="width:100%; margin:5px 0; border-color: #ec4899; color: #ec4899;" onclick="buyRandomizer()">RANDOMIZE LOADOUT <span class="highlight">100g</span></button>
            
            <button class="btn" style="margin-top: 20px; border-color: #3b82f6; color: #3b82f6;" onclick="openSwapMenu(false)">SWAP ACTIVE</button>
            <button class="btn" style="margin-top: 10px; border-color: #ef4444; color: #ef4444;" onclick="nextFloor()">ASCEND TOWER</button>
        </div>
    </div>

    <!-- GAME OVER -->
    <div id="screen-end" class="screen menu-bg hidden" style="background: rgba(0,0,0,0.95);">
        <div class="title-text" id="end-title" style="color: var(--hp-red);">PARTY WIPED</div>
        <div class="menu-panel" style="background: transparent; border: none; box-shadow: none;">
            <p style="font-size: 14px; margin-bottom: 30px;">Floor Reached: <span id="end-floor">1</span><br><br><span id="end-time" style="font-size:10px; color:#aaa;"></span></p>
            <button class="btn" onclick="location.reload()">RETURN TO TITLE</button>
        </div>
    </div>

    <!-- QTE OVERLAY -->
    <div id="qte-ui" class="hidden">
        <div class="qte-box" id="qte-box">
            <div class="qte-key" id="qte-key">W</div>
            <div class="qte-label">TAP TO PARRY!</div>
        </div>
    </div>

    <!-- BATTLE UI -->
    <div id="screen-battle" class="screen hidden">
        <div class="tower-info">
            <span>FLOOR <span id="hud-floor">1</span> | GOLD: <span id="hud-gold">0</span></span>
            <span style="font-size: 8px; color: #aaa;">PARTY: <span id="hud-party-count">10/10</span> ALIVE</span>
        </div>
        
        <div class="hud-top">
            <div class="health-box">
                <div class="name-row">
                    <span id="p-name" style="color: #60a5fa;">PLAYER</span>
                    <div><span id="p-hp-text">100/100</span> <span id="p-mp-text" class="mp-text">EN:100</span></div>
                </div>
                <div class="bar-bg"><div id="p-hp-bar" class="bar-fill" style="width: 100%;"></div></div>
                <div class="mp-bar-bg"><div id="p-mp-bar" class="mp-bar-fill" style="width: 100%;"></div></div>
            </div>
            
            <div class="health-box" id="e-health-box" style="text-align: right; border-color: #ef4444;">
                <div class="name-row" style="justify-content: flex-end; gap: 10px;">
                    <div><span id="e-mp-text" class="mp-text">EN:100</span> <span id="e-hp-text">100/100</span></div>
                    <span id="e-name" style="color: #f87171;">ENEMY</span>
                </div>
                <div class="bar-bg" style="display: flex; justify-content: flex-end;"><div id="e-hp-bar" class="bar-fill" style="width: 100%;"></div></div>
                <div class="mp-bar-bg" style="display: flex; justify-content: flex-end;"><div id="e-mp-bar" class="mp-bar-fill" style="width: 100%;"></div></div>
            </div>
        </div>

        <div class="hud-bottom">
            <div id="dialogue-box" class="dialogue-box"><span id="dialogue-text">...</span></div>
            <div id="moves-container" class="hidden">
                <div id="menu-main" class="menu-grid-2x2">
                    <button class="action-btn" onclick="doBasicAttack()">ATTACK <br><span style="color:#60a5fa;font-size:8px;">+25 EN</span></button>
                    <button class="action-btn" onclick="switchBattleMenu('skills')">SKILL</button>
                    <button class="action-btn" onclick="doUltimate()" id="btn-main-ult">ULTIMATE</button>
                    <button class="action-btn" onclick="switchBattleMenu('items')">ITEM</button>
                </div>
                <div id="menu-skills" class="menu-grid-list hidden"></div>
                <div id="menu-items" class="menu-grid-list hidden">
                    <button class="action-btn" onclick="usePotion()" id="btn-use-potion" style="color: var(--hp-green);">POTION (x3)</button>
                    <button class="action-btn" onclick="switchBattleMenu('main')" style="color: #aaa;">BACK</button>
                </div>
                <div class="domain-container">
                    <div class="domain-label">DOMAIN</div>
                    <div class="domain-bar-bg"><div id="domain-bar-fill" class="domain-bar-fill"></div></div>
                </div>
                <div class="special-actions">
                    <button id="btn-swap" onclick="openSwapMenu(false)" style="color: #60a5fa;">SWAP</button>
                    <button id="btn-transform" onclick="attemptTransform()" style="color: #c084fc;">TRANSFORM</button>
                    <button id="btn-domain" onclick="attemptDomain()" style="color: var(--domain-purple);">DOMAIN</button>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    /* --- MASSIVE ANIME ABILITY DATABASE --- */
    const MOVE_TYPES = { STRIKE: 'STRIKE', BEAM: 'BEAM', BLAST: 'BLAST', SPECIAL: 'SPECIAL' };

    const ALL_ANIME_ABILITIES = [
        { n: "Kamehameha", pwr: 40, type: MOVE_TYPES.BEAM, anim: "beam_thick", color: "#60a5fa" },
        { n: "Dragon Fist", pwr: 80, type: MOVE_TYPES.STRIKE, anim: "dragon", color: "#eab308" },
        { n: "Spirit Bomb", pwr: 90, type: MOVE_TYPES.BLAST, anim: "spirit_bomb", color: "#93c5fd" },
        { n: "Death Beam", pwr: 35, type: MOVE_TYPES.BEAM, anim: "beam_thick", color: "#c084fc" },
        { n: "Supernova", pwr: 85, type: MOVE_TYPES.BLAST, anim: "death_ball", color: "#f97316" },
        { n: "Rasengan", pwr: 45, type: MOVE_TYPES.STRIKE, anim: "dash", color: "#93c5fd" },
        { n: "Rasenshuriken", pwr: 80, type: MOVE_TYPES.BLAST, anim: "disk", color: "#86efac" },
        { n: "Fireball Jutsu", pwr: 35, type: MOVE_TYPES.BLAST, anim: "death_ball", color: "#f97316" },
        { n: "Susanoo Slash", pwr: 70, type: MOVE_TYPES.STRIKE, anim: "slashes", color: "#c084fc" },
        { n: "Amaterasu", pwr: 65, type: MOVE_TYPES.BLAST, anim: "spirit_bomb", color: "#000" },
        { n: "Gum-Gum Pistol", pwr: 30, type: MOVE_TYPES.STRIKE, anim: "flurry", color: "#fca5a5" },
        { n: "Red Hawk", pwr: 60, type: MOVE_TYPES.STRIKE, anim: "dash", color: "#ef4444" },
        { n: "Thunder Bagua", pwr: 85, type: MOVE_TYPES.STRIKE, anim: "shatter", color: "#c084fc" },
        { n: "Divine Departure", pwr: 90, type: MOVE_TYPES.STRIKE, anim: "shatter", color: "#ef4444" },
        { n: "Getsuga Tensho", pwr: 55, type: MOVE_TYPES.BEAM, anim: "beam_huge", color: "#000", core: "#ef4444" },
        { n: "Cero", pwr: 40, type: MOVE_TYPES.BEAM, anim: "beam_thick", color: "#ef4444" },
        { n: "Hollow Purple", pwr: 95, type: MOVE_TYPES.BEAM, anim: "shatter", color: "#a855f7" },
        { n: "Cursed Technique: Blue", pwr: 60, type: MOVE_TYPES.BLAST, anim: "death_ball", color: "#3b82f6" },
        { n: "Cleave", pwr: 75, type: MOVE_TYPES.STRIKE, anim: "slashes", color: "#fca5a5" },
        { n: "Dismantle", pwr: 50, type: MOVE_TYPES.STRIKE, anim: "slashes", color: "#fff" },
        { n: "Detroit Smash", pwr: 70, type: MOVE_TYPES.STRIKE, anim: "world_shake", color: "#fff" },
        { n: "Serious Punch", pwr: 120, type: MOVE_TYPES.STRIKE, anim: "world_shake", color: "#fff" },
        // SANS EXCLUSIVES
        { n: "Gaster Blaster", pwr: 150, type: MOVE_TYPES.BEAM, anim: "beam_huge", color: "#fff", core: "#3b82f6" },
        { n: "Bone Smash", pwr: 90, type: MOVE_TYPES.STRIKE, anim: "slashes", color: "#fff" },
        { n: "Karmic Retribution", pwr: 120, type: MOVE_TYPES.BLAST, anim: "death_ball", color: "#a855f7" }
    ];

    ALL_ANIME_ABILITIES.forEach(m => { m.mpCost = Math.max(10, Math.floor(m.pwr * 0.45)); });

    const ULTIMATE_ATTACKS = [
        { n: "100% SMASH", pwr: 350, type: MOVE_TYPES.STRIKE, anim: "world_shake", color: "#fff" },
        { n: "TRUE KAMEHAMEHA", pwr: 320, type: MOVE_TYPES.BEAM, anim: "beam_huge", color: "#93c5fd", core: "#fff" },
        { n: "DOMAIN: MALEVOLENT", pwr: 380, type: MOVE_TYPES.SPECIAL, anim: "shatter", color: "#ef4444" },
        { n: "FINAL GETSUGA", pwr: 340, type: MOVE_TYPES.BEAM, anim: "blackhole", color: "#000", core: "#000" },
        { n: "GALAXY BREAKER", pwr: 400, type: MOVE_TYPES.BLAST, anim: "shatter", color: "#c084fc" },
        { n: "MEGALOVANIA", pwr: 666, type: MOVE_TYPES.SPECIAL, anim: "blackhole", color: "#3b82f6", core: "#fff" }
    ];

    const BASIC_ATTACK = { n: "BASIC STRIKE", pwr: 15, mpCost: 0, type: MOVE_TYPES.STRIKE, anim: "dash", color: "#fff" };

    const TRANSFORMATIONS = [
        { name: "SUPER FORM", mult: 1.5, color: "#fde047", msg: "Aura turns golden! Power surges!" },
