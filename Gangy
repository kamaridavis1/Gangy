<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>GANGY: Domain Clash</title>
    <link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-color: #050505;
            --gb-white: #f8f8f8;
            --gb-black: #181818;
            --gb-gray: #686868;
            --gb-lightgray: #a8a8a8;
        }

        body, html {
            margin: 0; padding: 0; width: 100%; height: 100%;
            background-color: var(--bg-color);
            display: flex; justify-content: center; align-items: center;
            font-family: 'Press Start 2P', monospace;
            color: var(--gb-black);
            user-select: none; touch-action: none;
            transition: background-color 0.5s, color 0.5s;
        }

        /* --- THEME OVERRIDES FOR CRAZY GUI EFFECTS --- */
        body.domain-ui {
            --bg-color: #0f001a;
            --gb-white: #1a0033;
            --gb-black: #e6ccff;
            --gb-gray: #9933ff;
            --gb-lightgray: #d9b3ff;
            animation: domainPulse 2s infinite alternate;
        }
        @keyframes domainPulse { 
            0% { box-shadow: inset 0 0 5vw #a855f7; } 
            100% { box-shadow: inset 0 0 15vw #6b21a8; } 
        }

        body.transformed-ui {
            --bg-color: #1a0000;
            --gb-white: #000;
            --gb-black: #fca5a5;
            --gb-gray: #ef4444;
            --gb-lightgray: #7f1d1d;
        }

        #game-wrapper {
            position: relative;
            width: 100%; max-width: 900px; aspect-ratio: 3 / 2;
            background-color: var(--gb-white);
            overflow: hidden; border: 0.5vw solid var(--gb-black);
            box-shadow: 0 10px 40px rgba(0,0,0,0.9);
            image-rendering: pixelated;
            transition: all 0.3s;
        }

        /* CRT Scanline Overlay */
        #game-wrapper::after {
            content: ""; position: absolute; top: 0; left: 0; width: 100%; height: 100%;
            background: linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.1) 50%);
            background-size: 100% 4px; z-index: 5; pointer-events: none;
        }

        canvas { position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 1; }

        #ui-layer {
            position: absolute; top: 0; left: 0; width: 100%; height: 100%;
            z-index: 10; pointer-events: none; display: flex; flex-direction: column;
        }

        .hidden { display: none !important; }

        /* --- BATTLE HUD --- */
        .hud-box {
            position: absolute; background: var(--gb-white);
            border: 0.4vw solid var(--gb-black); border-radius: 0.5vw;
            padding: 1vw; box-shadow: 0.4vw 0.4vw 0 rgba(0,0,0,0.3); z-index: 12;
            transition: border-color 0.3s, background 0.3s;
        }

        .hud-name { font-size: 1.6vw; margin-bottom: 0.5vw; text-transform: uppercase; color: var(--gb-black); }
        .hud-lv { font-size: 1vw; float: right; color: var(--gb-black); }
        
        .hp-container {
            display: flex; align-items: center; margin-bottom: 0.5vw;
            background: var(--gb-black); border-radius: 0.3vw; padding: 0.2vw 0.5vw;
        }
        .hp-label { color: #facc15; font-size: 1vw; margin-right: 0.5vw; }
        .hp-bar-bg { flex-grow: 1; height: 1vw; background: var(--gb-gray); border: 0.2vw solid var(--gb-black); border-radius: 0.3vw; position: relative; overflow: hidden;}
        .hp-bar-fill { height: 100%; background: #22c55e; width: 100%; transition: width 0.3s linear, background-color 0.3s; }
        .hp-text { font-size: 1.2vw; text-align: right; color: var(--gb-black); }

        #enemy-hud { top: 2vw; left: 2vw; width: 35%; }
        #player-hud { bottom: 33%; right: 2vw; width: 40%; }

        /* VULNERABLE STATE */
        .vulnerable-shake {
            animation: vulnShake 0.3s infinite;
            border-color: #ef4444 !important;
            background-color: #fee2e2 !important;
        }
        @keyframes vulnShake { 0% {transform: translateX(0);} 25% {transform: translateX(-0.5vw) rotate(-1deg);} 75% {transform: translateX(0.5vw) rotate(1deg);} }

        /* --- BOTTOM TEXT & MENU BOX --- */
        #bottom-panel {
            position: absolute; bottom: 0; left: 0; width: 100%; height: 30%;
            background: var(--gb-white); border-top: 0.5vw solid var(--gb-black);
            display: flex; pointer-events: auto; box-sizing: border-box; z-index: 15;
            transition: background 0.3s;
        }

        #dialogue-box {
            flex: 1; padding: 2vw; font-size: 1.6vw; line-height: 1.6; cursor: pointer;
            border-right: 0.5vw solid var(--gb-black); color: var(--gb-black);
        }

        #action-menu, #moves-menu {
            width: 45%; padding: 1vw; display: grid; grid-template-columns: 1fr 1fr;
            gap: 1vw; box-sizing: border-box;
        }

        .menu-btn {
            background: var(--gb-white); border: 0.3vw solid var(--gb-black); color: var(--gb-black);
            border-radius: 0.5vw; font-family: 'Press Start 2P', monospace;
            font-size: 1vw; cursor: pointer; text-transform: uppercase; transition: 0.1s;
        }
        .menu-btn:hover { background: var(--gb-lightgray); transform: scale(1.03); }
        .menu-btn:active { background: var(--gb-gray); color: white; }
        .menu-btn:disabled { opacity: 0.4; cursor: not-allowed; }
        .btn-highlight { border-color: #ef4444; color: #ef4444; animation: pulseBtn 1s infinite alternate; }
        @keyframes pulseBtn { from {transform: scale(1);} to {transform: scale(1.05); box-shadow: 0 0 10px #ef4444;} }

        /* --- GUI GLITCH EFFECTS --- */
        .glitch-effect { animation: guiGlitch 0.2s cubic-bezier(.25, .46, .45, .94) both infinite; }
        @keyframes guiGlitch {
            0% { transform: translate(0) skew(0deg); filter: invert(0) contrast(1); }
            20% { transform: translate(-1vw, 1vw) skew(5deg); filter: invert(1) hue-rotate(90deg) contrast(2); }
            40% { transform: translate(1vw, -1vw) skew(-5deg); filter: hue-rotate(-90deg) contrast(3); }
            60% { transform: translate(-1vw, -1vw) skew(2deg); filter: invert(0) saturate(5); }
            80% { transform: translate(1vw, 1vw) skew(-2deg); filter: invert(1) contrast(1); }
            100% { transform: translate(0) skew(0deg); filter: invert(0); }
        }

        /* --- OVERLAYS & CUTSCENES --- */
        #cutscene-layer, #clash-layer {
            position: absolute; top:0; left:0; width:100%; height:100%;
            z-index: 40; display: flex; flex-direction: column; justify-content: center; align-items: center;
            background: rgba(0,0,0,0.85); pointer-events: auto;
        }
        
        .cinematic-text {
            color: white; font-size: 4vw; text-shadow: 0.5vw 0.5vw 0 #ef4444;
            animation: cinematicSlide 0.5s ease-out forwards; text-align: center;
            line-height: 1.2;
        }
        @keyframes cinematicSlide {
            0% { transform: scale(3) rotate(-10deg); opacity: 0; }
            100% { transform: scale(1) rotate(0deg); opacity: 1; }
        }

        #clash-bar-container { width: 80%; height: 4vw; background: #333; border: 0.5vw solid white; margin-top: 2vw; position: relative; }
        #clash-bar-fill { height: 100%; width: 50%; background: #3b82f6; transition: width 0.1s; }
        .mash-btn {
            margin-top: 3vw; padding: 2vw 4vw; font-size: 3vw; background: #ef4444; color: white;
            border: 0.5vw solid white; cursor: pointer; font-family: 'Press Start 2P';
            border-radius: 1vw; animation: pulseBtn 0.2s infinite alternate;
        }

        /* Full Screens */
        .full-screen {
            position: absolute; top: 0; left: 0; width: 100%; height: 100%;
            display: flex; flex-direction: column; justify-content: center; align-items: center;
            text-align: center; pointer-events: auto; z-index: 50;
            background: var(--gb-white);
        }
        
        h1 { font-size: 4vw; color: var(--gb-black); margin-bottom: 1vw; text-shadow: 0.4vw 0.4vw 0 var(--gb-lightgray); }
        h2 { font-size: 1.8vw; color: var(--gb-gray); margin-bottom: 4vw; }
        
        .big-btn {
            padding: 1.5vw 3vw; font-size: 1.8vw; background: var(--gb-black); color: var(--gb-white);
            border: 0.5vw solid var(--gb-gray); cursor: pointer; font-family: 'Press Start 2P', monospace;
            margin-bottom: 1.5vw; width: 65%; text-transform: uppercase; transition: 0.2s;
        }
        .big-btn:hover { background: var(--gb-gray); transform: scale(1.05); }
        .blink { animation: blinker 1s linear infinite; }
        @keyframes blinker { 50% { opacity: 0; } }

    </style>
</head>
<body>

<div id="game-wrapper">
    <canvas id="gameCanvas" width="240" height="160"></canvas>

    <div id="ui-layer">
        <!-- Battle HUD -->
        <div id="battle-ui" class="hidden">
            <div id="enemy-hud" class="hud-box">
                <div class="hud-name" id="e-name">Enemy</div>
                <div class="hud-lv" id="e-lv">Lv5</div>
                <div class="hp-container">
                    <span class="hp-label">HP</span>
                    <div class="hp-bar-bg"><div class="hp-bar-fill" id="e-hp-bar"></div></div>
                </div>
            </div>

            <div id="player-hud" class="hud-box">
                <div class="hud-name">GANGY</div>
                <div class="hud-lv" id="p-lv">Lv5</div>
                <div class="hp-container">
                    <span class="hp-label">HP</span>
                    <div class="hp-bar-bg"><div class="hp-bar-fill" id="p-hp-bar"></div></div>
                </div>
                <div class="hp-container" style="margin-bottom:0.2vw;">
                    <span class="hp-label" style="color:#a855f7;">DOM</span>
                    <div class="hp-bar-bg" style="background:#333;"><div class="hp-bar-fill" id="p-domain-bar" style="background:#a855f7; width:0%;"></div></div>
                </div>
                <div class="hp-text" id="p-hp-text" style="font-size: 0.9vw;">100/100</div>
            </div>

            <div id="bottom-panel">
                <div id="dialogue-box" onclick="advanceText()">
                    <span id="dialogue-text"></span><span id="dialogue-arrow" class="blink hidden">▼</span>
                </div>
                
                <div id="action-menu" class="hidden">
                    <button class="menu-btn" onclick="openMoves()">FIGHT</button>
                    <button class="menu-btn" id="btn-domain" onclick="handleAction('domain')" style="color:#a855f7;" disabled>DOMAIN (0/5)</button>
                    <button class="menu-btn" id="btn-heal" onclick="handleAction('heal')">HEAL</button>
                    <button class="menu-btn" id="btn-ultimate" onclick="handleAction('ultimate')" style="color:#ef4444; font-weight:bold;">ULTIMATE</button>
                </div>

                <div id="moves-menu" class="hidden"></div>
            </div>
        </div>

        <div id="cutscene-layer" class="hidden"><h1 id="cutscene-text" class="cinematic-text">DOMAIN EXPANSION</h1></div>

        <div id="clash-layer" class="hidden">
            <h1 style="color:white; font-size:3vw; text-shadow: none;">BEAM CLASH!</h1>
            <div id="clash-bar-container"><div id="clash-bar-fill"></div></div>
            <button class="mash-btn" onclick="mashClash()">MASH CLICK!</button>
        </div>

        <!-- System Screens -->
        <div id="start-screen" class="full-screen">
            <h1>GANGY</h1>
            <h2 style="color: #a855f7;">DOMAIN CLASH</h2>
            <button class="big-btn" onclick="startGame()">START GAME</button>
        </div>

        <div id="upgrade-screen" class="full-screen hidden" style="background:var(--gb-black); color:white;">
            <h1 style="color:white; text-shadow:none;">BOSS DEFEATED!</h1>
            <button class="big-btn" style="background:white; color:black; border-color:white;" onclick="applyUpgrade('atk')">+ ATK POWER</button>
            <button class="big-btn" style="background:white; color:black; border-color:white;" onclick="applyUpgrade('hp')">+ MAX HP</button>
        </div>

        <div id="game-over-screen" class="full-screen hidden" style="background:#450a0a;">
            <h1 style="color:#fca5a5; text-shadow:none;">DEFEATED</h1>
            <h2 style="color:#fecaca;">Gangy's journey ends here...</h2>
            <button class="big-btn" style="background:#fca5a5; color:#450a0a;" onclick="location.reload()">RETRY</button>
        </div>

        <div id="win-screen" class="full-screen hidden" style="background:#fef08a;">
            <h1 style="color:#854d0e; text-shadow:none; font-size:3.5vw;">THE STRONGEST!</h1>
            <h2 style="color:#a16207;">You conquered the Academy!</h2>
            <button class="big-btn" style="background:#854d0e; color:#fef08a;" onclick="location.reload()">PLAY AGAIN</button>
        </div>

    </div>
</div>

<script>
    // Engine Base Setup
    const canvas = document.getElementById('gameCanvas');
    const ctx = canvas.getContext('2d');
    
    // Engine State
    let gameState = "START"; 
    let textQueue = []; let onQueueEmpty = null;
    let isTyping = false; let currentText = ""; let typedText = ""; let textCharIndex = 0; let typeSpeed = 2; 
    let frameCount = 0;

    let animState = null; let animTimer = 0; let animData = {}; let particles = [];
    let activeDomain = null; // {owner: 'player' | 'enemy', color1, color2, turnsLeft: int}
    
    let clashValue = 50; let clashActive = false; let clashTimer = 0;
    let currentEnemyIdx = 0;

    // --- SPRITES (16x16) ---
    const colors = {
        '0': null, '1': '#000000', '2': '#ffffff', '3': '#ef4444', '4': '#3b82f6', 
        '5': '#22c55e', '6': '#eab308', '7': '#fcd34d', '8': '#94a3b8', '9': '#a855f7', 
        'A': '#f97316', 'B': '#78350f', 'C': '#06b6d4', 'D': '#f43f5e'
    };

    const spr_player = [
        "0000011110000000", "0000144441000000", "0001444444100000", "0014444444410000",
        "0017777777710000", "0017777777710000", "0001444444100000", "0001122221100000",
        "0012222222210000", "0122222222221000", "0121222222121000", "0110111111011000",
        "0000110011000000", "0000110011000000", "0001110011100000", "0000000000000000"
    ];

    const spr_player_awaken = [
        "0000222222000000", "0002666666200000", "0026666666620000", "0266666666662000",
        "0267777777762000", "0267676676762000", "0026666666620000", "0021111111120000",
        "0211111111112000", "2111111111111200", "2111111111111200", "2110111111011200",
        "0000110011000000", "0000110011000000", "0001110011100000", "0000000000000000"
    ];

    const spr_kamari = [
        "0000011110000000", "0000199991000000", "0001999999100000", "0001719917100000",
        "0001721127100000", "0001799997100000", "0000111111000000", "0001133331100000",
        "0011133331110000", "0110133331011000", "0000111111000000", "0000110011000000",
        "0000110011000000", "0001110011100000", "0000000000000000", "0000000000000000"
    ];

    const spr_damin = [
        "0000011110000000", "0001A3333A100000", "0013333333310000", "0017711117710000",
        "0017721127710000", "0017771177710000", "00011AAAA1100000", "0001A1AA1A100000",
        "001AA1AA1AA10000", "00101AAAA1010000", "000011AA11000000", "0000110011000000",
        "0000110011000000", "0001110011100000", "0000000000000000", "0000000000000000"
    ];

    const spr_legend = [
        "0000111111000000", "0001666666100000", "0016666666610000", "0017711117710000",
        "00177C11C7710000", "0017777777710000", "0001122221100000", "0001216612100000",
        "0012216612210000", "0010122221010000", "0000112211000000", "0000110011000000",
        "0000110011000000", "0001110011100000", "0000000000000000", "0000000000000000"
    ];

    // --- GAME DATA ---
    let player = {
        name: "GANGY", level: 10, maxHp: 200, hp: 200, atk: 40,
        domainMeter: 0, vulnerable: false, transformed: false,
        domain: { name: "INFINITE VOID", color1: "#000000", color2: "#3b0764" },
        ultimate: { name: "HOLLOW PURPLE", msg: "GANGY unleashes HOLLOW PURPLE!" },
        moves: [
            { name: "KAMEHAMEHA", power: 1.0, type: "atk", color: "#3b82f6" },
            { name: "RASENGAN", power: 1.5, type: "atk_recoil", color: "#60a5fa" }
        ]
    };

    const enemies = [
        { name: "KAMARI", level: 12, maxHp: 250, hp: 250, atk: 25, sprite: spr_kamari, color: "#9333ea", 
          eMove: "SHADOW STRIKE", intro: "KAMARI HAS ARRIVED!",
          domain: { name: "SHADOW GARDEN", color1: "#111", color2: "#4c1d95" }, ultimate: { name: "DEMONIC SLASH", used: false } },
        { name: "DAMIN", level: 18, maxHp: 400, hp: 400, atk: 35, sprite: spr_damin, color: "#ef4444", 
          eMove: "FIRE ARROW", intro: "DAMIN HAS ENTERED VALLHALLA!",
          domain: { name: "MALEVOLENT SHRINE", color1: "#450a0a", color2: "#7f1d1d" }, ultimate: { name: "CLEAVE & DISMANTLE", used: false } },
        { name: "LEGEND", level: 25, maxHp: 650, hp: 650, atk: 55, sprite: spr_legend, color: "#eab308", 
          eMove: "LIGHT SPEED", intro: "THE URBAN LEGEND HAS ATTAINED KING STATUS...",
          domain: { name: "UNLIMITED BLADES", color1: "#713f12", color2: "#a16207" }, ultimate: { name: "EXCALIBUR BLAST", used: false } }
    ];

    let pPos = { x: 30, y: 80 }; let ePos = { x: 150, y: 10 }; 
    let pOff = { x: 0, y: 0 }; let eOff = { x: 0, y: 0 };
    let eFlash = false, pFlash = false, eVis = true, pVis = true;

    // --- ENGINE & RENDERING (FANCY 8-BIT SHADING) ---
    function emitParticles(x, y, color, count, speed=2, life=30) {
        for(let i=0; i<count; i++) {
            particles.push({
                x, y, vx: (Math.random()-0.5)*speed*2, vy: (Math.random()-0.5)*speed*2,
                color, life: life + Math.random()*10, maxLife: life
            });
        }
    }

    function updateParticles() {
        for(let i = particles.length-1; i>=0; i--) {
            let p = particles[i];
            p.x += p.vx; p.y += p.vy; p.life--;
            if (p.life <= 0) particles.splice(i, 1);
        }
    }

    function darkenColor(hex, factor) {
        if(!hex || hex === 'none') return '#000000';
        let r = parseInt(hex.slice(1,3), 16) * factor;
        let g = parseInt(hex.slice(3,5), 16) * factor;
        let b = parseInt(hex.slice(5,7), 16) * factor;
        return `rgb(${Math.floor(r)},${Math.floor(g)},${Math.floor(b)})`;
    }

    function drawSprite(arr, x, y, scale=4, flash=false, isTransformed=false) {
        if (!arr) return;
        
        // 1. Draw Drop Shadow
        ctx.fillStyle = 'rgba(0,0,0,0.4)';
        for(let r=0; r<16; r++) {
            for(let c=0; c<16; c++) {
                if(arr[r][c] !== '0') ctx.fillRect(x + c*scale + scale, y + r*scale + scale*2, scale, scale);
            }
        }

        // 2. Glowing Aura if transformed
        if (isTransformed) {
            ctx.shadowColor = '#eab308'; ctx.shadowBlur = 15;
        }

        // 3. Draw Main Pixels with Procedural Shading
        for (let r=0; r<16; r++) {
            for (let c=0; c<16; c++) {
                let ch = arr[r][c];
                if (ch !== '0') {
                    let fill = flash ? '#ffffff' : colors[ch];
                    // Apply darker shading to the lower half of the character (Fake 3D Lighting)
                    if (!flash && r > 9 && ch !== '1') fill = darkenColor(colors[ch], 0.6);
                    ctx.fillStyle = fill;
                    ctx.fillRect(x + c*scale, y + r*scale, scale, scale);
                }
            }
        }
        ctx.shadowBlur = 0; // reset
    }

    function renderGame() {
        ctx.clearRect(0, 0, 240, 160);
        let camX = 0, camY = 0;
        if (animState === "SHAKE") { camX = (Math.random() - 0.5) * 8; camY = (Math.random() - 0.5) * 8; }
        ctx.save(); ctx.translate(camX, camY);

        // Fancy Background
        if (activeDomain) {
            let shift = (frameCount % 40) / 40;
            let grad = ctx.createRadialGradient(120, 80, 10, 120, 80, 150 + Math.sin(frameCount*0.05)*20);
            grad.addColorStop(0, activeDomain.color1); grad.addColorStop(1, activeDomain.color2);
            ctx.fillStyle = grad; ctx.fillRect(0,0,240,160);
            if (frameCount%5===0) emitParticles(Math.random()*240, 160, '#ffffff', 1, 0.5, 60);
        } else {
            // Fancy Gradient Sky & Floor
            let skyGrad = ctx.createLinearGradient(0,0,0,100);
            skyGrad.addColorStop(0, '#d1d5db'); skyGrad.addColorStop(1, '#f3f4f6');
            ctx.fillStyle = skyGrad; ctx.fillRect(0, 0, 240, 100);
            
            let floorGrad = ctx.createLinearGradient(0,100,0,160);
            floorGrad.addColorStop(0, '#9ca3af'); floorGrad.addColorStop(1, '#6b7280');
            ctx.fillStyle = floorGrad; ctx.fillRect(0, 100, 240, 60);

            // Parallax Grid Floor
            ctx.fillStyle = 'rgba(0,0,0,0.1)';
            for(let i=0; i<160; i+=10) { ctx.fillRect(0, 100 + i, 240, 2); }

            // Shadow Pads
            ctx.fillStyle = 'rgba(0,0,0,0.3)';
            ctx.beginPath(); ctx.ellipse(180, 75, 45, 12, 0, 0, Math.PI*2); ctx.fill();
            ctx.beginPath(); ctx.ellipse(60, 145, 50, 15, 0, 0, Math.PI*2); ctx.fill();
        }

        let enemy = enemies[currentEnemyIdx];
        if (eVis && enemy) drawSprite(enemy.sprite, ePos.x + eOff.x, ePos.y + eOff.y, 4, eFlash, false);
        
        let pSprite = player.transformed ? spr_player_awaken : spr_player;
        if (pVis) drawSprite(pSprite, pPos.x + pOff.x, pPos.y + pOff.y, 4, pFlash, player.transformed);

        // Particles
        particles.forEach(p => {
            ctx.fillStyle = p.color;
            let size = Math.max(1, (p.life/p.maxLife) * 3);
            ctx.fillRect(p.x, p.y, size, size);
        });

        // Beam Attack
        if (animState === "BEAM") {
            ctx.fillStyle = animData.color; ctx.fillRect(animData.x, animData.y, animData.w, animData.h);
            ctx.fillStyle = '#fff'; ctx.fillRect(animData.x, animData.y + animData.h/4, animData.w, animData.h/2); // Inner beam core
            emitParticles(animData.x + (animData.w > 0 ? animData.w : 0), animData.y + animData.h/2, animData.color, 2, 4, 10);
        }

        ctx.restore();
    }

    // --- UI & MECHANICS ---
    function updateHUD() {
        let enemy = enemies[currentEnemyIdx];
        if(!enemy) return;

        // Enemy UI
        document.getElementById('e-name').innerText = enemy.name;
        document.getElementById('e-lv').innerText = `Lv${enemy.level}`;
        document.getElementById('e-hp-bar').style.width = Math.max(0, (enemy.hp / enemy.maxHp) * 100) + '%';

        // Player UI
        document.getElementById('p-lv').innerText = `Lv${player.level}`;
        document.getElementById('p-hp-text').innerText = `${Math.floor(player.hp)}/${player.maxHp}`;
        document.getElementById('p-hp-bar').style.width = Math.max(0, (player.hp / player.maxHp) * 100) + '%';

        // Domain Meter
        let dBar = document.getElementById('p-domain-bar');
        dBar.style.width = (player.domainMeter / 5) * 100 + '%';
        let btnDomain = document.getElementById('btn-domain');
        if (player.domainMeter >= 5) {
            btnDomain.disabled = false; btnDomain.innerText = "DOMAIN!";
            btnDomain.classList.add('btn-highlight');
        } else {
            btnDomain.disabled = true; btnDomain.innerText = `DOM (${player.domainMeter}/5)`;
            btnDomain.classList.remove('btn-highlight');
        }

        // Ultimate & Awaken Toggle
        let ultBtn = document.getElementById('btn-ultimate');
        let healBtn = document.getElementById('btn-heal');
        if (player.hp <= player.maxHp * 0.5) { 
            ultBtn.disabled = false; ultBtn.innerText = "ULTIMATE"; 
            if(!player.transformed) {
                healBtn.innerText = "AWAKEN"; healBtn.style.color = "#ef4444"; healBtn.classList.add('btn-highlight');
            }
        } else { 
            ultBtn.disabled = true; ultBtn.innerText = "ULT(50%)"; 
            if(!player.transformed) {
                healBtn.innerText = "HEAL"; healBtn.style.color = ""; healBtn.classList.remove('btn-highlight');
            }
        }

        // Vulnerable state visuals
        let pHud = document.getElementById('player-hud');
        if (player.vulnerable) {
            pHud.classList.add('vulnerable-shake');
            document.getElementById('p-hp-text').innerText += " (VULNERABLE!)";
        } else {
            pHud.classList.remove('vulnerable-shake');
        }
    }

    // --- TEXT QUEUE SYSTEM ---
    function queueText(text) { textQueue.push(text); }

    function processTextQueue() {
        if (textQueue.length > 0) {
            gameState = "TEXT";
            currentText = textQueue.shift(); typedText = ""; textCharIndex = 0; isTyping = true;
            document.getElementById('dialogue-box').classList.remove('hidden');
            document.getElementById('action-menu').classList.add('hidden');
            document.getElementById('moves-menu').classList.add('hidden');
            document.getElementById('dialogue-arrow').classList.add('hidden');
        } else {
            if (onQueueEmpty) { let cb = onQueueEmpty; onQueueEmpty = null; cb(); } 
            else { showActionMenu(); }
        }
    }

    window.advanceText = function() {
        if (gameState !== "TEXT" && gameState !== "INTRO") return;
        if (isTyping) {
            typedText = currentText; document.getElementById('dialogue-text').innerText = typedText;
            isTyping = false; textCharIndex = currentText.length;
            document.getElementById('dialogue-arrow').classList.remove('hidden');
        } else {
            if (gameState === "INTRO") {
                gameState = "BATTLE_WAIT"; queueText(`Go! ${player.name}!`); processTextQueue();
            } else { processTextQueue(); }
        }
    };

    function showActionMenu() {
        gameState = "MENU";
        document.getElementById('dialogue-text').innerText = `What will\n${player.name} do?`;
        document.getElementById('dialogue-arrow').classList.add('hidden');
        document.getElementById('action-menu').classList.remove('hidden');
        document.getElementById('moves-menu').classList.add('hidden');
        updateHUD();
    }

    window.openMoves = function() {
        document.getElementById('action-menu').classList.add('hidden');
        let movesMenu = document.getElementById('moves-menu');
        movesMenu.innerHTML = '';
        player.moves.forEach((m, i) => {
            let btn = document.createElement('button'); btn.className = 'menu-btn';
            btn.innerText = m.name; btn.style.color = m.color;
            btn.onclick = () => useMove(i); movesMenu.appendChild(btn);
        });
        let backBtn = document.createElement('button'); backBtn.className = 'menu-btn'; backBtn.style.gridColumn = 'span 2';
        backBtn.innerText = 'BACK'; backBtn.onclick = () => { movesMenu.classList.add('hidden'); document.getElementById('action-menu').classList.remove('hidden'); };
        movesMenu.appendChild(backBtn);
        movesMenu.classList.remove('hidden');
    }

    // --- BATTLE LOGIC ---
    window.startGame = function() {
        document.getElementById('start-screen').classList.add('hidden');
        document.getElementById('battle-ui').classList.remove('hidden');
        startEncounter();
    }

    function startEncounter() {
        let enemy = enemies[currentEnemyIdx];
        activeDomain = null;
        eVis = true; pVis = true; eOff = {x:0, y:0}; pOff = {x:0, y:0};
        updateHUD();
        
        gameState = "INTRO"; currentText = enemy.intro;
        typedText = ""; textCharIndex = 0; isTyping = true;
        document.getElementById('dialogue-box').classList.remove('hidden');
        document.getElementById('action-menu').classList.add('hidden');
        document.getElementById('moves-menu').classList.add('hidden');
    }

    window.handleAction = function(act) {
        if (gameState !== "MENU") return;
        document.getElementById('action-menu').classList.add('hidden');
        
        if (act === 'heal') {
            if (player.hp <= player.maxHp * 0.5 && !player.transformed) {
                // AWAKEN TRANSFORMATION
                document.getElementById('game-wrapper').classList.add('glitch-effect');
                setTimeout(() => document.getElementById('game-wrapper').classList.remove('glitch-effect'), 1000);
                
                document.body.className = 'transformed-ui';
                player.transformed = true;
                player.atk = Math.floor(player.atk * 1.5);
                
                playAnim('PLAYER_HEAL', () => {
                    player.hp = player.maxHp; updateHUD();
                    queueText(`${player.name} AWAKENED! Stats drastically boosted!`);
                    endPlayerTurn();
                }, '#fca5a5');
            } else {
                // Normal Heal
                queueText(`${player.name} used PLOT ARMOR!`);
                onQueueEmpty = () => {
                    playAnim('PLAYER_HEAL', () => {
                        player.hp = Math.min(player.maxHp, player.hp + player.maxHp*0.4);
                        updateHUD(); queueText(`Recovered HP!`);
                        endPlayerTurn();
                    }, '#22c55e');
                };
                processTextQueue();
            }
        } 
        else if (act === 'domain') {
            document.getElementById('game-wrapper').classList.add('glitch-effect');
            setTimeout(() => document.getElementById('game-wrapper').classList.remove('glitch-effect'), 500);
            
            triggerCutscene(`${player.name}:\nDOMAIN EXPANSION!\n${player.domain.name}`, () => {
                activeDomain = { owner: 'player', color1: player.domain.color1, color2: player.domain.color2, turnsLeft: 3 };
                player.domainMeter = 0;
                document.body.className = 'domain-ui';
                emitParticles(120, 80, '#ffffff', 50, 5, 60);
                queueText(`The battlefield shifted! You get 3 TURNS!`);
                endPlayerTurn();
            });
        } 
        else if (act === 'ultimate') {
            if (player.hp > player.maxHp * 0.5) return;
            document.getElementById('game-wrapper').classList.add('glitch-effect');
            setTimeout(() => document.getElementById('game-wrapper').classList.remove('glitch-effect'), 400);

            triggerCutscene(`ULTIMATE:\n${player.ultimate.name}!`, () => {
                queueText(player.ultimate.msg);
                onQueueEmpty = () => {
                    let enemy = enemies[currentEnemyIdx];
                    if (enemy.hp <= enemy.maxHp * 0.5 && !enemy.ultimate.used) {
                        enemy.ultimate.used = true;
                        triggerCutscene(`ENEMY COUNTERS:\n${enemy.ultimate.name}!`, startClash);
                    } else {
                        playAnim('PLAYER_ULTIMATE', () => {
                            let dmg = getDamage(player.atk, 4.0, 'player');
                            enemy.hp = Math.max(0, enemy.hp - dmg); updateHUD();
                            queueText(`Devastating Hit! ${dmg} DMG!`);
                            endPlayerTurn();
                        });
                    }
                };
                processTextQueue();
            });
        }
    }

    window.useMove = function(idx) {
        let m = player.moves[idx];
        document.getElementById('action-menu').classList.add('hidden');
        document.getElementById('moves-menu').classList.add('hidden');
        queueText(`${player.name} used ${m.name}!`);

        onQueueEmpty = () => {
            playAnim('PLAYER_ATTACK', () => {
                let e = enemies[currentEnemyIdx];
                let dmg = getDamage(player.atk, m.power, 'player');
                e.hp = Math.max(0, e.hp - dmg); updateHUD();
                queueText(`Dealt ${dmg} damage!`);
                if (m.type === 'atk_recoil') {
                    let r = Math.floor(player.maxHp * 0.1); player.hp = Math.max(0, player.hp - r);
                    queueText(`Hit with recoil!`); updateHUD();
                }
                endPlayerTurn();
            }, m.color);
        };
        processTextQueue();
    }

    function getDamage(base, mult, attacker) {
        let d = Math.floor(base * mult * (0.85 + Math.random()*0.3));
        if (activeDomain && activeDomain.owner === attacker) d = Math.floor(d * 1.5);
        if (attacker === 'enemy' && player.vulnerable) d = Math.floor(d * 2.0);
        if (attacker === 'player' && player.vulnerable) d = Math.floor(d * 0.5);
        return d;
    }

    function endPlayerTurn() {
        onQueueEmpty = () => {
            if (enemies[currentEnemyIdx].hp <= 0) { handleVictory(); return; }
            if (player.hp <= 0) { handleDefeat(); return; }

            player.vulnerable = false; // Reset vulnerability after player takes a turn

            // DOMAIN MULTI-TURN LOGIC
            if (activeDomain && activeDomain.owner === 'player') {
                activeDomain.turnsLeft--;
                if (activeDomain.turnsLeft > 0) {
                    queueText(`DOMAIN ACTIVE! (${activeDomain.turnsLeft} turns left)`);
                    onQueueEmpty = showActionMenu; processTextQueue();
                } else {
                    document.getElementById('game-wrapper').classList.add('glitch-effect');
                    setTimeout(() => document.getElementById('game-wrapper').classList.remove('glitch-effect'), 500);
                    
                    queueText(`DOMAIN COLLAPSED! ${player.name} is VULNERABLE!`);
                    activeDomain = null;
                    player.vulnerable = true;
                    document.body.className = player.transformed ? 'transformed-ui' : ''; // Reset UI
                    onQueueEmpty = executeEnemyTurn; processTextQueue();
                }
            } else {
                player.domainMeter = Math.min(5, player.domainMeter + 1);
                executeEnemyTurn();
            }
        };
        processTextQueue();
    }

    function executeEnemyTurn() {
        let e = enemies[currentEnemyIdx];
        
        if (e.hp <= e.maxHp * 0.5 && !e.ultimate.used) {
            e.ultimate.used = true;
            triggerCutscene(`${e.name}:\n${e.ultimate.name}!`, () => {
                queueText(`${e.name} unleashed their Ultimate!`);
                onQueueEmpty = () => {
                    if (player.hp <= player.maxHp * 0.5) {
                        queueText(`Counter with your ULTIMATE?`);
                        onQueueEmpty = () => {
                            document.getElementById('dialogue-text').innerText = "COUNTER?";
                            document.getElementById('action-menu').innerHTML = `
                                <button class="menu-btn" style="color:red; grid-column: span 2;" onclick="acceptClash()">YES (ULTIMATE)</button>
                                <button class="menu-btn" style="grid-column: span 2;" onclick="declineClash()">NO (DEFEND)</button>
                            `;
                            document.getElementById('action-menu').classList.remove('hidden');
                            gameState = "MENU";
                        };
                        processTextQueue();
                    } else {
                        playAnim('ENEMY_ULTIMATE', () => {
                            let dmg = getDamage(e.atk, 4.0, 'enemy');
                            player.hp = Math.max(0, player.hp - dmg); updateHUD();
                            queueText(`You couldn't counter! Took ${dmg} DMG!`);
                            onQueueEmpty = () => { if(player.hp<=0) handleDefeat(); else showActionMenu(); };
                            processTextQueue();
                        });
                    }
                };
                processTextQueue();
            });
            return;
        }

        if (!activeDomain && Math.random() < 0.2) {
            triggerCutscene(`${e.name}: DOMAIN EXPANSION!\n${e.domain.name}`, () => {
                activeDomain = { owner: 'enemy', color1: e.domain.color1, color2: e.domain.color2, turnsLeft: 99 };
                emitParticles(120, 80, '#000000', 50, 5, 60);
                queueText(`The enemy expanded their Domain!`);
                onQueueEmpty = showActionMenu; processTextQueue();
            });
            return;
        }

        queueText(`--- ENEMY TURN ---`);
        queueText(`${e.name} used ${e.eMove}!`);
        onQueueEmpty = () => {
            playAnim('ENEMY_ATTACK', () => {
                let dmg = getDamage(e.atk, 1.2, 'enemy');
                player.hp = Math.max(0, player.hp - dmg); updateHUD();
                queueText(`Took ${dmg} damage!`);
                onQueueEmpty = () => { if(player.hp<=0) handleDefeat(); else showActionMenu(); };
                processTextQueue();
            }, e.color);
        };
        processTextQueue();
    }

    // --- BEAM CLASH SYSTEM ---
    window.acceptClash = function() {
        document.getElementById('action-menu').classList.add('hidden');
        resetActionMenu();
        document.getElementById('game-wrapper').classList.add('glitch-effect');
        setTimeout(() => document.getElementById('game-wrapper').classList.remove('glitch-effect'), 500);
        triggerCutscene(`${player.name}:\n${player.ultimate.name}!`, startClash);
    }

    window.declineClash = function() {
        document.getElementById('action-menu').classList.add('hidden');
        resetActionMenu();
        let e = enemies[currentEnemyIdx];
        playAnim('ENEMY_ULTIMATE', () => {
            let dmg = getDamage(e.atk, 3.0, 'enemy');
            player.hp = Math.max(0, player.hp - dmg); updateHUD();
            queueText(`Guarded! But still took ${dmg} DMG!`);
            onQueueEmpty = () => { if(player.hp<=0) handleDefeat(); else showActionMenu(); };
            processTextQueue();
        });
    }

    function resetActionMenu() {
        document.getElementById('action-menu').innerHTML = `
            <button class="menu-btn" onclick="openMoves()">FIGHT</button>
            <button class="menu-btn" id="btn-domain" onclick="handleAction('domain')" style="color:#a855f7;">DOMAIN</button>
            <button class="menu-btn" id="btn-heal" onclick="handleAction('heal')">HEAL</button>
            <button class="menu-btn" id="btn-ultimate" onclick="handleAction('ultimate')" style="color:#ef4444; font-weight:bold;">ULTIMATE</button>
        `;
    }

    function startClash() {
        gameState = "CLASH"; clashActive = true; clashValue = 50; clashTimer = 100;
        document.getElementById('clash-layer').classList.remove('hidden');
        updateClashUI();
    }

    window.mashClash = function() {
        if(!clashActive) return;
        clashValue += 6; 
        emitParticles(120, 80, '#3b82f6', 2, 8, 20);
        updateClashUI();
    }

    function updateClashUI() {
        let bar = document.getElementById('clash-bar-fill');
        bar.style.width = Math.max(0, Math.min(100, clashValue)) + '%';
        bar.style.backgroundColor = clashValue > 50 ? '#3b82f6' : '#ef4444';
    }

    function resolveClash() {
        clashActive = false;
        document.getElementById('clash-layer').classList.add('hidden');
        
        let e = enemies[currentEnemyIdx];
        if (clashValue >= 100 || (clashValue > 50 && clashTimer <= 0)) {
            playAnim('PLAYER_ULTIMATE', () => {
                let dmg = getDamage(player.atk, 5.0, 'player'); 
                e.hp = Math.max(0, e.hp - dmg); updateHUD();
                queueText(`CLASH WON! You overwhelmed ${e.name}! Dealt ${dmg} DMG!`);
                endPlayerTurn();
            });
        } else {
            playAnim('ENEMY_ULTIMATE', () => {
                let dmg = getDamage(e.atk, 5.0, 'enemy'); 
                player.hp = Math.max(0, player.hp - dmg); updateHUD();
                queueText(`CLASH LOST! Overpowered! Took ${dmg} DMG!`);
                onQueueEmpty = () => { if(player.hp<=0) handleDefeat(); else showActionMenu(); };
                processTextQueue();
            });
        }
    }

    // --- ANIMATIONS & CUTSCENES ---
    function triggerCutscene(text, callback) {
        gameState = "CUTSCENE";
        let layer = document.getElementById('cutscene-layer');
        let textEl = document.getElementById('cutscene-text');
        textEl.innerText = text;
        textEl.style.animation = 'none'; textEl.offsetHeight; textEl.style.animation = null;
        layer.classList.remove('hidden');
        setTimeout(() => { layer.classList.add('hidden'); callback(); }, 1500);
    }

    function playAnim(type, callback, color = '#ffffff') {
        animState = type; animTimer = 0; animData.color = color;
        
        let int = setInterval(() => {
            animTimer++;
            if (type === 'PLAYER_ATTACK') {
                if(animTimer===1) pOff.x = 10; 
                if(animTimer===10) { pOff.x=0; animState="BEAM"; animData={x:80,y:90,w:0,h:12,color}; }
                if(animTimer>10 && animTimer<20) animData.w += 15;
                if(animTimer===20) { animState="SHAKE"; eFlash=true; emitParticles(150,30,color,15,5,20); }
                if(animTimer===35) { eFlash=false; animState=null; clearInterval(int); callback(); }
            }
            else if (type === 'ENEMY_ATTACK') {
                if(animTimer===1) eOff.x = -10; 
                if(animTimer===10) { eOff.x=0; animState="BEAM"; animData={x:150,y:30,w:0,h:18,color}; }
                if(animTimer>10 && animTimer<20) { animData.w -= 15; animData.x -= 15; }
                if(animTimer===20) { animState="SHAKE"; pFlash=true; emitParticles(30,80,color,15,5,20); }
                if(animTimer===35) { pFlash=false; animState=null; clearInterval(int); callback(); }
            }
            else if (type === 'PLAYER_HEAL') {
                if(animTimer%5===0) emitParticles(pPos.x+16, pPos.y+16, color, 4, 3, 20);
                if(animTimer===30) { animState=null; clearInterval(int); callback(); }
            }
            else if (type === 'PLAYER_ULTIMATE') {
                if(animTimer===1) { animState="SHAKE"; emitParticles(pPos.x+16, pPos.y+16, '#3b82f6', 30, 8, 40); }
                if(animTimer===20) { animState="BEAM"; animData={x:50,y:10,w:0,h:140,color:'#a855f7'}; } // massive beam
                if(animTimer>20 && animTimer<30) animData.w += 20;
                if(animTimer===30) { animState="SHAKE"; eFlash=true; emitParticles(150,30,'#a855f7',40,10,30); document.getElementById('game-wrapper').classList.add('glitch-effect'); }
                if(animTimer===60) { eFlash=false; animState=null; document.getElementById('game-wrapper').classList.remove('glitch-effect'); clearInterval(int); callback(); }
            }
            else if (type === 'ENEMY_ULTIMATE') {
                let ec = enemies[currentEnemyIdx].color;
                if(animTimer===1) { animState="SHAKE"; emitParticles(ePos.x+16, ePos.y+16, ec, 30, 8, 40); }
                if(animTimer===20) { animState="BEAM"; animData={x:190,y:10,w:0,h:140,color:ec}; } 
                if(animTimer>20 && animTimer<30) { animData.w -= 20; animData.x -= 20; }
                if(animTimer===30) { animState="SHAKE"; pFlash=true; emitParticles(30,80,ec,40,10,30); document.getElementById('game-wrapper').classList.add('glitch-effect'); }
                if(animTimer===60) { pFlash=false; animState=null; document.getElementById('game-wrapper').classList.remove('glitch-effect'); clearInterval(int); callback(); }
            }
            else if (type === 'ENEMY_FAINT') {
                eOff.y += 4; emitParticles(ePos.x+16, ePos.y+eOff.y, '#ffffff', 2, 1, 10);
                if (animTimer === 30) { eVis = false; animState=null; clearInterval(int); callback(); }
            }
        }, 1000/60); 
    }

    function handleVictory() {
        let e = enemies[currentEnemyIdx];
        playAnim('ENEMY_FAINT', () => {
            queueText(`You defeated ${e.name}!`);
            queueText(`${player.name} grew to level ${player.level + 2}!`);
            onQueueEmpty = () => {
                currentEnemyIdx++;
                if (currentEnemyIdx >= enemies.length) {
                    document.getElementById('win-screen').classList.remove('hidden'); gameState = "WIN";
                } else {
                    document.getElementById('upgrade-screen').classList.remove('hidden'); gameState = "UPGRADE";
                }
            };
            processTextQueue();
        });
    }

    function handleDefeat() {
        queueText(`${player.name} was overwhelmed...`);
        onQueueEmpty = () => { document.getElementById('game-over-screen').classList.remove('hidden'); gameState = "GAMEOVER"; };
        processTextQueue();
    }

    window.applyUpgrade = function(type) {
        if (type === 'atk') player.atk += 15;
        if (type === 'hp') player.maxHp += 50;
        player.hp = player.maxHp; player.level += 2;
        document.getElementById('upgrade-screen').classList.add('hidden');
        startEncounter();
    }

    // --- MAIN LOOP ---
    function gameLoop() {
        frameCount++;
        
        if (gameState === "TEXT" || gameState === "INTRO") {
            if (isTyping && frameCount % typeSpeed === 0) {
                typedText += currentText.charAt(textCharIndex);
                document.getElementById('dialogue-text').innerText = typedText;
                textCharIndex++;
                if (textCharIndex >= currentText.length) {
                    isTyping = false; document.getElementById('dialogue-arrow').classList.remove('hidden');
                }
            }
        } else if (gameState === "CLASH") {
            clashTimer--; clashValue -= 1.5; updateClashUI();
            if(frameCount%2===0) emitParticles(120 + (clashValue-50)*2, 80, (Math.random()>0.5?'#3b82f6':'#ef4444'), 2, 6, 15);
            if (clashValue >= 100 || clashValue <= 0 || clashTimer <= 0) resolveClash();
        }

        updateParticles(); renderGame();
        requestAnimationFrame(gameLoop);
    }
    
    // START THE ENGINE
    requestAnimationFrame(gameLoop);

</script>
</body>
</html>
